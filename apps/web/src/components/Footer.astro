---
import type { MenuItem } from '../types';
import MenuIcon from './MenuIcon.astro';

interface Props {
  siteTitle?: string;
  icp?: string;
  footerText?: string;
  siteStartDate?: string;
  footerTechInfo?: string;
  menus?: MenuItem[];
  apiUrl?: string;
  showMotto?: string;
  mottoTitle?: string;
  mottoText?: string;
  mottoCtaText?: string;
  mottoCtaUrl?: string;
  mottoCtaTarget?: string;
  footerBadges?: string;
}

const {
  siteTitle = 'mccsjs',
  icp = '',
  footerText = '',
  siteStartDate = '',
  footerTechInfo = '',
  menus = [],
  apiUrl = '',
  showMotto = 'true',
  mottoTitle = '格言🧬',
  mottoText = '',
  mottoCtaText = '',
  mottoCtaUrl = '',
  mottoCtaTarget = '_self',
  footerBadges = '',
} = Astro.props;

// 解析页脚徽标（footerBadges 为 JSON 字符串数组）
let badges: { title: string; href: string; img: string }[] = [];
try {
  if (footerBadges) badges = JSON.parse(footerBadges);
} catch {
  badges = [];
}

const year = new Date().getFullYear();
const startYear = siteStartDate ? new Date(siteStartDate).getFullYear() : NaN;
const copyrightRange = !isNaN(startYear) && startYear < year ? `${startYear} - ${year}` : `${year}`;
const visibleMenus = menus.filter((m) => m.visible);

// 「猜你想看」：展开所有可见菜单（含子菜单），取前 8 个做两列布局
const guessLinks: { label: string; href: string; target?: string }[] = [];
for (const m of visibleMenus) {
  if (m.children?.length) {
    for (const c of m.children.filter((c) => c.visible)) {
      guessLinks.push({ label: c.label, href: c.href || '#', target: c.target || undefined });
    }
  } else {
    guessLinks.push({ label: m.label, href: m.href || '#', target: m.target || undefined });
  }
}

// 「推荐友链」：从后端 /api/friends/recommended 拉取（仅 recommended=true 的友链）
let friends: { name: string; url: string; avatar: string }[] = [];
try {
  if (apiUrl) {
    const res = await fetch(`${apiUrl}/api/friends/recommended`);
    if (res.ok) {
      const data = await res.json();
      for (const f of data || []) {
        friends.push({ name: f.name, url: f.url, avatar: f.avatar || f.screenshot || '' });
      }
    }
  }
} catch {
  // API 不可用时走兜底
}
// 兜底：后端未设置任何推荐友链时，展示技术栈占位（与旧版页脚一致，可删）
if (friends.length === 0) {
  friends = [
    { name: 'Astro', url: 'https://astro.build', avatar: 'https://astro.build/assets/press/astro-icon-dark.png' },
    { name: 'Elysia', url: 'https://elysiajs.com', avatar: 'https://elysiajs.com/assets/elysia.svg' },
    { name: 'Prisma', url: 'https://prisma.io', avatar: 'https://prisma.io/images/apple-touch-icon.png' },
    { name: 'Tailwind CSS', url: 'https://tailwindcss.com', avatar: 'https://tailwindcss.com/favicons/apple-touch-icon.png' },
  ];
}
---

<footer class="site-footer">
  <div id="footer-wrap">
    <!-- 顶部分区：格言 + 猜你想看 / 推荐友链 -->
    <div id="ft">
      {/* 左：格言 + 猜你想看 */}
      <div class="ft-item-1">
        <div class="t-top">
          {/* 格言 */}
          {showMotto !== 'false' && (
            <div class="t-t-l">
              <p class="ft-t t-l-t">{mottoTitle}</p>
              <div class="bg-ad">
                {mottoText && <div class="motto">{mottoText}</div>}
                {mottoCtaText && (
                  <div class="btn-xz-box">
                    <a
                      class="btn-xz"
                      href={mottoCtaUrl || '#'}
                      target={mottoCtaTarget === '_blank' ? '_blank' : undefined}
                      rel={mottoCtaTarget === '_blank' ? 'noopener noreferrer' : undefined}
                    >{mottoCtaText}</a>
                  </div>
                )}
              </div>
            </div>
          )}
          {/* 猜你想看 */}
          <div class="t-t-r">
            <p class="ft-t t-l-t">猜你想看💡</p>
            <ul class="ft-links">
              {Array.from({ length: Math.ceil(guessLinks.length / 2) }).map((_, row) => (
                <li>
                  {guessLinks.slice(row * 2, row * 2 + 2).map((l) => (
                    <a href={l.href} target={l.target || undefined}>{l.label}</a>
                  ))}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>

      {/* 右：推荐友链 */}
      <div class="ft-item-2">
        <p class="ft-t">推荐友链⌛</p>
        <div class="ft-img-group">
          {friends.map((f) => (
            <div class="img-group-item">
              <a href={f.url} title={f.name} target="_blank" rel="noopener noreferrer">
                {f.avatar ? (
                  <img src={f.avatar} alt={f.name} loading="lazy" />
                ) : (
                  <span class="img-fallback">{f.name.slice(0, 1)}</span>
                )}
              </a>
            </div>
          ))}
          {/* 广告位招占位（有互动效果，不跳转） */}
          <div class="img-group-item img-group-ad">
            <span title="广告位招租" class="ad-placeholder-btn">
              <img src="/img/ad-placeholder.webp" alt="广告位招租" loading="lazy" />
            </span>
          </div>
        </div>
      </div>
    </div>

    {/* 版权 */}
    <div class="copyright">
      <span><b>&copy;{copyrightRange} {siteTitle}</b></span>
    </div>

    {/* 网站运行时长计时器 */}
    {siteStartDate && <div id="workboard"></div>}

    {/* 框架信息 */}
    {footerTechInfo ? (
      <div class="framework-info">{footerTechInfo}</div>
    ) : (
      <div class="framework-info">
        <span>由 </span>
        <a href="https://astro.build" target="_blank" rel="noopener noreferrer">Astro</a>
        <span class="footer-separator">|</span>
        <span>前端 </span>
        <a href="https://tailwindcss.com" target="_blank" rel="noopener noreferrer">Tailwind CSS</a>
        <span class="footer-separator">|</span>
        <span>后端 </span>
        <a href="https://elysiajs.com" target="_blank" rel="noopener noreferrer">ElysiaJS</a>
      </div>
    )}

    {/* 自定义页脚文字 */}
    {footerText && <div class="footer_custom_text" set:html={footerText} />}

    {/* shields.io 徽章（来自系统设置「页脚设置」） */}
    {(badges.length > 0 || icp) && (
      <p id="ghbdages">
        {badges.map((b) => (
          <a class="github-badge" target="_blank" href={b.href} title={b.title}>
            <img src={b.img} alt="" loading="lazy" />
          </a>
        ))}
        {icp && (
          <a class="github-badge" target="_blank" href="https://beian.miit.gov.cn/" title="ICP 备案">
            <img src={`https://img.shields.io/badge/ICP-${icp}-a8d5b8?style=flat`} alt="" />
          </a>
        )}
      </p>
    )}
  </div>
</footer>

<style>
  .site-footer {
    margin-top: auto;
    border-top: 1px solid rgb(var(--card-border));
    background: rgb(var(--bg-soft) / 0.55);
    backdrop-filter: blur(12px) saturate(140%);
    color: rgb(var(--fg-muted));
  }

  #footer-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 12px 20px 0;
    max-width: 1200px;
    margin: 0 auto;
  }

  /* 顶部分区：左(格言+猜你想看) 右(友链) */
  #ft {
    width: 100%;
    display: flex;
    flex-wrap: wrap;
    text-align: left;
    color: rgb(var(--fg-muted));
    margin-bottom: 14px;
  }
  .ft-item-1,
  .ft-item-2 {
    display: flex;
    height: 100%;
    padding: 10px 14px;
  }
  .ft-item-1 {
    flex: 2;
    flex-direction: column;
  }
  .ft-item-2 {
    flex: 1;
    flex-direction: column;
  }

  .t-top {
    display: flex;
  }
  .t-top .t-t-l {
    display: flex;
    flex-direction: column;
    flex: 1.4;
    margin-right: 10px;
  }
  .t-top .t-t-r {
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  /* 格言卡片（玻璃拟态） */
  .t-top .t-t-l .bg-ad {
    width: 85%;
    border-radius: 16px;
    padding: 14px 16px;
    background: transparent;
    border: none;
    backdrop-filter: none;
  }
  .motto {
    font-size: 0.82rem;
    line-height: 1.7;
    color: rgb(var(--fg-soft));
  }
  .btn-xz-box {
    margin-top: 12px;
  }
  .btn-xz {
    display: block;
    background: var(--color-accent-sand);
    color: var(--color-ink-700);
    text-align: center;
    line-height: 2.4;
    border-radius: 16px;
    font-weight: 600;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .btn-xz:hover {
    text-decoration: none;
    background: #c4a884;
    transform: translateY(-2px);
    box-shadow: 0 8px 20px -8px rgba(0, 0, 0, 0.35);
  }

  /* 猜你想看：两列链接 */
  .ft-links {
    padding: 0 14px;
    list-style: none;
    margin: 0;
  }
  .ft-links li {
    display: flex;
    gap: 0;
  }
  .ft-links li a {
    flex: 1;
    box-sizing: border-box;
    cursor: pointer;
    padding: 4px 8px;
    border-radius: 12px;
    color: rgb(var(--fg-soft));
    transition: color 0.25s ease, transform 0.2s ease;
  }
  .ft-links li a:hover {
    text-decoration: none;
    color: #facc15;
    transform: translateX(3px);
  }

  /* 推荐友链头像网格 — 5列自适应 */
  .ft-item-2 .ft-img-group {
    width: 100%;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .ft-t {
    font-size: 0.8rem;
    margin-bottom: 18px;
    line-height: 1;
    font-weight: 700;
    color: rgb(var(--fg-soft));
  }
  .t-l-t {
    padding-left: 14px;
  }
  .ft-item-2 .ft-img-group .img-group-item {
    width: calc(20% - 8px);
    flex-shrink: 0;
  }
  .ft-item-2 .ft-img-group .img-group-item a {
    display: block;
    width: 100%;
    aspect-ratio: 1;
    border-radius: 12px;
    overflow: hidden;
    background: rgb(var(--card-bg) / 0.6);
    border: 1px solid rgb(var(--card-border));
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .ft-item-2 .ft-img-group .img-group-item a:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 22px -10px rgba(0, 0, 0, 0.4);
    border-color: var(--color-accent-sand);
  }

  /* 广告位占位按钮：互动效果但不跳转 */
  .ad-placeholder-btn {
    display: block;
    width: 100%;
    aspect-ratio: 1;
    border-radius: 12px;
    overflow: hidden;
    cursor: pointer;
    background: linear-gradient(135deg, rgba(59,130,246,.08), rgba(147,197,253,.12));
    position: relative;
    transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .ad-placeholder-btn::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 12px;
    opacity: 0;
    background: radial-gradient(circle at center, rgba(59,130,246,.18) 0%, transparent 70%);
    transition: opacity 0.35s ease;
  }
  .ad-placeholder-btn img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 11px;
    border: 1px solid rgba(255, 255, 255, 0.55);
    box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.06);
    opacity: 0.85;
    transition: all 0.35s ease;
  }
  .ad-placeholder-btn:hover {
    transform: translateY(-3px) scale(1.03);
    box-shadow: 0 10px 26px -10px rgba(59, 130, 246, 0.45);
    background: linear-gradient(135deg, rgba(59,130,246,.14), rgba(147,197,253,.18));
  }
  .ad-placeholder-btn:hover::after {
    opacity: 1;
  }
  .ad-placeholder-btn:hover img {
    opacity: 1;
  }
  .ad-placeholder-btn:active {
    transform: translateY(-1px) scale(1.01);
    box-shadow: 0 4px 14px -8px rgba(59, 130, 246, 0.4);
  }
  .ft-item-2 .ft-img-group .img-group-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .img-fallback {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-accent-sand);
  }

  /* 版权 / 框架信息 / 自定义文字 */
  #footer-wrap .copyright,
  #footer-wrap .framework-info,
  #footer-wrap .footer_custom_text,
  #footer-wrap #ghbdages {
    margin: 0 auto;
  }
  .copyright {
    font-size: 1rem;
    margin-top: -16px !important;
  }
  #workboard {
    font-size: 0.82rem;
    font-weight: 700;
    margin-top: 6px;
    color: rgb(var(--fg-soft));
    letter-spacing: 0.5px;
  }
  .runtime-heart {
    display: inline-block;
    margin-left: 2px;
    animation: heartbeat 1.2s ease-in-out infinite;
  }
  .framework-info {
    font-size: 0.8rem;
    margin-top: 10px;
  }
  .framework-info a {
    color: var(--color-accent-sky);
    transition: color 0.25s ease;
  }
  .framework-info a:hover {
    color: var(--color-accent-sand);
  }
  .footer-separator {
    margin: 0 4px;
    opacity: 0.5;
  }
  .footer_custom_text {
    margin-top: 8px;
    font-size: 0.8rem;
  }

  /* shields 徽章 */
  #ghbdages {
    display: block;
    margin-top: 6px;
  }
  .github-badge {
    display: inline-block;
    margin: 2px 5px;
  }
  .github-badge img {
    border-radius: 4px;
    transition: transform 0.25s ease;
  }
  .github-badge:hover img {
    transform: scale(1.06);
  }

  /* 响应式 */
  @media screen and (max-width: 768px) {
    .ft-item-1,
    .ft-item-2 {
      flex-basis: 100% !important;
    }
    .t-top .t-t-l .bg-ad {
      width: 100%;
    }

    /* 手机端底部区域：增加间距避免拥挤 */
    #footer-wrap {
      padding: 16px 20px 24px;
    }
    .copyright {
      margin-top: 0 !important;
    }
    #workboard {
      margin-top: 8px;
      font-size: 0.78rem;
    }
    .framework-info {
      margin-top: 10px;
      font-size: 0.72rem;
      line-height: 1.5;
    }
    .framework-info .footer-separator {
      margin: 0 3px;
    }
    #ghbdages {
      margin-top: 12px;
    }
    .github-badge {
      margin: 3px 4px;
    }
    .github-badge img {
      max-height: 22px;
    }
  }
  @media screen and (max-width: 576px) {
    .t-top {
      flex-wrap: wrap;
    }
    .t-top .t-t-l,
    .t-top .t-t-r {
      flex-basis: 100% !important;
    }
    .t-top .t-t-r {
      margin-top: 16px;
    }
    .ft-item-2 .ft-img-group .img-group-item {
      width: calc(20% - 8px);
    }
    .ad-placeholder-btn {
      /* 跟随 aspect-ratio:1 自动正方 */
    }

    /* 小屏底部进一步宽松 */
    #workboard {
      font-size: 0.75rem;
    }
    .framework-info {
      font-size: 0.7rem;
    }
    .github-badge img {
      max-height: 20px;
    }
  }
  @keyframes heartbeat {
    0%, 100% { transform: scale(1); }
    25% { transform: scale(1.15); }
    50% { transform: scale(1); }
    75% { transform: scale(1.1); }
  }
</style>

{siteStartDate && (
  <script define:vars={{ startDate: siteStartDate }}>
    function createRuntimeCounter() {
      const startTime = new Date(startDate);
      if (isNaN(startTime.getTime())) return;

      function pad(n) { return String(n).padStart(2, '0'); }

      function update() {
        const now = new Date();
        const diff = now - startTime;
        const totalDays = Math.floor(diff / 86400000);
        const years = Math.floor(totalDays / 365);
        const days = totalDays % 365;
        const hours = Math.floor((diff % 86400000) / 3600000);
        const minutes = Math.floor((diff % 3600000) / 60000);
        const seconds = Math.floor((diff % 60000) / 1000);

        let text;
        if (years > 0) {
          text = `\u672C\u7AD9\u5C45\u7136\u8FD0\u884C\u4E86${years}\u5E74${days}\u5929${pad(hours)}\u5C0F\u65F6${pad(minutes)}\u5206${pad(seconds)}\u79D2`;
        } else {
          text = `\u672C\u7AD9\u5C45\u7136\u8FD0\u884C\u4E86${totalDays}\u5929${pad(hours)}\u5C0F\u65F6${pad(minutes)}\u5206${pad(seconds)}\u79D2`;
        }

        const el = document.getElementById('workboard');
        if (el) el.innerHTML = text + '<span class="runtime-heart">❤️</span>';
      }

      update();
      setInterval(update, 1000);
    }
    createRuntimeCounter();
  </script>
)}
