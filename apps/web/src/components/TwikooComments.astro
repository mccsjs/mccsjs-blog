---
const API_URL = (typeof import.meta !== 'undefined' && import.meta.env && import.meta.env.PUBLIC_API_URL)
  || (typeof process !== 'undefined' && process.env && process.env.PUBLIC_API_URL)
  || '';
const DEFAULT_ENV_ID = 'https://twikoo.seln.cn';

let envId = DEFAULT_ENV_ID;
try {
  const res = await fetch(`${API_URL}/api/settings`);
  if (res.ok) {
    const data = await res.json();
    envId = data.twikooEnvId || DEFAULT_ENV_ID;
  }
} catch {}
---

<!-- 仅渲染容器，初始化逻辑在 BaseLayout 全局脚本中 -->
<div id="tcomment" data-twikoo-env-id={envId}></div>
