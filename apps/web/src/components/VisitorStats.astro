---
// 访客统计卡片：所有时间的聚合数据，纯自有数据（无 Umami）。
// 布局仿 guole.fun/about：左竖排 3 大数 + 右横排 3 列 TOP5。
// 通过 GET /api/visitor-public-stats 拉取，前端渲染。
---

<div class="vstat-card" id="visitor-stats">
  <div class="vstat-head">
    <div class="vstat-head-text">
      <span class="vstat-tips">网站数据</span>
      <h2 class="vstat-title">访问统计</h2>
    </div>
    <span class="vstat-badge">总计</span>
  </div>

  <div class="vstat-body">
    <div class="vstat-stats">
      <div class="vstat-stat">
        <span class="vstat-lbl">浏览量</span>
        <span class="vstat-num" data-stat="pageviews">—</span>
      </div>
      <div class="vstat-stat">
        <span class="vstat-lbl">访客</span>
        <span class="vstat-num" data-stat="visitors">—</span>
      </div>
      <div class="vstat-stat">
        <span class="vstat-lbl">访问次数</span>
        <span class="vstat-num" data-stat="visits">—</span>
      </div>
    </div>

    <div class="vstat-metrics">
      <div class="vstat-col">
        <h3 class="vstat-col-title">国家 / 地区 TOP6</h3>
        <div class="vstat-list" data-list="country"></div>
      </div>
      <div class="vstat-col">
        <h3 class="vstat-col-title">操作系统 TOP6</h3>
        <div class="vstat-list" data-list="os"></div>
      </div>
      <div class="vstat-col">
        <h3 class="vstat-col-title">浏览器 TOP6</h3>
        <div class="vstat-list" data-list="browser"></div>
      </div>
    </div>
  </div>

  <p class="vstat-foot">* 统计数据来自后端返回</p>
</div>

<style>
  .vstat-card {
    position: relative;
    margin: 1.5rem 0;
    padding: 1.25rem 2rem;
    border-radius: 1.5rem;
    background: rgb(var(--glass-bg) / 0.6);
    -webkit-backdrop-filter: blur(16px) saturate(1.6);
    backdrop-filter: blur(16px) saturate(1.6);
    border: 1px solid rgb(var(--glass-border) / 0.45);
    box-shadow: 0 12px 40px -14px rgb(0 0 0 / 0.18);
    overflow: hidden;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s ease;
  }
  .vstat-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 56px -16px rgb(0 0 0 / 0.26);
  }
  .vstat-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(120% 80% at 100% 0%, rgb(var(--primary) / 0.12), transparent 60%);
    pointer-events: none;
  }
  .vstat-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .vstat-head-text {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .vstat-tips {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: rgb(var(--fg-muted));
  }
  .vstat-title {
    font-size: 1.6rem;
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.01em;
    background: linear-gradient(120deg, rgb(var(--primary)), rgb(var(--fg)));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .vstat-badge {
    font-size: 0.72rem;
    font-weight: 600;
    padding: 0.25rem 0.7rem;
    border-radius: 999px;
    color: rgb(var(--primary));
    background: rgb(var(--primary) / 0.12);
    border: 1px solid rgb(var(--primary) / 0.25);
    white-space: nowrap;
  }
  .vstat-body {
    display: grid;
    grid-template-columns: minmax(110px, 0.4fr) 2.6fr;
    gap: 2rem;
    align-items: stretch;
  }
  .vstat-stats {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    padding-right: 1.5rem;
    border-right: 1px solid rgb(var(--border) / 0.5);
  }
  .vstat-stat {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding: 0.7rem 0.85rem;
    border-radius: 0.9rem;
    background: rgb(var(--card-bg) / 0.5);
    border: 1px solid rgb(var(--border) / 0.5);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), background 0.3s ease;
  }
  .vstat-stat:hover {
    transform: translateX(4px) scale(1.02);
    background: rgb(var(--card-bg) / 0.85);
  }
  .vstat-lbl {
    font-size: 0.82rem;
    color: rgb(var(--fg-muted));
  }
  .vstat-num {
    font-size: 1.5rem;
    font-weight: 800;
    line-height: 1.15;
    color: rgb(var(--fg));
    font-variant-numeric: tabular-nums;
  }
  .vstat-metrics {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  .vstat-col-title {
    font-size: 0.76rem;
    font-weight: 700;
    color: rgb(var(--fg-soft));
    margin-bottom: 0.6rem;
    padding-bottom: 0.35rem;
    border-bottom: 1px solid rgb(var(--border) / 0.5);
  }
  .vstat-foot {
    margin: 1.5rem 0 0;
    padding-top: 1rem;
    border-top: 1px solid rgb(var(--border) / 0.4);
    font-size: 0.74rem;
    color: rgb(var(--fg-muted));
  }
  @media (max-width: 820px) {
    .vstat-body {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .vstat-stats {
      flex-direction: row;
      flex-wrap: nowrap;
      gap: 0.5rem;
      padding-right: 0;
      border-right: none;
      border-bottom: 1px solid rgb(var(--border) / 0.5);
      padding-bottom: 1rem;
    }
    .vstat-stat {
      flex: 1;
      min-width: 0;
      padding: 0.6rem 0.5rem;
    }
  }
  @media (max-width: 560px) {
    .vstat-metrics {
      grid-template-columns: 1fr;
    }
    .vstat-stat-num {
      font-size: 1.25rem;
    }
    .vstat-title {
      font-size: 1.35rem;
    }
  }
</style>

<!-- 行级样式用 is:inline：JS innerHTML 动态生成的元素没有 Astro scoping 属性，scoped 选择器匹配不上 -->
<style is:inline>
  .vstat-row {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    height: 24px;
    margin-bottom: 2px;
    padding: 0 0.4rem;
    border-radius: 0.4rem;
    overflow: hidden;
    transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1), background 0.25s ease;
  }
  .vstat-row:hover {
    transform: translateX(3px);
  }
  .vstat-bar {
    position: absolute;
    left: 0; top:0; bottom: 0;
    border-radius: 0.4rem;
    z-index: 0;
    transition: width 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .vstat-ico {
    position: relative;
    z-index: 1;
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .vstat-name {
    position: relative;
    z-index: 1;
    flex: 1;
    min-width: 0;
    font-size: 0.75rem;
    color: rgb(var(--fg));
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .vstat-count {
    position: relative;
    z-index: 1;
    margin-left: auto;
    white-space: nowrap;
    font-size: 0.72rem;
    font-weight: 600;
    color: rgb(var(--fg-soft));
    font-variant-numeric: tabular-nums;
  }
  .vstat-empty {
    font-size: 0.8rem;
    color: rgb(var(--fg-muted));
    padding: 0.4rem 0;
  }
</style>

<script>
  // 动态加载 iconify 自定义元素（与 MenuIcon.astro 一致；非内联脚本经 Vite 打包，裸模块名可解析）
  import('iconify-icon')

  function initVisitorStats() {
    const root = document.getElementById('visitor-stats')
    if (!root) return

    const API_URL = (window.__API_URL__ || '').replace(/\/+$/, '')

    // ISO 国家码 → circle-flags 图标名（如 'cn' → 'circle-flags:cn'）
    function countryIcon(code) {
      if (!code || code.length !== 2) return 'circle-flags:unknown'
      return 'circle-flags:' + code.toLowerCase()
    }
    // 常用国家中文名（缺省回退到代码）
    const CN_NAME = {
      CN: '中国', HK: '中国香港', TW: '中国台湾', MO: '中国澳门', US: '美国', JP: '日本',
      KR: '韩国', SG: '新加坡', GB: '英国', DE: '德国', FR: '法国', RU: '俄罗斯',
      CA: '加拿大', AU: '澳大利亚', IN: '印度', BR: '巴西', NL: '荷兰', TH: '泰国',
      VN: '越南', MY: '马来西亚', ID: '印度尼西亚', PH: '菲律宾', NZ: '新西兰',
    }
    function countryName(code) {
      return CN_NAME[code?.toUpperCase()] || code || '未知'
    }
    function osIcon(os) {
      var s = (os || '').toLowerCase()
      if (s.includes('windows')) return 'simple-icons:windows'
      if (s.includes('macos') || s.includes('mac os')) return 'simple-icons:apple'
      if (s.includes('ios') || s.includes('iphone') || s.includes('ipad')) return 'ic:baseline-phone-iphone'
      if (s.includes('android')) return 'simple-icons:android'
      if (s.includes('linux')) return 'simple-icons:linux'
      return 'mdi:laptop'
    }
    function browserIcon(b) {
      var s = (b || '').toLowerCase()
      if (s.includes('edge')) return 'simple-icons:microsoftedge'
      if (s.includes('firefox')) return 'simple-icons:firefoxbrowser'
      if (s.includes('safari')) return 'simple-icons:safari'
      if (s.includes('opera')) return 'simple-icons:opera'
      if (s.includes('chrome')) return 'simple-icons:googlechrome'
      return 'mdi:web'
    }
    function iconFor(kind, value) {
      if (kind === 'country') return countryIcon(value)
      if (kind === 'os') return osIcon(value)
      return browserIcon(value)
    }
    function labelFor(kind, value) {
      if (kind === 'country') return countryName(value)
      return value || '未知'
    }

    // 紧凑计数：>=10000 用 w（如 12345→1.2w），1 万内显示真实数据
    function fmtShort(n) {
      var v = Number(n) || 0
      if (v >= 10000) return (v / 10000).toFixed(1).replace(/\.0$/, '') + 'w'
      return String(v)
    }

    function renderStats(stats) {
      root.querySelectorAll('.vstat-num').forEach(function (el) {
        var k = el.getAttribute('data-stat')
        el.textContent = fmtShort(stats[k])
      })
    }
    function renderList(kind, rows) {
      var box = root.querySelector('[data-list="' + kind + '"]')
      if (!box) return
      if (!rows || !rows.length) {
        box.innerHTML = '<div class="vstat-empty">暂无数据</div>'
        return
      }
      var max = Math.max.apply(null, rows.map(function (r) { return r.count }))
      box.innerHTML = rows
        .map(function (r) {
          var pct = max ? Math.round((r.count / max) * 100) : 0
          var name = labelFor(kind, r.value)
          var icn = iconFor(kind, r.value)
          return (
            '<div class="vstat-row">' +
            '<div class="vstat-bar" style="width:' + pct + '%"></div>' +
            '<iconify-icon class="vstat-ico" icon="' + icn + '" width="14" height="14"></iconify-icon>' +
            '<span class="vstat-name" title="' + name + '">' + name + '</span>' +
            '<span class="vstat-count">' + fmtShort(r.count) + '</span>' +
            '</div>'
          )
        })
        .join('')
    }

    async function load() {
      try {
        var res = await fetch((API_URL || '') + '/api/visitor-public-stats', {
          headers: { Accept: 'application/json' },
        })
        if (!res.ok) throw new Error('HTTP ' + res.status)
        var d = await res.json()
        renderStats(d.stats || {})
        renderList('country', d.country)
        renderList('os', d.os)
        renderList('browser', d.browser)
      } catch (e) {
        root.querySelectorAll('.vstat-num').forEach(function (el) { el.textContent = '—' })
      }
    }

    load()
  }

  // 首屏加载与每次 Swup 切页都会触发，保证组件在任意导航后都重新拉数渲染
  document.addEventListener('astro:page-load', initVisitorStats)
  // 首次加载兜底：非内联模块脚本 deferred 执行可能晚于 astro:page-load 首次触发
  initVisitorStats()
</script>
