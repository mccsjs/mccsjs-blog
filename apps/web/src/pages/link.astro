---
import BaseLayout from '../layouts/BaseLayout.astro';
import TwikooComments from '../components/TwikooComments.astro';
import SelfComments from '../components/SelfComments.astro';
import TabNav from '../components/TabNav.astro';
import MarkdownIt from 'markdown-it';

// 动态导入 highlight.js，避免 ESM/CJS 兼容问题
let hljsModule: any;
try {
  hljsModule = await import('highlight.js');
} catch (_) {
  console.warn('highlight.js not available');
}

const API_URL = (typeof import.meta !== 'undefined' && import.meta.env && import.meta.env.PUBLIC_API_URL)
  || (typeof process !== 'undefined' && process.env && process.env.PUBLIC_API_URL)
  || '';

interface FriendItem {
  id: string;
  name: string;
  url: string;
  description: string;
  avatar: string;
  screenshot?: string;
  accessible: number;
  latency: number;
}

interface FriendGroup {
  type_name: string;
  friends: FriendItem[];
}

let groups: FriendGroup[] = [];
let linkMarkdownHtml = '';
let commentProvider = 'twikoo';
let commentEmojiCdn = '';

const isLostGroup = (name: string) => /失联/.test(name);

try {
  const [friendsRes, settingsRes] = await Promise.all([
    fetch(`${API_URL}/api/friends`),
    fetch(`${API_URL}/api/settings`),
  ]);

  if (friendsRes.ok) {
    const data = await friendsRes.json();
    groups = (data.groups || []).filter((g: FriendGroup) => g.friends.length > 0);
  }

  if (settingsRes.ok) {
    const settings = await settingsRes.json();
    commentProvider = settings.commentProvider || 'twikoo';
    commentEmojiCdn = settings.commentEmojiCdn || '';
    const raw = settings.linkMarkdown || '';
      if (raw) {
        const hl = hljsModule?.default || hljsModule;
        const md = new MarkdownIt({
          html: true,
          linkify: true,
          typographer: true,
          breaks: true,
          highlight: function (str: string, lang: string) {
            if (hl && lang && hl.getLanguage(lang)) {
              try { return hl.highlight(str, { language: lang }).value; } catch (_) {}
            }
            if (hl) {
              try { return hl.highlightAuto(str).value; } catch (_) {}
            }
            return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
          },
        });
        md.use((await import('markdown-it-mark')).default);
        // 图片加 lazy loading
        md.renderer.rules.image = (tokens, idx) => {
          const token = tokens[idx];
          const src = token.attrGet('src') || '';
          const alt = token.content;
          return `<img src="${src}" alt="${alt}" loading="lazy" class="max-w-full rounded-lg" />`;
        };
      linkMarkdownHtml = md.render(raw);
    }
  }
} catch {}
---

<BaseLayout title="友链" wide showComment={true} description="友情链接 — 有趣的人与站点，欢迎交换友链">
  <section class="mb-10 text-center">
    <h1 class="text-3xl font-extrabold tracking-tight sm:text-4xl">友情链接</h1>
    <p class="mt-3 text-[rgb(var(--fg-soft))] dark:text-[rgb(var(--fg-muted))]">有趣的人与站点，欢迎交换友链</p>
  </section>

  <TabNav tabs={[
    { label: '友链', href: '/link' },
    { label: '朋友圈', href: '/fc' },
  ]} />

  {
    groups.length === 0 ? (
      <div class="rounded-xl border border-[rgb(var(--card-border))] bg-[rgb(var(--card-bg))] p-12 text-center text-[rgb(var(--fg-muted))] dark:border-[rgb(var(--card-border))] dark:bg-[rgb(var(--card-bg))] dark:text-[rgb(var(--fg-muted))]">
        暂无友链，稍后再来吧
      </div>
    ) : (
      groups.map((group) => {
        const lost = isLostGroup(group.type_name);
        return (
          <section class="mb-12">
            <h2 class="mb-5 text-lg font-bold text-[rgb(var(--fg))] dark:text-[rgb(var(--fg))]">
              {group.type_name}
            </h2>
            {lost ? (
              <div class="flex flex-wrap items-center gap-x-6 gap-y-2">
                {group.friends.map((friend) => (
                  <span class="text-sm text-[rgb(var(--fg-muted))] dark:text-[rgb(var(--fg-muted))]">{friend.name}</span>
                ))}
              </div>
            ) : (
              <div class="grid gap-4 grid-cols-2 lg:grid-cols-6">
                {group.friends.map((friend) => (
                  <a
                    href={friend.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group block overflow-hidden rounded-2xl border border-[rgb(var(--card-border))] bg-[rgb(var(--card-bg))] shadow-sm transition-all hover:-translate-y-0.5 hover:shadow-md dark:border-[rgb(var(--card-border))] dark:bg-[rgb(var(--card-bg))]"
                  >
                    <div class="relative h-32 w-full overflow-hidden bg-gray-100 dark:bg-gray-800">
                      {friend.screenshot ? (
                        <img src={friend.screenshot} alt={friend.name} loading="lazy" decoding="async" onload="this.classList.add('is-loaded')" class="friend-shot h-full w-full object-cover opacity-0 transition-all duration-500 group-hover:scale-105" />
                      ) : (
                        <div class="flex h-full w-full items-center justify-center text-xs text-[rgb(var(--fg-muted))] dark:text-[rgb(var(--fg-muted))]">暂无截图</div>
                      )}
                      <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent" />
                      {friend.latency > 0 || friend.accessible === 1 ? (
                    <div class="absolute top-1 left-1 flex items-center gap-0.5 rounded-full px-1 py-px text-[9px] font-medium shadow-sm"
                      class:list={[
                        friend.accessible === 1
                          ? 'bg-red-500/90 text-white'
                          : friend.latency <= 4000
                            ? 'bg-green-500/90 text-white'
                            : 'bg-yellow-400/90 text-yellow-900'
                      ]}
                    >
                      {friend.accessible === 0 ? (
                        <span>{(friend.latency / 1000).toFixed(2)}s</span>
                      ) : (
                        <span>不可用</span>
                      )}
                        </div>
                      ) : null}
                    </div>
                    <div class="flex items-start gap-2.5 py-1 px-2 h-[54px]">
                      <div class="h-9 w-9 shrink-0 -ml-1 rounded-full border border-[rgb(var(--card-border))] bg-[rgb(var(--bg-soft))] dark:border-[rgb(var(--card-border))] dark:bg-gray-800">
                        {friend.avatar ? (
                          <img src={friend.avatar} alt={friend.name} class="h-full w-full rounded-full object-cover" />
                        ) : (
                          <span class="text-[10px] font-bold text-[rgb(var(--fg-muted))] dark:text-[rgb(var(--fg-muted))] flex h-full items-center justify-center">{friend.name.charAt(0)}</span>
                        )}
                      </div>
                      <div class="min-w-0">
                        <h3 class="truncate text-xs font-semibold text-[rgb(var(--fg))] group-hover:text-yellow-700 dark:text-[rgb(var(--fg))] dark:group-hover:text-yellow-300">
                          {friend.name}
                        </h3>
                        <p class="mt-0 line-clamp-2 text-xs leading-snug text-[rgb(var(--fg-muted))] dark:text-[rgb(var(--fg-muted))]">
                          {friend.description || friend.url}
                        </p>
                      </div>
                    </div>
                  </a>
                ))}
              </div>
            )}
          </section>
        );
      })
    )
  }

  {
    linkMarkdownHtml && (
      <section id="link-markdown-section" class="mb-10">
        <div class="prose max-w-none rounded-xl border border-[rgb(var(--card-border))] bg-[rgb(var(--card-bg))] p-6 shadow-sm dark:border-[rgb(var(--card-border))] dark:bg-[rgb(var(--card-bg))]"
          set:html={linkMarkdownHtml}
        ></div>
      </section>
    )
  }

  <section id="comments" class="mt-14">
    <h2 class="text-2xl font-bold">评论</h2>
    <div class="mt-6">
      {commentProvider === 'native' ? (
        <SelfComments postId="link" emojiCdn={commentEmojiCdn} />
      ) : (
        <TwikooComments />
      )}
    </div>
  </section>
  <style>
    /* 友链截图：懒加载完成后淡入 */
    .friend-shot.is-loaded {
      opacity: 1;
    }
  </style>

  <script>
    // 兜底：缓存命中的图片不会触发 onload，直接标记为已加载
    document.querySelectorAll('.friend-shot').forEach(function (img) {
      if (img.complete) {
        img.classList.add('is-loaded');
      } else {
        img.addEventListener('load', function () { img.classList.add('is-loaded'); }, { once: true });
      }
    });
  </script>
</BaseLayout>
