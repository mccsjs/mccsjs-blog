# ===== 数据库（本地 SQLite）=====
# Prisma 相对 schema.prisma 所在目录解析，默认即 backend/prisma/dev.db
DATABASE_URL="file:./dev.db"

# ===== 运行环境 =====
# 本地开发保持 development（会 app.listen + 跑 node-cron 定时任务）
NODE_ENV="development"

# ===== 鉴权（better-auth）=====
BETTER_AUTH_SECRET="<至少32位随机串，openssl rand -base64 32>"
# better-auth 回调地址，本地开发填 http://localhost:4000
BETTER_AUTH_URL="http://localhost:4000"

# ===== CORS（本地开发放行前端/管理端来源）=====
FRONTEND_URL="http://localhost:4321"
ADMIN_URL="http://localhost:5173"

# ===== 可选 =====
# XXAPI_TOKEN="<友链测速用的 xxapi.cn token>"
# PUBLIC_API_URL 是前端用的，不在这个后端 .env 里
