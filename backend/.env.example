# ===== 数据库（Turso / libSQL）=====
DATABASE_URL="libsql://mccsjsblog-mccsjs1.aws-ap-northeast-1.turso.io"
TURSO_AUTH_TOKEN="<数据库级 token，用 Turso API 生成，不要填控制台给的账户级 API Token>"

# ===== 运行环境 =====
# 部署到任何 serverless 平台都必须设 production，否则会尝试 app.listen() 且跳过 CORS 限制
NODE_ENV="production"

# ===== 鉴权（better-auth）=====
BETTER_AUTH_SECRET="<至少32位随机串，openssl rand -base64 32>"
# better-auth 回调地址，填你部署后的后端域名
BETTER_AUTH_URL="https://<你的后端域名>"

# ===== CORS（生产环境只放行这两个来源，前端/管理端才能跨域调 API）=====
FRONTEND_URL="https://mccsjsblog.com"
ADMIN_URL="https://admin.mccsjsblog.com"

# ===== 定时任务端点保护（/api/cron/*，平台 Cron 调用时带 Bearer）=====
CRON_SECRET="<随机串>"

# ===== 可选 =====
# XXAPI_TOKEN="<友链测速用的 xxapi.cn token>"
# PUBLIC_API_URL 是前端用的，不在这个后端 .env 里
