{
  "name": "mccsjsblog-backend",
  "buildCommand": "npm run build",
  "installCommand": "npm install --legacy-peer-deps",
  "outputDirectory": "dist",
  "cloudFunctions": {
    "nodejs": {
      "entry": "cloud-functions/[[default]].ts"
    }
  },
  "schedules": [
    {
      "name": "friend-check",
      "cron": "0 */6 * * *",
      "path": "/api/cron/friend-check",
      "method": "POST",
      "timezone": "Asia/Shanghai"
    },
    {
      "name": "rss-refresh",
      "cron": "0 */3 * * *",
      "path": "/api/cron/rss-refresh",
      "method": "POST",
      "timezone": "Asia/Shanghai"
    }
  ]
}
