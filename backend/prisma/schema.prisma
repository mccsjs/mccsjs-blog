
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified Boolean?  @default(false)
  image         String?
  password      String?
  accounts      Account[]
  sessions      Session[]
  posts         Post[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("user")
}

model Account {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  password              String?

  @@unique([accountId, providerId])
  @@index([userId])
  @@map("account")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?

  @@index([userId])
  @@map("session")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  expiresAt  DateTime

  @@index([identifier])
  @@map("verification")
}

model Post {
  id         String   @id @default(cuid())
  title      String
  slug       String   @unique
  content    String
  excerpt    String
  coverImage String?
  published  Boolean  @default(false)
  views      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  authorId   String
  categoryId String
  author     User      @relation(fields: [authorId], references: [id])
  category   Category  @relation(fields: [categoryId], references: [id])
  tags       Tag[]
  comments   Comment[]
}

model Category {
  id    String @id @default(cuid())
  name  String @unique
  slug  String @unique
  posts Post[]
}

model Tag {
  id    String @id @default(cuid())
  name  String @unique
  slug  String @unique
  posts Post[]
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  author    String
  email     String
  website   String?
  content   String
  ip        String?
  region    String?
  os        String?
  browser   String?
  visible   Boolean  @default(true)
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id])
}

model SiteSetting {
  id                String   @id @default(cuid())
  key               String   @unique
  value             String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("site_setting")
}

model Menu {
  id          String   @id @default(cuid())
  label       String
  href        String?
  icon        String?
  type        String
  parentId    String?
  sortOrder   Int      @default(0)
  visible     Boolean  @default(true)
  target      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent   Menu?  @relation("MenuChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children Menu[] @relation("MenuChildren")

  @@index([type])
  @@index([parentId])
  @@map("menu")
}

model FriendType {
  id        String    @id @default(cuid())
  name      String
  sort      Int       @default(0)
  isVisible Boolean   @default(true) @map("is_visible")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  friends   Friend[]

  @@map("friend_type")
}

model Friend {
  id          String   @id @default(cuid())
  name        String
  url         String
  description String   @default("")
  avatar      String   @default("")
  screenshot  String   @default("")
  sort        Int      @default(5)
  isInvalid   Boolean  @default(false) @map("is_invalid")
  recommended Boolean  @default(false) @map("recommended")
  typeId      String?  @map("type_id")
  type        FriendType? @relation(fields: [typeId], references: [id], onDelete: SetNull)
  accessible  Int      @default(0)
  latency     Int      @default(0) @map("latency")
  rssUrl      String?  @map("rss_url")
  rssLatime   DateTime? @map("rss_latime")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rssArticles RssArticle[]

  @@index([sort])
  @@map("friend")
}

model RssArticle {
  id          String   @id @default(cuid())
  friendId    String   @map("friend_id")
  friend      Friend   @relation(fields: [friendId], references: [id], onDelete: Cascade)
  title       String
  link        String   @unique
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([friendId])
  @@index([publishedAt])
  @@map("rss_article")
}

model VisitorLog {
  id         String   @id @default(cuid())
  visitorId  String   @map("visitor_id")
  ip         String?
  page       String
  region     String?
  os         String?
  browser    String?
  referrer   String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([visitorId])
  @@index([page])
  @@index([createdAt])
  @@map("visitor_log")
}
