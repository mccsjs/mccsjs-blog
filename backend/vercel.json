{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "npx prisma generate",
  "installCommand": "npm install",
  "builds": [
    {
      "src": "vercel-entry.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "vercel-entry.ts" }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
