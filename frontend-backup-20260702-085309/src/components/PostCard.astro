---
import type { Post } from '../types';

interface Props {
  post: Post;
}

const { post } = Astro.props;

const formatDate = (date: string) =>
  new Date(date).toLocaleDateString('zh-CN', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
---

<article class="group flex flex-col overflow-hidden rounded-2xl border border-[rgb(var(--border)/0.4)] bg-[rgb(var(--surface))] shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-md">
  {
    post.coverImage && (
      <a href={`/posts/${post.slug}`} class="block overflow-hidden rounded-2xl">
        <img
          src={post.coverImage}
          alt={post.title}
          class="aspect-[16/10] w-full object-cover transition-transform duration-300 group-hover:scale-105"
        />
      </a>
    )
  }
  <div class="flex flex-1 flex-col p-4">
    <div class="flex flex-wrap items-center gap-2 text-xs style=\'color:rgb(var(--fg-soft))"">
      <span class="rounded-full px-2 py-1 font-medium style=\'background:rgb(var(--bg-soft));color:rgb(var(--fg))"">
        {post.category.name}
      </span>
      <span>·</span>
      <time datetime={post.createdAt}>{formatDate(post.createdAt)}</time>
      <span>·</span>
      <span>{post.views} 次阅读</span>
    </div>
    <h3 class="mt-3 text-lg font-bold leading-snug">
      <a href={`/posts/${post.slug}`} class="hover:text-[rgb(var(--primary))] transition-colors">
        {post.title}
      </a>
    </h3>
    <p class="mt-2 line-clamp-3 text-sm leading-relaxed text-[rgb(var(--fg-soft))]">
      {post.excerpt}
    </p>
    {
      post.tags.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2">
          {post.tags.map((tag) => (
            <span class="rounded-full border px-2 py-0.5 text-xs text-[rgb(var(--fg-soft))] style=\'border-color:rgb(var(--border)/0.5)"">
              #{tag.name}
            </span>
          ))}
        </div>
      )
    }
  </div>
</article>
