---
interface TabItem {
  label: string;
  href: string;
}

interface Props {
  tabs: TabItem[];
}

const { tabs } = Astro.props;
const slug = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<nav id="tab-nav" class="tab-nav">
  <div id="tab-hover-border"></div>
  {tabs.map((tab) => {
    const tabPath = tab.href.replace(/\/$/, '') || '/';
    const isActive = slug === tabPath || (slug !== '/' && tabPath !== '/' && slug.startsWith(tabPath));
    return (
      <a
        href={tab.href}
        class={`tab-item${isActive ? ' active' : ''}`}
        role="tab"
        aria-selected={isActive ? 'true' : 'false'}
      >
        {tab.label}
      </a>
    );
  })}
</nav>

<style>
  .tab-nav {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2px;
    width: fit-content;
    margin: 0 auto 2.5rem;
    padding: 5px;
    border-radius: 50px;
    background: oklch(1 0 0 / 0.72);
    border: 1px solid oklch(0 0 0 / 0.06);
    box-shadow: 0 1px 3px oklch(0 0 0 / 0.04);
  }
  :global(.dark) .tab-nav {
    background: oklch(0.15 0 0 / 0.72);
    border-color: oklch(1 0 0 / 0.06);
    box-shadow: 0 1px 3px oklch(0 0 0 / 0.12);
  }

  /* hover 滑动边框 */
  #tab-hover-border {
    position: absolute;
    height: 2.25rem;
    border-radius: 9999px;
    border: 1.5px solid oklch(0.35 0 0);
    background: transparent;
    opacity: 0;
    pointer-events: none;
    z-index: 0;
    transition: left 0.25s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                width 0.25s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  :global(.dark) #tab-hover-border {
    border-color: oklch(0.6 0 0);
  }
  .tab-nav:hover #tab-hover-border,
  .tab-nav.has-active #tab-hover-border {
    opacity: 1;
  }

  /* 标签项 */
  .tab-item {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6px 18px;
    border-radius: 50px;
    font-size: 14px;
    font-weight: 500;
    color: oklch(0.35 0 0);
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.15s ease;
    line-height: 1;
    font-family: inherit;
  }
  :global(.dark) .tab-item {
    color: oklch(0.55 0 0);
  }
  .tab-item:hover {
    color: oklch(0.1 0 0);
  }
  :global(.dark) .tab-item:hover {
    color: oklch(0.95 0 0);
  }
  .tab-item.active {
    font-weight: 600;
    color: oklch(0.2 0 0);
  }
  :global(.dark) .tab-item.active {
    color: oklch(0.9 0 0);
  }
</style>

<script>
  function initTabNav() {
    const tabNav = document.getElementById('tab-nav');
    const hoverBorder = document.getElementById('tab-hover-border');
    if (!tabNav || !hoverBorder) return;

    const tabItems = tabNav.querySelectorAll('.tab-item');

    function positionBorder(item: Element) {
      const rect = item.getBoundingClientRect();
      const nRect = tabNav!.getBoundingClientRect();
      hoverBorder!.style.width = `${rect.width}px`;
      hoverBorder!.style.left = `${rect.left - nRect.left}px`;
    }

    // 初始定位到 active 项
    const active = tabNav.querySelector('.tab-item.active');
    if (active) {
      positionBorder(active);
      tabNav.classList.add('has-active');
    }

    tabItems.forEach((item) => {
      item.addEventListener('mouseenter', () => positionBorder(item));
    });

    tabNav.addEventListener('mouseleave', () => {
      const activeItem = tabNav.querySelector('.tab-item.active');
      if (activeItem) {
        positionBorder(activeItem);
      }
    });
  }

  initTabNav();

  if (window.swup) {
    window.swup.hooks.on('content:replace', initTabNav);
  } else {
    document.addEventListener('swup:enable', () => {
      window.swup.hooks.on('content:replace', initTabNav);
    });
  }
</script>
