---
import BaseLayout from '../../layouts/BaseLayout.astro';
import type { Post } from '../../types';

const API_URL = 'http://localhost:4000';

export async function getStaticPaths() {
  const response = await fetch('http://localhost:4000/api/categories');
  const categories = await response.json();
  return categories.map((category: { slug: string }) => ({
    params: { slug: category.slug },
  }));
}

const { slug } = Astro.params;

let posts: Post[] = [];
let error: string | null = null;
let categoryName = '';

try {
  const response = await fetch(`${API_URL}/api/posts?categorySlug=${encodeURIComponent(slug || '')}`);
  if (!response.ok) {
    throw new Error(`无法加载文章：${response.status}`);
  }
  posts = await response.json();
} catch (err) {
  error = err instanceof Error ? err.message : '未知错误';
}

if (posts.length > 0 && posts[0].category.slug === slug) {
  categoryName = posts[0].category.name;
}
---

<BaseLayout title={categoryName ? `${categoryName} | My Blog` : '分类 | My Blog'}>
  <section class="mb-10 text-center">
    <h1 class="text-3xl font-extrabold tracking-tight sm:text-4xl">{categoryName || '分类'}</h1>
    <p class="mt-3 text-gray-600 dark:text-gray-400">共 {posts.length} 篇文章</p>
  </section>

  {
    error ? (
      <div class="rounded-xl border border-red-100 bg-red-50 dark:bg-red-900/20 dark:border-red-800 dark:text-red-300 p-6 text-center text-red-700">
        <p class="font-medium">加载文章失败</p>
        <p class="mt-1 text-sm">{error}</p>
      </div>
    ) : posts.length === 0 ? (
      <div class="rounded-xl border border-gray-200 bg-white p-12 text-center text-gray-500 dark:border-gray-800 dark:bg-[#111] dark:text-gray-400">
        该分类下暂无文章。
      </div>
    ) : (
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => (
          <a
            href={`/posts/${post.slug}`}
            class="group rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition-all hover:-translate-y-0.5 hover:shadow-md dark:border-gray-800 dark:bg-[#111]"
          >
            <h2 class="text-lg font-semibold text-gray-900 group-hover:text-yellow-600 dark:text-gray-100 dark:group-hover:text-yellow-400">
              {post.title}
            </h2>
            <p class="mt-2 line-clamp-2 text-sm text-gray-600 dark:text-gray-400">
              {post.description || ''}
            </p>
          </a>
        ))}
      </div>
    )
  }
</BaseLayout>
