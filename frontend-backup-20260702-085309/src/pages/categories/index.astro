---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TabNav from '../../components/TabNav.astro';

const API_URL = 'http://localhost:4000';
---

<BaseLayout title="分类 | My Blog">
  <section class="mb-10 text-center">
    <h1 class="text-3xl font-extrabold tracking-tight sm:text-4xl">分类</h1>
    <p id="category-count" class="mt-3 text-gray-600 dark:text-gray-400">共 0 个分类</p>
  </section>
  <!-- Nav tabs -->
  <TabNav tabs={[
    { label: '文章', href: '/posts' },
    { label: '归档', href: '/archive' },
    { label: '分类', href: '/categories' },
    { label: '标签', href: '/tags' },
  ]} />
  

  

  <div id="category-error" class="hidden rounded-xl border border-red-100 bg-red-50 dark:bg-red-900/20 dark:border-red-800 dark:text-red-300 p-6 text-center text-red-700">
    <p class="font-medium">加载分类失败</p>
    <p id="category-error-message" class="mt-1 text-sm"></p>
  </div>

  <div id="category-empty" class="hidden rounded-xl border border-gray-200 bg-white p-12 text-center text-gray-500 dark:border-gray-800 dark:bg-[#111] dark:text-gray-400">
    暂无分类。
  </div>

  <div id="category-list" class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3"></div>
</BaseLayout>

<script>
  const container = document.getElementById('category-list');
  const countEl = document.getElementById('category-count');
  const errorEl = document.getElementById('category-error');
  const errorMessageEl = document.getElementById('category-error-message');
  const emptyEl = document.getElementById('category-empty');

  if (!container || !countEl || !errorEl || !errorMessageEl || !emptyEl) {
    throw new Error('缺少分类列表容器');
  }

  async function loadCategories() {
    try {
      const response = await fetch('http://localhost:4000/api/categories');
      if (!response.ok) {
        throw new Error(`无法加载分类：${response.status}`);
      }
      const categories = await response.json();
      countEl.textContent = `共 ${categories.length} 个分类`;

      if (categories.length === 0) {
        emptyEl.classList.remove('hidden');
        return;
      }

      container.innerHTML = categories
        .map(
          (category) => `
            <a href="/categories/${category.slug}" class="group rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition-all hover:-translate-y-0.5 hover:shadow-md dark:border-gray-800 dark:bg-[#111]">
              <h2 class="text-lg font-semibold text-gray-900 group-hover:text-yellow-600 dark:text-gray-100 dark:group-hover:text-yellow-400">${category.name}</h2>
              ${category.description ? `<p class="mt-2 line-clamp-2 text-sm text-gray-600 dark:text-gray-400">${category.description}</p>` : ''}
            </a>
          `
        )
        .join('');
    } catch (err) {
      errorEl.classList.remove('hidden');
      errorMessageEl.textContent = err instanceof Error ? err.message : '未知错误';
    }
  }

  loadCategories();
</script>
