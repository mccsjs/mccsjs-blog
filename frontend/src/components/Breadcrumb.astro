---
import type { Post } from '../types';

const API_URL = 'http://localhost:4000';

interface BreadcrumbItem {
  label: string;
  href?: string;
  isCurrent?: boolean;
}

interface Props {
  title?: string;
  postSlug?: string;
  postCategory?: string;
}

const { title, postSlug, postCategory } = Astro.props as Props;

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const isHome = pathname === '/';

// 页面类型判断
const isPostDetail = pathname.startsWith('/posts/');
const isArchive = pathname === '/archive';
const isCategories = pathname === '/categories';
const isCategoryDetail = pathname.startsWith('/categories/') && !isCategories;
const isTags = pathname === '/tags';
const isTagDetail = pathname.startsWith('/tags/') && !isTags;
const isPosts = pathname === '/posts';
const isLink = pathname === '/link';

const homeItem: BreadcrumbItem = {
  label: '主页',
  href: '/',
};

let items: BreadcrumbItem[] = [];

if (!isHome) {
  if (isPostDetail) {
    const categoryLabel = postCategory || '未分类';
    items = [
      homeItem,
      { label: '文章', href: '/posts' },
      { label: title || categoryLabel, isCurrent: true },
    ];
  } else if (isArchive) {
    items = [
      homeItem,
      { label: '归档', isCurrent: true },
    ];
  } else if (isCategoryDetail) {
    const categorySlug = pathname.replace('/categories/', '');
    items = [
      homeItem,
      { label: '分类', href: '/categories' },
      { label: categorySlug, isCurrent: true },
    ];
  } else if (isCategories) {
    items = [
      homeItem,
      { label: '分类', isCurrent: true },
    ];
  } else if (isTagDetail) {
    const tagSlug = pathname.replace('/tags/', '');
    items = [
      homeItem,
      { label: '标签', href: '/tags' },
      { label: `#${tagSlug}`, isCurrent: true },
    ];
  } else if (isTags) {
    items = [
      homeItem,
      { label: '标签', isCurrent: true },
    ];
  } else if (isPosts) {
    items = [
      homeItem,
      { label: '文章', isCurrent: true },
    ];
  } else if (isLink) {
    items = [
      homeItem,
      { label: '友链', isCurrent: true },
    ];
  } else {
    // 其他独立页面
    const pageTitle = title?.replace(/\s*\|\s*mccsjs\s*$/, '').trim() || '';
    items = [
      homeItem,
      { label: pageTitle || '页面', isCurrent: true },
    ];
  }
}
---

{items.length > 0 && (
  <nav class="mb-6" aria-label="Breadcrumb">
    <ol class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-gray-600 dark:text-gray-400">
      {items.map((item, idx) => (
        <li class="flex items-center gap-3">
          {idx > 0 && <span class="text-gray-400 dark:text-gray-600">/</span>}
          {item.href && !item.isCurrent ? (
            <a href={item.href} class="text-yellow-600 hover:text-yellow-700 dark:text-yellow-400 dark:hover:text-yellow-300 transition-colors">
              {item.label}
            </a>
          ) : (
            <span class:list={[item.isCurrent ? 'text-gray-900 dark:text-gray-100 font-medium' : '']}>
              {item.label}
            </span>
          )}
        </li>
      ))}
    </ol>
  </nav>
)}