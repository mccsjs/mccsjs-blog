---
import type { Comment } from '../types';
import { createHash } from 'node:crypto';

interface Props {
  comments: Comment[];
}

const { comments } = Astro.props;

const formatDate = (date: string) =>
  new Date(date).toLocaleDateString('zh-CN', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });

// WeAvatar 与 Gravatar 兼容，URL 格式为 https://weavatar.com/avatar/{md5(email)}
const avatarUrl = (email: string) => {
  const hash = createHash('md5').update(email.trim().toLowerCase()).digest('hex');
  return `https://weavatar.com/avatar/${hash}?s=200&d=robohash`;
};

const badgeClass =
  'inline-flex items-center gap-1 rounded-full border border-gray-100 bg-gray-50 px-2.5 py-1 text-xs text-gray-500';
---

<div class="mt-6 space-y-5">
  {comments.length === 0 ? (
    <p class="text-gray-500">暂无评论，快来抢沙发吧！</p>
  ) : (
    comments.map((comment) => {
      const avatar = avatarUrl(comment.email);
      const nameEl = comment.website ? (
        <a
          href={comment.website}
          target="_blank"
          rel="noopener noreferrer"
          class="font-semibold text-gray-900 hover:text-yellow-600 hover:underline"
        >
          {comment.author}
        </a>
      ) : (
        <span class="font-semibold text-gray-900">{comment.author}</span>
      );
      return (
        <div class="flex gap-4 rounded-2xl border border-gray-100 bg-white p-5 shadow-sm">
          <a
            href={comment.website || '#'}
            target={comment.website ? '_blank' : undefined}
            rel={comment.website ? 'noopener noreferrer' : undefined}
            class="shrink-0"
            aria-label={comment.website ? `${comment.author} 的网站` : undefined}
          >
            <img
              src={avatar}
              alt={comment.author}
              class="h-12 w-12 rounded-xl object-cover bg-gray-100"
              loading="lazy"
            />
          </a>
          <div class="min-w-0 flex-1">
            <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
              {nameEl}
              <time class="text-xs text-gray-400" datetime={comment.createdAt}>
                {formatDate(comment.createdAt)}
              </time>
            </div>
            <p class="mt-2.5 whitespace-pre-wrap text-sm leading-relaxed text-gray-700">
              {comment.content}
            </p>
            {(comment.region || comment.os || comment.browser) && (
              <div class="mt-3 flex flex-wrap items-center gap-2">
                {comment.region && (
                  <span class={badgeClass}>
                    <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                    {comment.region}
                  </span>
                )}
                {comment.os && (
                  <span class={badgeClass}>
                    <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                    {comment.os}
                  </span>
                )}
                {comment.browser && (
                  <span class={badgeClass}>
                    <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="4"/><line x1="21.17" y1="8" x2="12" y2="8"/><line x1="3.95" y1="6.06" x2="8.54" y2="14"/><line x1="10.88" y1="21.94" x2="15.46" y2="14"/></svg>
                    {comment.browser}
                  </span>
                )}
              </div>
            )}
          </div>
        </div>
      );
    })
  )}
</div>
