---
interface Props {
  title: string;
  postUrl?: string;
  publishedAt?: string;
  authorName: string;
  authorHref?: string;
  licenseName?: string;
  licenseUrl?: string;
}

const {
  title,
  postUrl,
  publishedAt,
  authorName,
  authorHref,
  licenseName,
  licenseUrl = 'https://creativecommons.org/licenses/by-nc-sa/4.0/',
} = Astro.props;
---

<div class="relative mt-10 overflow-hidden rounded-2xl border border-yellow-100 bg-[#FFFDF5] p-6 py-5 shadow-sm dark:border-yellow-900/30 dark:bg-yellow-950/20">
  <!-- 复制链接按钮（右上角） -->
  <button
    id="copy-link-btn"
    title="复制链接"
    class="absolute right-3 top-3 flex items-center gap-1 rounded-lg border border-gray-200 bg-white px-2.5 py-1.5 text-xs text-gray-500 transition-colors hover:border-yellow-300 hover:text-yellow-600 dark:border-gray-700 dark:bg-[#1a1a1a] dark:text-gray-400 dark:hover:border-yellow-500 dark:hover:text-yellow-400"
  >
    <span>🔗</span>
    <span id="copy-link-label">复制链接</span>
  </button>

  <div class="font-bold text-black/75 dark:text-white/75">{title}</div>
  {postUrl && (
    <a href={postUrl} class="mt-1 block break-all text-yellow-700 underline underline-offset-2 dark:text-yellow-400">
      {postUrl}
    </a>
  )}
  <div class="mt-2 flex flex-col gap-3 sm:flex-row sm:gap-6">
    <div>
      <div class="text-sm text-black/30 dark:text-white/25">文章作者</div>
      {authorHref ? (
        <a href={authorHref} class="text-black/75 line-clamp-2 hover:underline dark:text-white/75">
          {authorName}
        </a>
      ) : (
        <div class="text-black/75 line-clamp-2 dark:text-white/75">{authorName}</div>
      )}
    </div>
    {publishedAt && (
      <div>
        <div class="text-sm text-black/30 dark:text-white/25">发布日期</div>
        <div class="text-black/75 line-clamp-2 dark:text-white/75">{publishedAt}</div>
      </div>
    )}
    <div>
      <div class="text-sm text-black/30 dark:text-white/25">许可协议</div>
      <a
        href={licenseUrl}
        target="_blank"
        class="text-yellow-700 underline underline-offset-2 line-clamp-2 dark:text-yellow-400"
      >
        {licenseName || 'CC BY-NC-SA 4.0'}
      </a>
    </div>
  </div>
</div>

<script>
  function initCopyLink() {
    const copyBtn = document.getElementById('copy-link-btn');
    const copyLabel = document.getElementById('copy-link-label');
    copyBtn?.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        if (copyLabel) copyLabel.textContent = '已复制';
        setTimeout(() => { if (copyLabel) copyLabel.textContent = '复制链接'; }, 2000);
      } catch {
        if (copyLabel) copyLabel.textContent = '复制失败';
      }
    });
  }
  initCopyLink();
  document.addEventListener('astro:page-load', initCopyLink);
</script>
