---
---

<div id="floating-bar">
  <button
    id="float-theme"
    class="float-btn visible"
    title="切换主题"
    aria-label="切换主题"
  >
    <iconify-icon icon="line-md:moon" id="float-theme-dark" width={18} height={18} />
    <iconify-icon icon="solar:sun-broken" id="float-theme-light" width={18} height={18} />
  </button>
  <button
    id="float-toc"
    class="float-btn"
    title="目录"
    aria-label="目录"
    data-float-btn
  >
    <iconify-icon icon="line-md:list" width={18} height={18} />
  </button>
  <button
    id="float-comment"
    class="float-btn"
    title="查看评论"
    aria-label="查看评论"
    data-float-btn
  >
    <iconify-icon icon="lucide:message-circle" width={18} height={18} />
  </button>
  <button
    id="float-top"
    class="float-btn"
    title="回到顶部"
    aria-label="回到顶部"
    data-float-btn
  >
    <iconify-icon icon="lucide:arrow-up" width={18} height={18} />
  </button>

  <div id="float-toc-panel" class="float-toc-panel" aria-hidden="true" hidden>
    <div class="float-toc-header">
      <div class="float-toc-title">目录</div>
      <button id="float-toc-close" class="float-toc-close" aria-label="关闭目录">×</button>
    </div>
    <div id="float-toc-list" class="float-toc-body"></div>
  </div>
</div>

<style>
  #floating-bar {
    position: fixed;
    right: 24px;
    bottom: 40px;
    z-index: 45;
    display: flex;
    flex-direction: column;
    gap: 10px;
    pointer-events: none;
  }

  .float-btn {
    pointer-events: auto;
    display: none;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border-radius: 12px;
    border: 1.5px solid oklch(0.7 0 0 / 0.2);
    background: oklch(1 0 0 / 0.85);
    backdrop-filter: blur(12px) saturate(1.6);
    -webkit-backdrop-filter: blur(12px) saturate(1.6);
    color: oklch(0.35 0 0);
    box-shadow: 0 2px 12px oklch(0 0 0 / 0.06);
    cursor: pointer;
    transition:
      transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1),
      opacity 0.25s ease,
      border-color 0.15s ease,
      color 0.15s ease,
      background 0.15s ease;
    opacity: 0;
    transform: translateY(8px) scale(0.92);
  }

  .float-btn.visible {
    display: flex;
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  .float-btn:hover {
    transform: translateY(-1px) scale(1.06);
    border-color: oklch(0.5 0 0 / 0.35);
    color: oklch(0.15 0 0);
    background: oklch(1 0 0 / 0.95);
  }

  :global(.dark) .float-btn {
    background: oklch(0.18 0 0 / 0.75);
    border-color: oklch(0.9 0 0 / 0.1);
    color: oklch(0.9 0 0);
  }
  :global(.dark) .float-btn:hover {
    background: oklch(0.22 0 0 / 0.9);
    border-color: oklch(0.9 0 0 / 0.2);
    color: oklch(0.95 0 0);
  }

  @media (max-width: 639px) {
    #floating-bar {
      right: 16px;
      bottom: 28px;
    }
    .float-btn {
      width: 38px;
      height: 38px;
    }
  }

  @media (min-width: 1024px) {
    #float-toc {
      display: none !important;
    }
  }

  /* 主题切换按钮图标切换 */
  #float-theme {
    position: relative;
    overflow: hidden;
  }
  #float-theme-dark,
  #float-theme-light {
    position: absolute;
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.3s ease;
  }
  #float-theme-dark {
    opacity: 1;
    transform: scale(1) rotate(0deg);
  }
  :global(.dark) #float-theme-dark {
    opacity: 0;
    transform: scale(0.5) rotate(90deg);
    pointer-events: none;
  }
  #float-theme-light {
    opacity: 0;
    transform: scale(0.5) rotate(-90deg);
    pointer-events: none;
  }
  :global(.dark) #float-theme-light {
    opacity: 1;
    transform: scale(1) rotate(0deg);
    pointer-events: auto;
  }

  /* ===== 移动端目录弹出面板 ===== */
  .float-toc-panel {
    position: fixed;
    right: 68px;
    bottom: 44px;
    width: 260px;
    max-height: 320px;
    z-index: 46;
    border-radius: 14px;
    border: 1px solid rgb(var(--border));
    background: rgb(var(--surface));
    box-shadow: 0 10px 30px oklch(0 0 0 / 0.12);
    display: flex;
    flex-direction: column;
    opacity: 0;
    transform: translateX(12px) scale(0.96);
    pointer-events: none;
    transition:
      opacity 0.22s ease,
      transform 0.22s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  :global(.dark) .float-toc-panel {
    background: rgb(var(--surface));
    border-color: oklch(0.9 0 0 / 0.12);
  }

  .float-toc-panel.open {
    display: flex;
    opacity: 1;
    transform: translateX(0) scale(1);
    pointer-events: auto;
  }

  .float-toc-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 12px;
    border-bottom: 1px solid rgb(var(--border) / 0.6);
  }

  .float-toc-title {
    font-size: 13px;
    font-weight: 700;
    color: rgb(var(--fg));
  }

  .float-toc-close {
    width: 28px;
    height: 28px;
    border-radius: 8px;
    border: 1px solid rgb(var(--border) / 0.5);
    background: transparent;
    color: rgb(var(--fg-soft));
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    font-size: 16px;
    line-height: 1;
  }

  .float-toc-body {
    flex: 1;
    overflow-y: auto;
    padding: 8px 10px;
    --toc-color: #6b7280;
    --toc-active-bg: rgba(234, 179, 8, 0.12);
    --toc-active-text: #ca8a04;
  }

  :global(.dark) .float-toc-body {
    --toc-color: #9ca3af;
    --toc-active-bg: rgba(250, 204, 21, 0.12);
    --toc-active-text: #facc15;
  }

  .float-toc-body ol {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .float-toc-body li {
    margin: 1px 0;
  }

  .float-toc-body .toc-link {
    display: block;
    padding: 4px 8px;
    font-size: 13px;
    line-height: 1.6;
    color: var(--toc-color);
    text-decoration: none;
    border-radius: 6px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .float-toc-body .toc-link:hover:not(.active) {
    color: var(--toc-active-text);
    background: rgba(234, 179, 8, 0.04);
  }

  :global(.dark) .float-toc-body .toc-link:hover:not(.active) {
    background: rgba(250, 204, 21, 0.06);
  }

  .float-toc-body .toc-link.active {
    font-weight: 600;
    color: var(--toc-active-text) !important;
    background: var(--toc-active-bg) !important;
    border-radius: 6px;
  }

  .float-toc-body ol.toc-child {
    padding-left: 14px;
  }

  .float-toc-body .toc-child {
    display: none;
    border-left: 1px solid rgba(0, 0, 0, 0.06);
    margin: 2px 0 2px 10px;
  }

  :global(.dark) .float-toc-body .toc-child {
    border-left-color: rgba(255, 255, 255, 0.08);
  }

  .float-toc-body li.toc-item.active > ol.toc-child {
    display: block;
  }

  @media (max-width: 639px) {
    .float-toc-panel {
      right: 58px;
      bottom: 34px;
      width: 230px;
      max-height: 280px;
    }
  }
</style>

<script is:inline>
  (function() {
    // 事件监听只注册一次
    if (!window.__floatingEventsBound) {
      window.__floatingEventsBound = true;

      var themeBtn = document.getElementById('float-theme');
      var topBtn = document.getElementById('float-top');
      var commentBtn = document.getElementById('float-comment');

      themeBtn?.addEventListener('click', () => {
        var isDark = document.documentElement.classList.contains('dark');
        if (isDark) {
          document.documentElement.classList.remove('dark');
          localStorage.setItem('theme', 'light');
        } else {
          document.documentElement.classList.add('dark');
          localStorage.setItem('theme', 'dark');
        }
      });

      if (topBtn) {
        var SHOW_AT = 200;
        var shown = false;

        function checkScroll() {
          var y = window.scrollY;
          if (!shown && y > SHOW_AT) {
            shown = true;
            topBtn.classList.add('visible');
          } else if (shown && y <= SHOW_AT) {
            shown = false;
            topBtn.classList.remove('visible');
          }
        }

        window.addEventListener('scroll', checkScroll, { passive: true });
        checkScroll();

        topBtn.addEventListener('click', () => {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      }

      if (commentBtn) {
        commentBtn.addEventListener('click', () => {
          var el = document.querySelector('#comments, [id*="comment"], #twikoo');
          if (el) {
            el.scrollIntoView({ behavior: 'smooth', block: 'start' });
          } else {
            window.scrollTo({ top: document.body.scrollHeight, behavior: 'smooth' });
          }
        });
      }
    }

    // 每次页面切换都更新显隐
    function updateVisibility() {
      var commentBtn = document.getElementById('float-comment');
      var tocBtn = document.getElementById('float-toc');
      var topBtn = document.getElementById('float-top');
      var desktopToc = document.getElementById('toc-list');

      // 目录按钮：只在有桌面端目录时显示
      if (tocBtn) {
        tocBtn.classList.toggle('visible', !!desktopToc && desktopToc.children.length > 0);
      }

      // 评论按钮：只在文章页和留言页显示
      if (commentBtn) {
        var path = window.location.pathname;
        var showComment = path.startsWith('/posts/') || path === '/link';
        commentBtn.classList.toggle('visible', showComment);
      }

      // 回到顶部按钮：根据滚动位置显示
      if (topBtn) {
        var y = window.scrollY;
        topBtn.classList.toggle('visible', y > 200);
      }
    }

    updateVisibility();
    document.addEventListener('astro:page-load', updateVisibility);
    document.addEventListener('swup:page-view', updateVisibility);

    function hookFloating() {
      if (!window.swup || !window.swup.hooks) return;
      if (window.__floatingSwupHook === window.swup) return;
      window.swup.hooks.on('page:view', updateVisibility);
      window.__floatingSwupHook = window.swup;
    }
    hookFloating();
    if (!window.swup || !window.swup.hooks) {
      var timer = setInterval(function() {
        if (window.swup && window.swup.hooks) {
          clearInterval(timer);
          hookFloating();
        }
      }, 50);
    }
  })();
</script>

<script is:inline>
  (function() {
    // ========== 目录面板逻辑 ==========
    // 事件监听只绑一次
    if (!window.__floatingTocInited) {
      window.__floatingTocInited = true;

      const tocBtn = document.getElementById('float-toc');
      const tocPanel = document.getElementById('float-toc-panel');
      const tocClose = document.getElementById('float-toc-close');
      const tocList = document.getElementById('float-toc-list');

      if (!tocBtn || !tocPanel || !tocClose || !tocList) return;

      let lastDesktopHtml = '';

      function getDesktopToc() {
        return document.getElementById('toc-list');
      }

      function syncActive() {
        const desktopToc = getDesktopToc();
        if (!desktopToc) return;
        const mobileLinks = tocList.querySelectorAll('.toc-link');
        const desktopLinks = desktopToc.querySelectorAll('.toc-link');
        const activeHrefs = new Set();
        desktopLinks.forEach((link) => {
          if (link.classList.contains('active')) {
            const href = link.getAttribute('href');
            if (href) activeHrefs.add(href);
          }
        });
        mobileLinks.forEach((link) => {
          const href = link.getAttribute('href');
          if (href && activeHrefs.has(href)) {
            link.classList.add('active');
          } else {
            link.classList.remove('active');
          }
        });
      }

      function openPanel() {
        const desktopToc = getDesktopToc();
        if (!desktopToc) return;
        const html = desktopToc.innerHTML || '';
        if (html !== lastDesktopHtml) {
          tocList.innerHTML = html;
          lastDesktopHtml = html;
        }
        tocPanel.removeAttribute('hidden');
        tocPanel.classList.add('open');
        tocPanel.setAttribute('aria-hidden', 'false');
        syncActive();
      }

      function closePanel() {
        tocPanel.classList.remove('open');
        tocPanel.setAttribute('aria-hidden', 'true');
        setTimeout(() => {
          if (!tocPanel.classList.contains('open')) {
            tocPanel.hidden = true;
          }
        }, 250);
      }

      tocBtn.addEventListener('click', () => {
        if (tocPanel.classList.contains('open')) {
          closePanel();
        } else {
          openPanel();
        }
      });

      tocClose.addEventListener('click', closePanel);

      tocList.addEventListener('click', (e) => {
        const link = e.target.closest('.toc-link');
        if (!link) return;
        e.preventDefault();
        const href = link.getAttribute('href');
        if (!href) return;
        const dest = document.getElementById(href.slice(1));
        if (dest) {
          dest.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
        closePanel();
      });

      document.addEventListener('click', (e) => {
        if (!tocPanel.contains(e.target) && e.target !== tocBtn && !tocBtn.contains(e.target)) {
          closePanel();
        }
      });

      window.addEventListener('scroll', () => {
        if (tocPanel.classList.contains('open')) {
          syncActive();
        }
      }, { passive: true });
    }

    // 每次页面切换：更新目录按钮显隐 + 刷新面板内容
    function updateTocVisibility() {
      const tocBtn = document.getElementById('float-toc');
      if (!tocBtn) return;
      const desktopToc = document.getElementById('toc-list');
      tocBtn.classList.toggle('visible', !!desktopToc && desktopToc.children.length > 0);
    }

    updateTocVisibility();
    document.addEventListener('astro:page-load', updateTocVisibility);
    document.addEventListener('swup:page-view', updateTocVisibility);

    function hookTocVisibility() {
      if (!window.swup || !window.swup.hooks) return;
      if (window.__tocVisibilityHook === window.swup) return;
      window.swup.hooks.on('page:view', updateTocVisibility);
      window.__tocVisibilityHook = window.swup;
    }
    hookTocVisibility();
    if (!window.swup || !window.swup.hooks) {
      var tocVisTimer = setInterval(function() {
        if (window.swup && window.swup.hooks) {
          clearInterval(tocVisTimer);
          hookTocVisibility();
        }
      }, 50);
    }
  })();
</script>
