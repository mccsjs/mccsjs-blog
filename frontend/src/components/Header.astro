---
import type { MenuItem } from '../types';
import MenuIcon from './MenuIcon.astro';

interface Props {
  siteTitle?: string;
  siteLogo?: string;
  favicon?: string;
  menus?: MenuItem[];
  aggregateMenus?: MenuItem[];
}

const { siteTitle = 'mccsjs', siteLogo = '', favicon = '', menus = [], aggregateMenus = [] } = Astro.props;

const visibleMenus = menus.filter((m) => m.visible);
const visibleAggregateMenus = aggregateMenus.filter((m) => m.visible && m.children?.length);
---

<div id="nav-top-row">
  <div id="nav-pill-wrapper">
    <div id="nav-pill">
      <!-- 毛玻璃层（滚动后显示） -->
      <div id="nav-glass-layer"></div>

      <div id="nav-inner">
        <!-- Logo + 聚合菜单 -->
        <div id="nav-logo-wrapper" class="relative flex items-center gap-2">
          {visibleAggregateMenus.length > 0 && (
            <button id="nav-aggregate-trigger" class="flex shrink-0 items-center justify-center" aria-label="打开聚合菜单">
              {favicon ? (
                <img src={favicon} alt={siteTitle} class="nav-logo-icon" />
              ) : (
                <iconify-icon icon="ep:menu" class="nav-logo-icon" width="20" height="20"></iconify-icon>
              )}
            </button>
          )}
          <a id="nav-logo" href="/">
            <span class="nav-logo-text">{siteTitle}</span>
          </a>

          {visibleAggregateMenus.length > 0 && (
            <div id="nav-aggregate-dropdown" class="nav-aggregate-dropdown">
              {visibleAggregateMenus.map((group) => (
                <div class="aggregate-group">
                  <div class="aggregate-title">{group.label}</div>
                  <div class="aggregate-grid">
                    {group.children
                      ?.filter((child) => child.visible)
                      .map((child) => (
                        <a
                          href={child.href || '#'}
                          target={child.target || undefined}
                          class="aggregate-item"
                        >
                          {child.icon && <MenuIcon icon={child.icon} class="aggregate-icon" />}
                          <span>{child.label}</span>
                        </a>
                      ))}
                  </div>
                </div>
              ))}
            </div>
          )}
        </div>

        <!-- 居中导航菜单 -->
        <div id="nav-center" class="nav-desktop-menu">
          <div id="nav-hover-border"></div>

          {visibleMenus.length > 0 ? (
            visibleMenus.map((menu) => {
              const visibleChildren = menu.children?.filter((c) => c.visible) ?? [];
              return visibleChildren.length > 0 ? (
                <div class="nav-dropdown-wrapper">
                  <button class="nav-item nav-has-children" data-dropdown-trigger>
                    {menu.icon && <MenuIcon icon={menu.icon} class="nav-icon" />}
                    <span>{menu.label}</span>
                    <svg class="nav-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
                  </button>
                  <div class="nav-dropdown-panel">
                    {visibleChildren.map((child) => (
                      <a href={child.href || '#'} target={child.target || undefined} class="nav-dropdown-item">
                        {child.icon && <MenuIcon icon={child.icon} class="nav-icon" />}
                        <span>{child.label}</span>
                      </a>
                    ))}
                  </div>
                </div>
              ) : (
                <a href={menu.href || '#'} target={menu.target || undefined} class="nav-item nav-link-item" data-nav-link>
                  {menu.icon && <MenuIcon icon={menu.icon} class="nav-icon" />}
                  <span>{menu.label}</span>
                </a>
              );
            })
          ) : (
            <>
              <a href="/" class="nav-item nav-link-item" data-nav-link><span>首页</span></a>
              <a href="/posts" class="nav-item nav-link-item" data-nav-link><span>文章</span></a>
              <a href="/archive" class="nav-item nav-link-item" data-nav-link><span>归档</span></a>
              <a href="/link" class="nav-item nav-link-item" data-nav-link><span>友链</span></a>
            </>
          )}
        </div>

        <!-- 右侧工具栏 -->
        <div id="nav-right">
          <!-- 搜索 -->
          <button id="nav-search-btn" class="nav-theme-btn" aria-label="搜索">
            <iconify-icon icon="humbleicons:search" width="18" height="18"></iconify-icon>
          </button>
          <!-- 主题切换 -->
          <button id="theme-toggle" class="nav-theme-btn" aria-label="切换主题">
            <iconify-icon icon="line-md:moon" class="theme-icon theme-icon-dark" width="18" height="18"></iconify-icon>
            <iconify-icon icon="solar:sun-broken" class="theme-icon theme-icon-light" width="18" height="18"></iconify-icon>
          </button>
          <!-- 移动端菜单开关 -->
          <button id="nav-mobile-toggle" class="nav-desktop-hide" aria-label="菜单">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <line x1="4" y1="6" x2="20" y2="6" />
              <line x1="4" y1="12" x2="20" y2="12" />
              <line x1="4" y1="18" x2="20" y2="18" />
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ========== 移动端抽屉 ========== -->
<div id="nav-mobile-overlay"></div>
<nav id="nav-mobile-drawer">
  <div id="nav-mobile-header">
    <span class="nav-mobile-title">导航</span>
    <button id="nav-mobile-close" aria-label="关闭">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" />
      </svg>
    </button>
  </div>
  <div id="nav-mobile-body">
    {visibleMenus.length > 0 ? (
      visibleMenus.map((menu, i) => {
        const visibleChildren = menu.children?.filter((c) => c.visible) ?? [];
        return (
          <div class="nav-mobile-group" style={`--stagger: ${i}`}>
            {visibleChildren.length > 0 ? (
              <>
                <div class="nav-mobile-parent">
                  {menu.icon && <MenuIcon icon={menu.icon} class="nav-icon" />}
                  <span>{menu.label}</span>
                </div>
                <div class="nav-mobile-children">
                  {visibleChildren.map((child) => (
                    <a href={child.href || '#'} target={child.target || undefined} class="nav-mobile-link">
                      {child.icon && <MenuIcon icon={child.icon} class="nav-icon" />}
                      <span>{child.label}</span>
                    </a>
                  ))}
                </div>
              </>
            ) : (
              <a href={menu.href || '#'} target={menu.target || undefined} class="nav-mobile-link nav-mobile-parent-link">
                {menu.icon && <MenuIcon icon={menu.icon} class="nav-icon" />}
                <span>{menu.label}</span>
              </a>
            )}
          </div>
        );
      })
    ) : (
      <>
        <a href="/" class="nav-mobile-link nav-mobile-parent-link"><span>首页</span></a>
        <a href="/posts" class="nav-mobile-link nav-mobile-parent-link"><span>文章</span></a>
        <a href="/archive" class="nav-mobile-link nav-mobile-parent-link"><span>归档</span></a>
        <a href="/link" class="nav-mobile-link nav-mobile-parent-link"><span>友链</span></a>
      </>
    )}
  </div>
</nav>

<!-- ========== 搜索弹窗 ========== -->
<div id="search-overlay" class="search-overlay">
  <div class="search-container">
    <div class="search-input-wrapper">
      <iconify-icon icon="material-symbols:search-rounded" class="search-input-icon" width="20" height="20"></iconify-icon>
      <input id="search-input" type="text" placeholder="搜索文章..." autocomplete="off" class="search-input" />
      <button id="search-close" class="search-close-btn" aria-label="关闭">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
      </button>
    </div>
    <div id="search-results" class="search-results"></div>
    <div id="search-hint" class="search-hint">
      输入关键词搜索文章，按 <kbd>↑</kbd> <kbd>↓</kbd> 导航，<kbd>Enter</kbd> 打开，<kbd>Esc</kbd> 关闭
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    // ========= 模块级状态 =========
    if (window.__headerInit) return;
    window.__headerInit = true;

    let _navAbort = null;

    // 关闭抽屉（模块级，供 swup 钩子和事件委托共用）
    function closeDrawer() {
      const mobileOverlay = document.getElementById('nav-mobile-overlay');
      const mobileDrawer = document.getElementById('nav-mobile-drawer');
      mobileOverlay?.classList.remove('open');
      mobileDrawer?.classList.remove('open');
      document.body.style.overflow = '';
    }

    // 事件委托：捕获阶段拦截 .nav-mobile-link 点击，在 swup 之前关闭抽屉
    document.addEventListener('click', (e) => {
      const link = (e.target).closest('.nav-mobile-link');
      if (link) closeDrawer();
    }, true);

    // swup 页面切换后强制关闭抽屉
    function ensureSwupHook() {
      if (!window.swup || !window.swup.hooks) return;
      // 如果已注册过且 swup 实例相同，跳过
      if (window.__headerSwupHook && window.__headerSwupHook === window.swup) return;
      window.swup.hooks.on('page:view', closeDrawer);
      window.__headerSwupHook = window.swup;
    }
    ensureSwupHook();
    // swup 可能异步加载，延迟重试
    if (!window.swup || !window.swup.hooks) {
      var swupAttempts = 0;
      var swupTimer = setInterval(function () {
        swupAttempts++;
        if (window.swup && window.swup.hooks) {
          clearInterval(swupTimer);
          ensureSwupHook();
        } else if (swupAttempts >= 40) {
          clearInterval(swupTimer);
        }
      }, 50);
    }

    function initNav() {
      // 清理旧监听器
      if (_navAbort) _navAbort.abort();
      _navAbort = new AbortController();
      const signal = _navAbort.signal;

    const topRow = document.getElementById('nav-top-row');
    const hoverBorder = document.getElementById('nav-hover-border');
    const navCenter = document.getElementById('nav-center');
    const mobileToggle = document.getElementById('nav-mobile-toggle');
    const mobileOverlay = document.getElementById('nav-mobile-overlay');
    const mobileDrawer = document.getElementById('nav-mobile-drawer');
    const mobileClose = document.getElementById('nav-mobile-close');

    if (!topRow) return;

    // ========= 1. 滚动收缩 =========
    const SCROLL_IN = 80;
    const SCROLL_OUT = 40;
    let scrolled = false;

    function onScroll() {
      const y = window.scrollY;
      if (!scrolled && y > SCROLL_IN) {
        scrolled = true;
        topRow.classList.add('scrolled');
      } else if (scrolled && y < SCROLL_OUT) {
        scrolled = false;
        topRow.classList.remove('scrolled');
      }
    }
    window.addEventListener('scroll', onScroll, { passive: true, signal });
    onScroll();

    // ========= 2. hover 滑动边框 =========
    let _hoverAbort = null;

    function cleanupHover() {
      if (_hoverAbort) { _hoverAbort.abort(); _hoverAbort = null; }
    }

    function initHover() {
      cleanupHover();
      if (!hoverBorder || !navCenter) return;

      _hoverAbort = new AbortController();
      const sig = _hoverAbort.signal;

      const navItems = navCenter.querySelectorAll(':scope > .nav-dropdown-wrapper, :scope > .nav-link-item');

      function positionBorder(item) {
        // 批量读取布局属性，然后批量写入样式（减少强制重排）
        const rect = item.getBoundingClientRect();
        const cRect = navCenter.getBoundingClientRect();
        // 先读取所有需要的值，再一次性写入样式
        const width = `${rect.width}px`;
        const height = `${rect.height}px`;
        const left = `${rect.left - cRect.left}px`;
        const top = `${(cRect.height - rect.height) / 2}px`;

        hoverBorder.style.width = width;
        hoverBorder.style.height = height;
        hoverBorder.style.left = left;
        hoverBorder.style.top = top;
      }

      function detectActive() {
        const path = window.location.pathname.replace(/\/$/, '') || '/';
        let hasActive = false;
        navItems.forEach((item) => {
          const link = item.querySelector('a, button[data-dropdown-trigger]');
          if (!link) return;
          const href = (link.getAttribute('href') || '').replace(/\/$/, '') || '/';
          if (href === path || (path !== '/' && href !== '/' && path.startsWith(href))) {
            item.classList.add('nav-item-active');
            hasActive = true;
            positionBorder(item);
          } else {
            item.classList.remove('nav-item-active');
          }
        });
        if (hasActive) {
          navCenter.classList.add('nav-has-active');
        } else {
          navCenter.classList.remove('nav-has-active');
        }
      }

      navItems.forEach((item) => {
        item.addEventListener('mouseenter', () => positionBorder(item), { signal: sig });
      });

      navCenter.addEventListener('mouseleave', () => {
        const active = navCenter.querySelector('.nav-item-active');
        if (active) {
          positionBorder(active);
        } else {
          hoverBorder.style.opacity = '0';
        }
      }, { signal: sig });

      navCenter.addEventListener('mouseenter', () => {
        hoverBorder.style.opacity = '1';
      }, { signal: sig });

      detectActive();
      document.addEventListener('astro:page-load', detectActive, { signal: sig });
    }

    initHover();

    // ========= 3. 下拉菜单 =========
    let openDropdown = null;

    document.querySelectorAll('[data-dropdown-trigger]').forEach((btn) => {
      const wrapper = btn.closest('.nav-dropdown-wrapper');

      btn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();

        if (openDropdown && openDropdown !== wrapper) {
          openDropdown.classList.remove('open');
        }

        if (wrapper.classList.contains('open')) {
          wrapper.classList.remove('open');
          openDropdown = null;
        } else {
          wrapper.classList.add('open');
          openDropdown = wrapper;
        }
      }, { signal });
    });

    document.addEventListener('click', (e) => {
      if (!e.target.closest('.nav-dropdown-wrapper')) {
        if (openDropdown) {
          openDropdown.classList.remove('open');
          openDropdown = null;
        }
      }
    }, { signal });

    // ========= 4. 移动端抽屉 =========
    function openDrawer() {
      mobileOverlay?.classList.add('open');
      mobileDrawer?.classList.add('open');
      document.body.style.overflow = 'hidden';
    }

    mobileToggle?.addEventListener('click', openDrawer, { signal });
    mobileClose?.addEventListener('click', closeDrawer, { signal });
    mobileOverlay?.addEventListener('click', closeDrawer, { signal });

    // ESC 关闭
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeDrawer();
    }, { signal });

    // ========= 5. 聚合菜单下拉 =========
    const aggTrigger = document.getElementById('nav-aggregate-trigger');
    const aggDropdown = document.getElementById('nav-aggregate-dropdown');
    if (aggTrigger && aggDropdown) {
      let aggTimer = 0;

      function openAggDropdown() {
        clearTimeout(aggTimer);
        aggDropdown.classList.add('open');
      }

      function closeAggDropdown() {
        aggTimer = window.setTimeout(() => {
          aggDropdown.classList.remove('open');
        }, 150);
      }

      aggTrigger.addEventListener('mouseenter', openAggDropdown, { signal });
      aggTrigger.addEventListener('mouseleave', closeAggDropdown, { signal });
      aggDropdown.addEventListener('mouseenter', openAggDropdown, { signal });
      aggDropdown.addEventListener('mouseleave', closeAggDropdown, { signal });

      aggTrigger.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        if (aggDropdown.classList.contains('open')) {
          aggDropdown.classList.remove('open');
        } else {
          aggDropdown.classList.add('open');
        }
      }, { signal });

      document.addEventListener('click', (e) => {
        if (!aggTrigger.contains(e.target) && !aggDropdown.contains(e.target)) {
          aggDropdown.classList.remove('open');
        }
      }, { signal });
    }
  }

  initNav();
  document.addEventListener('astro:page-load', initNav);

  // ========= 主题切换 =========
  // 确保 iconify-icon 已加载（不依赖 dynamic import）
  if (!customElements.get('iconify-icon')) {
    const script = document.createElement('script');
    script.src = 'https://code.iconify.design/3/3.1.0/iconify.min.js';
    script.defer = true;
    document.head.appendChild(script);
  }

  const themeToggle = document.getElementById('theme-toggle');
  themeToggle?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.contains('dark');
    if (isDark) {
      document.documentElement.classList.remove('dark');
      localStorage.setItem('theme', 'light');
    } else {
      document.documentElement.classList.add('dark');
      localStorage.setItem('theme', 'dark');
    }
    // 强制重绘，确保字体渲染更新
    void document.documentElement.offsetHeight;
  });

  // ========= 搜索 =========
  const API_URL = window.__API_URL__ || 'http://localhost:4000';
  let searchAbort = null;
  let searchResults = [];
  let searchActiveIdx = -1;

  const searchOverlay = document.getElementById('search-overlay');
  const searchInput = document.getElementById('search-input');
  const searchResultsEl = document.getElementById('search-results');
  const searchHint = document.getElementById('search-hint');
  const searchClose = document.getElementById('search-close');
  const searchBtn = document.getElementById('nav-search-btn');

  function openSearch() {
    searchOverlay?.classList.add('open');
    document.body.style.overflow = 'hidden';
    setTimeout(() => searchInput?.focus(), 50);
  }

  function closeSearch() {
    searchOverlay?.classList.remove('open');
    document.body.style.overflow = '';
    if (searchInput) searchInput.value = '';
    if (searchResultsEl) searchResultsEl.innerHTML = '';
    if (searchHint) searchHint.style.display = '';
    searchResults = [];
    searchActiveIdx = -1;
  }

  searchBtn?.addEventListener('click', openSearch);
  searchClose?.addEventListener('click', closeSearch);
  searchOverlay?.addEventListener('click', (e) => {
    if (e.target === searchOverlay) closeSearch();
  });

  document.addEventListener('keydown', (e) => {
    // Ctrl+K / Cmd+K 打开搜索
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
      e.preventDefault();
      if (searchOverlay?.classList.contains('open')) {
        closeSearch();
      } else {
        openSearch();
      }
      return;
    }
    if (!searchOverlay?.classList.contains('open')) return;
    if (e.key === 'Escape') {
      closeSearch();
    }
  });

  let searchTimer = 0;
  searchInput?.addEventListener('input', () => {
    clearTimeout(searchTimer);
    searchTimer = window.setTimeout(doSearch, 300);
  });

  async function doSearch() {
    const q = searchInput?.value.trim() || '';
    if (!q) {
      if (searchResultsEl) searchResultsEl.innerHTML = '';
      if (searchHint) searchHint.style.display = '';
      searchResults = [];
      searchActiveIdx = -1;
      return;
    }
    if (searchHint) searchHint.style.display = 'none';

    if (searchAbort) searchAbort.abort();
    searchAbort = new AbortController();

    try {
      const res = await fetch(`${API_URL}/api/posts/search?q=${encodeURIComponent(q)}`, {
        signal: searchAbort.signal,
      });
      if (!res.ok) return;
      searchResults = await res.json();
      searchActiveIdx = -1;
      renderResults(q);
    } catch {
      // aborted or failed
    }
  }

  function renderResults(q) {
    if (!searchResultsEl) return;
    if (searchResults.length === 0) {
      searchResultsEl.innerHTML = '<div class="search-empty">没有找到相关文章</div>';
      return;
    }

    const escapeHtml = (s) => s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    const highlight = (s) => {
      const escaped = escapeHtml(s);
      const escapedQ = q.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
      return escaped.replace(new RegExp(`(${escapedQ})`, 'gi'), '<mark>$1</mark>');
    };

    searchResultsEl.innerHTML = searchResults.map((post, i) => `
      <a href="/posts/${post.slug}" class="search-result-item ${i === searchActiveIdx ? 'active' : ''}" data-idx="${i}">
        <div class="search-result-title">${highlight(post.title)}</div>
        ${post.excerpt ? `<div class="search-result-excerpt">${highlight(post.excerpt)}</div>` : ''}
        <div class="search-result-meta">${new Date(post.createdAt).toLocaleDateString('zh-CN')}</div>
      </a>
    `).join('');

    // 点击结果项
    searchResultsEl.querySelectorAll('.search-result-item').forEach((el) => {
      el.addEventListener('click', () => closeSearch());
      el.addEventListener('mouseenter', () => {
        searchActiveIdx = parseInt(el.dataset.idx || '0');
        updateActiveItem();
      });
    });
  }

  function updateActiveItem() {
    if (!searchResultsEl) return;
    searchResultsEl.querySelectorAll('.search-result-item').forEach((el, i) => {
      el.classList.toggle('active', i === searchActiveIdx);
    });
    const active = searchResultsEl.querySelector('.search-result-item.active');
    if (active) active.scrollIntoView({ block: 'nearest' });
  }

  // 键盘导航
  searchInput?.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      searchActiveIdx = Math.min(searchActiveIdx + 1, searchResults.length - 1);
      updateActiveItem();
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      searchActiveIdx = Math.max(searchActiveIdx - 1, 0);
      updateActiveItem();
    } else if (e.key === 'Enter' && searchActiveIdx >= 0) {
      e.preventDefault();
      const post = searchResults[searchActiveIdx];
      if (post) {
        closeSearch();
        window.location.href = `/posts/${post.slug}`;
      }
    }
  });
})();
</script>
