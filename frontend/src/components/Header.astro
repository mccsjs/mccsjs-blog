---
import type { MenuItem } from '../types';
import MenuIcon from './MenuIcon.astro';

interface Props {
  siteTitle?: string;
  siteLogo?: string;
  favicon?: string;
  menus?: MenuItem[];
  aggregateMenus?: MenuItem[];
}

const { siteTitle = 'mccsjs', siteLogo = '', favicon = '', menus = [], aggregateMenus = [] } = Astro.props;

const visibleMenus = menus.filter((m) => m.visible);
const visibleAggregateMenus = aggregateMenus.filter((m) => m.visible && m.children?.length);
---

<div id="nav-top-row">
  <div id="nav-pill-wrapper">
    <div id="nav-pill">
      <!-- 毛玻璃层（滚动后显示） -->
      <div id="nav-glass-layer"></div>

      <div id="nav-inner">
        <!-- Logo + 聚合菜单 -->
        <div id="nav-logo-wrapper" class="relative flex items-center gap-2">
          {visibleAggregateMenus.length > 0 && (
            <button id="nav-aggregate-trigger" class="flex shrink-0 items-center justify-center" aria-label="打开聚合菜单">
              {favicon ? (
                <img src={favicon} alt={siteTitle} class="nav-logo-icon" />
              ) : (
                <iconify-icon icon="ep:menu" class="nav-logo-icon" width="20" height="20"></iconify-icon>
              )}
            </button>
          )}
          <a id="nav-logo" href="/">
            <span class="nav-logo-text">{siteTitle}</span>
          </a>

          {visibleAggregateMenus.length > 0 && (
            <div id="nav-aggregate-dropdown" class="nav-aggregate-dropdown">
              {visibleAggregateMenus.map((group) => (
                <div class="aggregate-group">
                  <div class="aggregate-title">{group.label}</div>
                  <div class="aggregate-grid">
                    {group.children
                      ?.filter((child) => child.visible)
                      .map((child) => (
                        <a
                          href={child.href || '#'}
                          target={child.target || undefined}
                          class="aggregate-item"
                        >
                          {child.icon && <MenuIcon icon={child.icon} class="aggregate-icon" />}
                          <span>{child.label}</span>
                        </a>
                      ))}
                  </div>
                </div>
              ))}
            </div>
          )}
        </div>

        <!-- 居中导航菜单 -->
        <div id="nav-center" class="nav-desktop-menu">
          <div id="nav-hover-border"></div>

          {visibleMenus.length > 0 ? (
            visibleMenus.map((menu) => {
              const visibleChildren = menu.children?.filter((c) => c.visible) ?? [];
              return visibleChildren.length > 0 ? (
                <div class="nav-dropdown-wrapper">
                  <button class="nav-item nav-has-children" data-dropdown-trigger>
                    {menu.icon && <MenuIcon icon={menu.icon} class="nav-icon" />}
                    <span>{menu.label}</span>
                    <svg class="nav-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
                  </button>
                  <div class="nav-dropdown-panel">
                    {visibleChildren.map((child) => (
                      <a href={child.href || '#'} target={child.target || undefined} class="nav-dropdown-item">
                        {child.icon && <MenuIcon icon={child.icon} class="nav-icon" />}
                        <span>{child.label}</span>
                      </a>
                    ))}
                  </div>
                </div>
              ) : (
                <a href={menu.href || '#'} target={menu.target || undefined} class="nav-item nav-link-item" data-nav-link>
                  {menu.icon && <MenuIcon icon={menu.icon} class="nav-icon" />}
                  <span>{menu.label}</span>
                </a>
              );
            })
          ) : (
            <>
              <a href="/" class="nav-item nav-link-item" data-nav-link><span>首页</span></a>
              <a href="/posts" class="nav-item nav-link-item" data-nav-link><span>文章</span></a>
              <a href="/archive" class="nav-item nav-link-item" data-nav-link><span>归档</span></a>
              <a href="/link" class="nav-item nav-link-item" data-nav-link><span>友链</span></a>
            </>
          )}
        </div>

        <!-- 右侧工具栏 -->
        <div id="nav-right">
          <!-- 搜索 -->
          <button id="nav-search-btn" class="nav-theme-btn" aria-label="搜索">
            <iconify-icon icon="humbleicons:search" width="18" height="18"></iconify-icon>
          </button>
          <!-- 主题切换 -->
          <button id="theme-toggle" class="nav-theme-btn" aria-label="切换主题">
            <iconify-icon icon="line-md:moon" class="theme-icon theme-icon-dark" width="18" height="18"></iconify-icon>
            <iconify-icon icon="solar:sun-broken" class="theme-icon theme-icon-light" width="18" height="18"></iconify-icon>
          </button>
          <!-- 移动端菜单开关 -->
          <button id="nav-mobile-toggle" class="nav-desktop-hide" aria-label="菜单">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <line x1="4" y1="6" x2="20" y2="6" />
              <line x1="4" y1="12" x2="20" y2="12" />
              <line x1="4" y1="18" x2="20" y2="18" />
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ========== 移动端抽屉 ========== -->
<div id="nav-mobile-overlay"></div>
<nav id="nav-mobile-drawer">
  <div id="nav-mobile-header">
    <span class="nav-mobile-title">导航</span>
    <button id="nav-mobile-close" aria-label="关闭">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" />
      </svg>
    </button>
  </div>
  <div id="nav-mobile-body">
    {visibleMenus.length > 0 ? (
      visibleMenus.map((menu, i) => {
        const visibleChildren = menu.children?.filter((c) => c.visible) ?? [];
        return (
          <div class="nav-mobile-group" style={`--stagger: ${i}`}>
            {visibleChildren.length > 0 ? (
              <>
                <div class="nav-mobile-parent">
                  {menu.icon && <MenuIcon icon={menu.icon} class="nav-icon" />}
                  <span>{menu.label}</span>
                </div>
                <div class="nav-mobile-children">
                  {visibleChildren.map((child) => (
                    <a href={child.href || '#'} target={child.target || undefined} class="nav-mobile-link">
                      {child.icon && <MenuIcon icon={child.icon} class="nav-icon" />}
                      <span>{child.label}</span>
                    </a>
                  ))}
                </div>
              </>
            ) : (
              <a href={menu.href || '#'} target={menu.target || undefined} class="nav-mobile-link nav-mobile-parent-link">
                {menu.icon && <MenuIcon icon={menu.icon} class="nav-icon" />}
                <span>{menu.label}</span>
              </a>
            )}
          </div>
        );
      })
    ) : (
      <>
        <a href="/" class="nav-mobile-link nav-mobile-parent-link"><span>首页</span></a>
        <a href="/posts" class="nav-mobile-link nav-mobile-parent-link"><span>文章</span></a>
        <a href="/archive" class="nav-mobile-link nav-mobile-parent-link"><span>归档</span></a>
        <a href="/link" class="nav-mobile-link nav-mobile-parent-link"><span>友链</span></a>
      </>
    )}
  </div>
</nav>

<!-- ========== 搜索弹窗 ========== -->
<div id="search-overlay" class="search-overlay">
  <div class="search-container">
    <div class="search-input-wrapper">
      <iconify-icon icon="material-symbols:search-rounded" class="search-input-icon" width="20" height="20"></iconify-icon>
      <input id="search-input" type="text" placeholder="搜索文章..." autocomplete="off" class="search-input" />
      <button id="search-close" class="search-close-btn" aria-label="关闭">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
      </button>
    </div>
    <div id="search-results" class="search-results"></div>
    <div id="search-hint" class="search-hint">
      输入关键词搜索文章，按 <kbd>↑</kbd> <kbd>↓</kbd> 导航，<kbd>Enter</kbd> 打开，<kbd>Esc</kbd> 关闭
    </div>
  </div>
</div>

<style>
  /* ============================================= */
  /*  浮动胶囊导航栏                                 */
  /* ============================================= */

  #nav-top-row {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    padding: 20px 16px 0;
    transition: padding 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }
  #nav-top-row.scrolled {
    padding-top: 8px;
  }

  #nav-pill-wrapper {
    margin: 0 auto;
    width: min(94%, 1100px);
    transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }
  #nav-top-row.scrolled #nav-pill-wrapper {
    width: min(80%, 860px);
  }

  #nav-pill {
    position: relative;
    border-radius: 50px;
    background: oklch(1 0 0 / 0.72);
    border: 1px solid oklch(0 0 0 / 0.06);
    box-shadow: 0 1px 3px oklch(0 0 0 / 0.04);
    transition: border-radius 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    min-width: 0;
  }
  :global(.dark) #nav-pill {
    background: oklch(0.22 0 0 / 0.88);
    border-color: oklch(1 0 0 / 0.12);
    box-shadow: 0 1px 3px oklch(0 0 0 / 0.25);
  }

  /* 毛玻璃层 */
  #nav-glass-layer {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    overflow: hidden;
    background: oklch(1 0 0 / 0.15);
    backdrop-filter: blur(12px) saturate(1.8);
    -webkit-backdrop-filter: blur(12px) saturate(1.8);
    opacity: 0;
    transition: opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
  }
  :global(.dark) #nav-glass-layer {
    background: oklch(0.14 0 0 / 0.45);
  }
  #nav-top-row.scrolled #nav-glass-layer {
    opacity: 1;
  }

  #nav-inner {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 52px;
    padding: 0 20px;
    transition: height 0.4s cubic-bezier(0.4, 0, 0.2, 1),
                padding 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }
  #nav-top-row.scrolled #nav-inner {
    height: 44px;
    padding: 0 14px;
  }

  /* Logo */
  #nav-logo {
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    flex-shrink: 0;
    z-index: 2;
  }
  .nav-logo-text {
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: oklch(0.2 0 0);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  :global(.dark) .nav-logo-text {
    color: oklch(0.9 0 0);
  }
  .nav-logo-icon {
    height: 28px;
    width: 28px;
    object-fit: contain;
    flex-shrink: 0;
    transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  #nav-aggregate-trigger {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 4px;
    border: none;
    background: transparent;
    border-radius: 10px;
    cursor: pointer;
    line-height: 0;
    color: oklch(0.2 0 0);
    transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }
  :global(.dark) #nav-aggregate-trigger {
    color: oklch(0.9 0 0);
  }
  #nav-aggregate-trigger:hover {
    background: oklch(0 0 0 / 0.06);
    color: oklch(0.1 0 0);
  }
  :global(.dark) #nav-aggregate-trigger:hover {
    background: oklch(1 0 0 / 0.08);
    color: oklch(0.95 0 0);
  }
  #nav-aggregate-trigger:active {
    transform: scale(0.96);
  }
  #nav-aggregate-trigger iconify-icon {
    width: 20px;
    height: 20px;
    display: block;
  }

  .nav-logo-img {
    height: 28px;
    width: auto;
    object-fit: contain;
    transition: height 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }
  #nav-top-row.scrolled .nav-logo-img {
    height: 24px;
  }

  /* 聚合菜单下拉 */
  #nav-logo-wrapper {
    flex-shrink: 0;
    z-index: 2;
  }
  .nav-aggregate-dropdown {
    position: absolute;
    top: calc(100% + 12px);
    left: 0;
    width: 280px;
    padding: 14px;
    border-radius: 16px;
    background: oklch(1 0 0 / 0.92);
    backdrop-filter: blur(20px) saturate(1.8);
    -webkit-backdrop-filter: blur(20px) saturate(1.8);
    border: 1px solid oklch(0 0 0 / 0.08);
    box-shadow: 0 12px 40px oklch(0 0 0 / 0.10);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-6px);
    transition: opacity 0.22s ease, transform 0.22s ease, visibility 0.22s;
    pointer-events: none;
    z-index: 50;
  }
  .nav-aggregate-dropdown.open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    pointer-events: auto;
  }
  :global(.dark) .nav-aggregate-dropdown {
    background: oklch(0.14 0 0 / 0.88);
    border-color: oklch(1 0 0 / 0.06);
    box-shadow: 0 8px 32px oklch(0 0 0 / 0.3);
  }
  .aggregate-group:not(:last-child) {
    margin-bottom: 10px;
    padding-bottom: 10px;
    border-bottom: 1px solid oklch(0 0 0 / 0.04);
  }
  :global(.dark) .aggregate-group:not(:last-child) {
    border-color: oklch(1 0 0 / 0.05);
  }
  .aggregate-title {
    padding: 0 6px 6px;
    font-size: 12px;
    font-weight: 600;
    color: oklch(0.35 0 0 / 0.5);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  :global(.dark) .aggregate-title {
    color: oklch(0.65 0 0 / 0.6);
  }
  .aggregate-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 4px;
  }
  .aggregate-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 10px;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 500;
    color: oklch(0.35 0 0);
    text-decoration: none;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .aggregate-item:hover {
    background: oklch(0 0 0 / 0.04);
    color: oklch(0.1 0 0);
  }
  :global(.dark) .aggregate-item {
    color: oklch(0.65 0 0);
  }
  :global(.dark) .aggregate-item:hover {
    background: oklch(1 0 0 / 0.06);
    color: oklch(0.95 0 0);
  }
  .aggregate-icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }
  .aggregate-icon :global(img),
  .aggregate-icon :global(svg),
  .aggregate-icon :global(iconify-icon) {
    width: 18px;
    height: 18px;
  }

  /* 居中菜单 */
  #nav-center {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    align-items: center;
    gap: 2px;
    z-index: 1;
  }

  /* hover 滑动边框（纯边框，复刻 ming：无背景填充） */
  #nav-hover-border {
    position: absolute;
    height: 2.5rem;
    border-radius: 9999px;
    border: 1.5px solid oklch(0.35 0 0);
    background: transparent;
    opacity: 0;
    pointer-events: none;
    z-index: 0;
    transition: left 0.25s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                width 0.25s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                height 0.25s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                top 0.25s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                opacity 0.25s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                border-color 0.25s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  :global(.dark) #nav-hover-border {
    border-color: oklch(0.75 0 0);
  }

  /* hover 时才显示边框 */
  #nav-center:hover #nav-hover-border,
  #nav-center.nav-has-active #nav-hover-border {
    opacity: 1;
  }

  /* 禁用导航项自身的悬停背景 */
  .nav-item:hover {
    background: none !important;
  }
  .nav-item:active::before,
  .nav-item:hover::before,
  .nav-item::before {
    background: transparent !important;
  }

  /* 导航项 */
  .nav-item {
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 6px 12px;
    border-radius: 50px;
    font-size: 15px;
    font-weight: 500;
    color: oklch(0.35 0 0);
    text-decoration: none;
    background: none;
    border: none;
    cursor: pointer;
    white-space: nowrap;
    transition: color 0.15s ease, background 0.15s ease;
    font-family: inherit;
    line-height: 1;
  }
  :global(.dark) .nav-item {
    color: oklch(0.65 0 0);
  }
  .nav-item:hover {
    color: oklch(0.1 0 0);
  }
  :global(.dark) .nav-item:hover {
    color: oklch(0.95 0 0);
  }

  .nav-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }
  .nav-icon :global(img),
  .nav-icon :global(svg) {
    width: 16px;
    height: 16px;
  }

  .nav-chevron {
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }
  .nav-dropdown-wrapper.open .nav-chevron {
    transform: rotate(180deg);
  }

  /* 下拉面板 */
  .nav-dropdown-wrapper {
    position: relative;
  }
  .nav-dropdown-panel {
    position: absolute;
    top: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%) translateY(-8px);
    min-width: 160px;
    padding: 6px;
    border-radius: 16px;
    background: oklch(1 0 0 / 0.85);
    backdrop-filter: blur(16px) saturate(1.8);
    -webkit-backdrop-filter: blur(16px) saturate(1.8);
    border: 1px solid oklch(0 0 0 / 0.06);
    box-shadow: 0 8px 32px oklch(0 0 0 / 0.08);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s ease-out, transform 0.2s ease-out, visibility 0.2s;
    z-index: 10;
  }
  :global(.dark) .nav-dropdown-panel {
    background: oklch(0.12 0 0 / 0.85);
    border-color: oklch(1 0 0 / 0.06);
    box-shadow: 0 8px 32px oklch(0 0 0 / 0.3);
  }
  .nav-dropdown-wrapper.open .nav-dropdown-panel {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  .nav-dropdown-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 500;
    color: oklch(0.35 0 0);
    text-decoration: none;
    transition: background 0.15s ease, color 0.15s ease;
  }
  :global(.dark) .nav-dropdown-item {
    color: oklch(0.65 0 0);
  }
  .nav-dropdown-item:hover {
    background: oklch(0 0 0 / 0.04);
    color: oklch(0.1 0 0);
  }
  :global(.dark) .nav-dropdown-item:hover {
    background: oklch(1 0 0 / 0.06);
    color: oklch(0.95 0 0);
  }

  /* 右侧工具栏 */
  #nav-right {
    display: flex;
    align-items: center;
    gap: 0;
    flex-shrink: 0;
    z-index: 2;
  }

  #nav-mobile-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: none;
    background: none;
    color: oklch(0.35 0 0);
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease;
  }
  :global(.dark) #nav-mobile-toggle {
    color: oklch(0.9 0 0);
  }
  #nav-mobile-toggle:hover {
    background: oklch(0 0 0 / 0.06);
  }
  :global(.dark) #nav-mobile-toggle:hover {
    background: oklch(1 0 0 / 0.08);
  }

  /* 主题切换按钮 */
  #theme-toggle,
  #nav-search-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: none;
    background: none;
    color: oklch(0.35 0 0);
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease;
  }
  #theme-toggle {
    position: relative;
    overflow: hidden;
  }
  :global(.dark) #theme-toggle,
  :global(.dark) #nav-search-btn {
    color: oklch(0.9 0 0);
  }
  #theme-toggle:hover,
  #nav-search-btn:hover {
    background: oklch(0 0 0 / 0.06);
  }
  :global(.dark) #theme-toggle:hover,
  :global(.dark) #nav-search-btn:hover {
    background: oklch(1 0 0 / 0.08);
  }
  .theme-icon {
    position: absolute;
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.3s ease;
  }
  .theme-icon-dark {
    /* 亮色模式显示月亮 → 暗色模式隐藏 */
    opacity: 1;
    transform: scale(1) rotate(0deg);
  }
  :global(.dark) .theme-icon-dark {
    opacity: 0;
    transform: scale(0.5) rotate(90deg);
    pointer-events: none;
  }
  .theme-icon-light {
    /* 亮色模式隐藏太阳 → 暗色模式显示 */
    opacity: 0;
    transform: scale(0.5) rotate(-90deg);
    pointer-events: none;
  }
  :global(.dark) .theme-icon-light {
    opacity: 1;
    transform: scale(1) rotate(0deg);
    pointer-events: auto;
  }

  /* ============================================= */
  /*  移动端抽屉                                    */
