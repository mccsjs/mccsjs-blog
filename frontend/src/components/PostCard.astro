---
import type { Post } from '../types';

interface Props {
  post: Post;
}

const { post } = Astro.props;

const formatDate = (date: string) =>
  new Date(date).toLocaleDateString('zh-CN', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
---

<article class="group flex flex-col overflow-hidden rounded-2xl border border-[rgb(var(--border)/0.4)] bg-white/60 shadow-sm backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-md dark:bg-white/5 dark:border-white/10">
  {
    post.coverImage && (
      <a href={`/posts/${post.slug}`} class="relative block overflow-hidden rounded-2xl">
        <img
          src={post.coverImage}
          alt={post.title}
          class="aspect-[16/10] w-full object-cover transition-transform duration-300 group-hover:scale-105"
        />
        <div class="dark:absolute dark:inset-0 dark:bg-gradient-to-b dark:from-black/10 dark:via-black/20 dark:to-black/40 dark:pointer-events-none"></div>
      </a>
    )
  }
  <div class="flex flex-1 flex-col p-4">
    <!-- 元信息：日期 + 阅读量 -->
    <div class="flex flex-wrap items-center gap-2 text-xs" style="color:rgb(var(--fg-soft))">
      <time datetime={post.createdAt}>{formatDate(post.createdAt)}</time>
      <span>·</span>
      <span>{post.views} 次阅读</span>
    </div>

    <h3 class="mt-3 text-lg font-bold leading-snug">
      <a href={`/posts/${post.slug}`} class="hover:text-[rgb(var(--primary))] transition-colors">
        {post.title}
      </a>
    </h3>

    <p class="mt-2 line-clamp-3 text-sm leading-relaxed text-[rgb(var(--fg-soft))]">
      {post.excerpt}
    </p>

    <!-- 分类 + 标签 -->
    <div class="mt-4 flex flex-wrap items-center gap-2 rounded-2xl bg-transparent p-0">
      <span class="rounded-full px-2.5 py-1 text-sm font-medium" style="background:rgb(var(--bg-soft));color:rgb(var(--fg))">
        {post.category.name}
      </span>
      {
        post.tags.map((tag) => (
          <span class="rounded-full border px-2.5 py-1 text-sm text-[rgb(var(--fg-soft))]" style="border-color:rgb(var(--border)/0.5)">
            #{tag.name}
          </span>
        ))
      }
    </div>
  </div>
</article>
