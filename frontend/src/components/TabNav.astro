---
interface TabItem {
  label: string;
  href: string;
}

interface Props {
  tabs: TabItem[];
}

const { tabs } = Astro.props;
const slug = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<nav id="tab-nav" class="tab-nav">
  <div id="tab-hover-border"></div>
  {tabs.map((tab) => {
    const tabPath = tab.href.replace(/\/$/, '') || '/';
    const isActive = slug === tabPath || (slug !== '/' && tabPath !== '/' && slug.startsWith(tabPath));
    return (
      <a
        href={tab.href}
        class={`tab-item${isActive ? ' active' : ''}`}
        role="tab"
        aria-selected={isActive ? 'true' : 'false'}
      >
        {tab.label}
      </a>
    );
  })}
</nav>

<style is:global>
  /* TabNav 全局样式已集中在 src/styles/global.css，避免 SWUP 切换后样式丢失 */
</style>

  <script is:inline>
  !(function() {
    var resizeObserver = null;
    var retryTimer = null;
    var retryCount = 0;
    var MAX_RETRIES = 8;

    // 批量读取布局属性，避免多次强制重排
    function positionBorder(item, hoverBorder) {
      requestAnimationFrame(function() {
        var w = item.offsetWidth;
        var l = item.offsetLeft;
        if (w > 0 && l >= 0) {
          hoverBorder.style.width = w + 'px';
          hoverBorder.style.left = l + 'px';
        }
      });
    }

    function initTabNav() {
      var tabNav = document.getElementById('tab-nav');
      var hoverBorder = document.getElementById('tab-hover-border');
      if (!tabNav || !hoverBorder) return;

      var tabItems = tabNav.querySelectorAll('.tab-item');
      if (!tabItems.length) return;

      // 清理旧监听器
      if (resizeObserver) {
        resizeObserver.disconnect();
        resizeObserver = null;
      }
      if (retryTimer) {
        clearTimeout(retryTimer);
        retryTimer = null;
      }
      retryCount = 0;

      tabItems.forEach(function(item) {
        if (item._tabMouseEnter) {
          item.removeEventListener('mouseenter', item._tabMouseEnter);
        }
      });

      function pos(item) {
        positionBorder(item, hoverBorder);
      }

      var active = tabNav.querySelector('.tab-item.active');
      if (active) {
        tabNav.classList.add('has-active');
        pos(active);

        // 如果元素有尺寸则立即再定位一次（字体/CSS 可能刚加载）
        if (active.offsetWidth > 0) {
          requestAnimationFrame(function() { pos(active); });
        }
      } else {
        tabNav.classList.remove('has-active');
      }

      tabItems.forEach(function(item) {
        item._tabMouseEnter = function() { pos(item); };
        item.addEventListener('mouseenter', item._tabMouseEnter);
      });

      // 移除旧的 mouseleave 监听（防止重复绑定）
      if (tabNav._tabMouseLeave) {
        tabNav.removeEventListener('mouseleave', tabNav._tabMouseLeave);
      }
      tabNav._tabMouseLeave = function() {
        var activeItem = tabNav.querySelector('.tab-item.active');
        if (activeItem) pos(activeItem);
      };
      tabNav.addEventListener('mouseleave', tabNav._tabMouseLeave);

      // ResizeObserver：窗口大小变化或字体加载后自动重新定位
      if (typeof ResizeObserver !== 'undefined') {
        resizeObserver = new ResizeObserver(function() {
          var curActive = tabNav.querySelector('.tab-item.active');
          if (curActive && curActive.offsetWidth > 0) pos(curActive);
        });
        resizeObserver.observe(tabNav);
      }

      // 多次延迟重试：处理 swup 切页后布局未稳定 / 字体异步加载等场景
      function scheduleRetry(delay) {
        if (retryCount >= MAX_RETRIES) return;
        retryTimer = setTimeout(function() {
          retryCount++;
          var cur = document.getElementById('tab-nav');
          var hb = document.getElementById('tab-hover-border');
          if (!cur || !hb) return;
          var curActive = cur.querySelector('.tab-item.active');
          if (curActive && curActive.offsetWidth > 0) {
            pos(curActive);
            // 连续两次成功就停止重试
            if (retryCount >= 2) return;
            scheduleRetry(Math.min(delay * 1.5, 400));
          } else if (curActive) {
            // 元素存在但尺寸仍为 0（字体/CSS 未就绪），继续等待
            scheduleRetry(Math.min(delay * 1.5, 400));
          }
        }, delay);
      }

      if (active && active.offsetWidth === 0) {
        scheduleRetry(50);
      } else if (active) {
        // 有尺寸但也延迟一次确认（应对 async font）
        retryTimer = setTimeout(function() {
          var cur = document.getElementById('tab-nav');
          if (cur) {
            var ca = cur.querySelector('.tab-item.active');
            if (ca && ca.offsetWidth > 0) pos(ca);
          }
        }, 150);
      }
    }

    function safeInit() {
      // 先立即尝试一次
      initTabNav();
      // 再等字体就绪后尝试（自定义字体会改变布局尺寸）
      if (document.fonts && document.fonts.ready) {
        document.fonts.ready.then(function() { initTabNav(); });
      }
    }

    // 首次初始化
    safeInit();

    // swup 切页后的重初始化（核心修复点）
    function handleSwupEnd() {
      // 用多重 rAF 确保 DOM 已完成布局
      requestAnimationFrame(function() {
        requestAnimationFrame(function() {
          safeInit();
        });
      });
    }

    function hookTabNav() {
      if (!window.swup || !window.swup.hooks) return;
      if (window.__tabNavSwupHook && window.__tabNavSwupHook === window.swup) return;
      window.swup.hooks.on('visit:end', handleSwupEnd);
      window.swup.hooks.on('page:view', handleSwupEnd);
      window.__tabNavSwupHook = window.swup;
    }
    hookTabNav();
    if (!window.swup || !window.swup.hooks) {
      var tabTimer = setInterval(function () {
        if (window.swup && window.swup.hooks) {
          clearInterval(tabTimer);
          hookTabNav();
        }
      }, 50);
    }

    // Astro View Transitions 兼容
    document.addEventListener('astro:page-load', handleSwupEnd);

    // 暴露给 base-layout.js 调用（统一入口）
    window.__initTabNav = safeInit;

    // 监听 base-layout.js 发出的自定义事件（最终安全网）
    document.addEventListener('swup:page-view', function() {
      requestAnimationFrame(function() {
        requestAnimationFrame(function() {
          safeInit();
        });
      });
    });
  })();
</script>
