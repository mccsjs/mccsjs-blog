---
interface TabItem {
  label: string;
  href: string;
}

interface Props {
  tabs: TabItem[];
}

const { tabs } = Astro.props;
const slug = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<nav id="tab-nav" class="tab-nav">
  <div id="tab-hover-border"></div>
  {tabs.map((tab) => {
    const tabPath = tab.href.replace(/\/$/, '') || '/';
    const isActive = slug === tabPath || (slug !== '/' && tabPath !== '/' && slug.startsWith(tabPath));
    return (
      <a
        href={tab.href}
        class={`tab-item${isActive ? ' active' : ''}`}
        role="tab"
        aria-selected={isActive ? 'true' : 'false'}
      >
        {tab.label}
      </a>
    );
  })}
</nav>

<style is:global>
  /* TabNav 全局样式已集中在 src/styles/global.css，避免 SWUP 切换后样式丢失 */
</style>

  <script is:inline>
  !(function() {
    var MIN_W = 20; /* 宽度小于此视为布局未就绪，不写入 */
    var ro = null;
    var retryTimer = null;
    var boundMouseEnter = null;
    var boundMouseLeave = null;
    /* 标记已初始化的 nav 元素，避免同一元素重复初始化 */
    var lastNav = null;

    /* 立即同步定位（不套 rAF），通过外部调度合并来防抖 */
    function setPosition(item, border) {
      if (!item || !border || !border.parentElement) return;
      var w = item.offsetWidth;
      var l = item.offsetLeft;
      if (w < MIN_W || l < 0) return;
      border.style.width = w + 'px';
      border.style.left = l + 'px';
    }

    /* 合并调度：同一帧内只执行最后一次 */
    var scheduledRaf = null;
    function pos(item, border) {
      if (scheduledRaf) cancelAnimationFrame(scheduledRaf);
      scheduledRaf = requestAnimationFrame(function() {
        scheduledRaf = null;
        setPosition(item, border);
      });
    }

    function initTabNav() {
      var tabNav = document.getElementById('tab-nav');
      var hoverBorder = document.getElementById('tab-hover-border');
      if (!tabNav || !hoverBorder) return;

      /* 同一 nav 不重复初始化（除非 swup 替换了整个 DOM） */
      if (tabNav === lastNav && tabNav.querySelector('.tab-item')) return;
      lastNav = tabNav;

      var tabItems = tabNav.querySelectorAll('.tab-item');
      if (!tabItems.length) return;

      /* 清理旧监听 */
      if (ro) { ro.disconnect(); ro = null; }
      if (retryTimer) { clearTimeout(retryTimer); retryTimer = null; }
      if (boundMouseEnter) {
        tabItems.forEach(function(it) {
          it.removeEventListener('mouseenter', boundMouseEnter);
        });
      }
      if (boundMouseLeave && lastNav) {
        lastNav.removeEventListener('mouseleave', boundMouseLeave);
      }

      var active = tabNav.querySelector('.tab-item.active');
      if (active) {
        tabNav.classList.add('has-active');
        /* 同步写入 + 延迟确认 */
        setPosition(active, hoverBorder);
        pos(active, hoverBorder);
      } else {
        tabNav.classList.remove('has-active');
        hoverBorder.style.width = '';
        hoverBorder.style.left = '';
      }

      /* mouseenter / mouseleave（整个生命周期只绑定一次函数引用） */
      boundMouseEnter = function() { pos(this, hoverBorder); };
      tabItems.forEach(function(item) {
        item.addEventListener('mouseenter', boundMouseEnter);
      });

      boundMouseLeave = function() {
        var a = tabNav.querySelector('.tab-item.active');
        if (a) pos(a, hoverBorder);
      };
      tabNav.addEventListener('mouseleave', boundMouseLeave);

      /* ResizeObserver */
      if (typeof ResizeObserver !== 'undefined') {
        ro = new ResizeObserver(function() {
          var a = tabNav.querySelector('.tab-item.active');
          if (a && a.offsetWidth >= MIN_W) pos(a, hoverBorder);
        });
        ro.observe(tabNav);
      }

      /* 重试机制：仅当 active 尚无有效尺寸时启动 */
      if (active && active.offsetWidth < MIN_W) {
        (function tryAgain(delay, count) {
          if (count > 10) return;
          retryTimer = setTimeout(function() {
            var n = document.getElementById('tab-nav');
            var b = document.getElementById('tab-hover-border');
            if (!n || !b) return;
            var a = n.querySelector('.tab-item.active');
            if (a && a.offsetWidth >= MIN_W) {
              setPosition(a, b);
            } else if (a) {
              tryAgain(Math.min(delay * 1.5, 500), count + 1);
            }
          }, delay);
        })(60, 0);
      }
    }

    function safeInit() {
      initTabNav();
      if (document.fonts && document.fonts.ready) {
        document.fonts.ready.then(initTabNav);
      }
    }

    /* ===== 入口点（精简为三处） ===== */

    /* 1) 首次加载 */
    safeInit();

    /* 2) 统一 swup 切页处理（去重：只注册一次） */
    function onPageSwitch() {
      lastNav = null; /* 允许重新初始化（swup 已替换 DOM） */
      requestAnimationFrame(function() {
        requestAnimationFrame(safeInit);
      });
    }
    window.__initTabNav = safeInit;
    window.__refreshTabNav = onPageSwitch;

    (function hookSwup() {
      if (window.swup && window.swup.hooks) {
        window.swup.hooks.on('page:view', onPageSwitch);
        /* visit:end 太早（动画可能还在跑），只用 page:view */
      } else {
        var timer = setInterval(function() {
          if (window.swup && window.swup.hooks) {
            clearInterval(timer);
            window.swup.hooks.on('page:view', onPageSwitch);
          }
        }, 80);
      }
    })();

    /* 3) Astro View Transitions 兼容 */
    document.addEventListener('astro:page-load', function() {
      lastNav = null;
      requestAnimationFrame(function() {
        requestAnimationFrame(safeInit);
      });
    });
  })();
</script>
