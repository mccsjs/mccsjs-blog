---
interface TabItem {
  label: string;
  href: string;
}

interface Props {
  tabs: TabItem[];
}

const { tabs } = Astro.props;
const slug = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<nav id="tab-nav" class="tab-nav">
  <div id="tab-hover-border"></div>
  {tabs.map((tab) => {
    const tabPath = tab.href.replace(/\/$/, '') || '/';
    const isActive = slug === tabPath || (slug !== '/' && tabPath !== '/' && slug.startsWith(tabPath));
    return (
      <a
        href={tab.href}
        class={`tab-item${isActive ? ' active' : ''}`}
        role="tab"
        aria-selected={isActive ? 'true' : 'false'}
      >
        {tab.label}
      </a>
    );
  })}
</nav>

<style is:global>
  /* 样式已迁移到 src/styles/global.css */
</style>

  <script is:inline>
  // TabNav 滑动边框初始化已移至 base-layout.js（Swup page:view 钩子统一调用）
  // 此处保留为首次加载的兜底，避免 base-layout.js 未加载时无样式
    !(function() {
      function tryInit() {
        var nav = document.getElementById('tab-nav');
        var border = document.getElementById('tab-hover-border');
        if (!nav || !border) return;
        var active = nav.querySelector('.tab-item.active');
        if (!active) { nav.classList.remove('has-active'); return; }
        nav.classList.add('has-active');
        border.style.width = active.offsetWidth + 'px';
        border.style.left = active.offsetLeft + 'px';
      }
      function go() {
        if (document.fonts && document.fonts.ready) {
          document.fonts.ready.then(tryInit);
        } else {
          tryInit();
        }
      }
      // 首次立即尝试
      go();
      // 字体/图片等资源加载后重试
      setTimeout(go, 200);
      document.addEventListener('swup:page-view', go);
      document.addEventListener('astro:page-load', go);
    })();
  </script>
