---
interface TabItem {
  label: string;
  href: string;
}

interface Props {
  tabs: TabItem[];
}

const { tabs } = Astro.props;
const slug = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<nav id="tab-nav" class="tab-nav">
  <div id="tab-hover-border"></div>
  {tabs.map((tab) => {
    const tabPath = tab.href.replace(/\/$/, '') || '/';
    const isActive = slug === tabPath || (slug !== '/' && tabPath !== '/' && slug.startsWith(tabPath));
    return (
      <a
        href={tab.href}
        class={`tab-item${isActive ? ' active' : ''}`}
        role="tab"
        aria-selected={isActive ? 'true' : 'false'}
      >
        {tab.label}
      </a>
    );
  })}
</nav>

<style is:global>
  /* TabNav 全局样式已集中在 src/styles/global.css，避免 SWUP 切换后样式丢失 */
</style>

  <script is:inline>
  !(function() {
    var MIN_W = 20; /* 宽度小于此视为布局未就绪 */
    var ro = null;
    var retryTimer = null;
    var boundMouseEnter = null;
    var boundMouseLeave = null;
    var lastNav = null;
    var scheduledRaf = null;

    /* 核心定位：同步写入 + 值校验 + 成功后显式显示 */
    function setPosition(item, border, nav) {
      if (!item || !border || !border.parentElement) return false;
      var w = item.offsetWidth;
      var l = item.offsetLeft;
      if (w < MIN_W || l < 0) return false;
      border.style.width = w + 'px';
      border.style.left = l + 'px';
      /* 定位成功 → 显示边框 */
      nav.classList.add('has-active');
      return true;
    }

    /* 防抖调度（同一帧合并） */
    function pos(item, border, nav) {
      if (scheduledRaf) cancelAnimationFrame(scheduledRaf);
      scheduledRaf = requestAnimationFrame(function() {
        scheduledRaf = null;
        setPosition(item, border, nav);
      });
    }

    function initTabNav() {
      var tabNav = document.getElementById('tab-nav');
      var hoverBorder = document.getElementById('tab-hover-border');
      if (!tabNav || !hoverBorder) return;

      if (tabNav === lastNav && tabNav.querySelector('.tab-item')) return;
      lastNav = tabNav;

      var tabItems = tabNav.querySelectorAll('.tab-item');
      if (!tabItems.length) return;

      /* ===== 先重置为隐藏状态（关键！）===== */
      tabNav.classList.remove('has-active');
      hoverBorder.style.width = '';
      hoverBorder.style.left = '';

      /* 清理旧监听 */
      if (ro) { ro.disconnect(); ro = null; }
      if (retryTimer) { clearTimeout(retryTimer); retryTimer = null; }
      if (boundMouseEnter) {
        /* 需要从旧 nav 上解绑（lastNav 在上面已被覆盖，用当前 tabNav） */
        /* 但此时旧元素可能已不在 DOM 中，直接 forEach 新的就行 */
      }
      var oldNav = document.querySelector('#tab-nav');
      if (boundMouseLeave && oldNav && oldNav !== tabNav) {
        oldNav.removeEventListener('mouseleave', boundMouseLeave);
      }
      if (boundMouseEnter) {
        /* 尝试从任何残留的 tab-item 上清理 */
        document.querySelectorAll('.tab-item').forEach(function(it) {
          it.removeEventListener('mouseenter', boundMouseEnter);
        });
      }

      var active = tabNav.querySelector('.tab-item.active');

      if (active) {
        /* 尝试同步定位 → 成功则 has-active 已被 setPosition 加上 */
        var ok = setPosition(active, hoverBorder, tabNav);
        if (!ok) {
          /* 同步失败 → 调度 rAF 重试 + setTimeout 兜底 */
          pos(active, hoverBorder, tabNav);

          /* 启动重试定时器：布局稳定后再试 */
          (function tryAgain(delay, count) {
            if (count > 12) return;
            retryTimer = setTimeout(function() {
              var n = document.getElementById('tab-nav');
              var b = document.getElementById('tab-hover-border');
              if (!n || !b) return;
              var a = n.querySelector('.tab-item.active');
              if (a && a.offsetWidth >= MIN_W) {
                setPosition(a, b, n);
              } else if (a) {
                tryAgain(Math.min(delay * 1.6, 500), count + 1);
              }
            }, delay);
          })(50, 0);
        } else {
          /* 同步成功也延迟一帧确认（字体可能异步加载改变尺寸） */
          pos(active, hoverBorder, tabNav);
        }
      }
      /* 无 active 项时保持 hidden（已在上面的 reset 中处理） */

      /* 绑定交互事件 */
      boundMouseEnter = function() { pos(this, hoverBorder, tabNav); };
      tabItems.forEach(function(item) {
        item.addEventListener('mouseenter', boundMouseEnter);
      });

      boundMouseLeave = function() {
        var a = tabNav.querySelector('.tab-item.active');
        if (a) pos(a, hoverBorder, tabNav);
      };
      tabNav.addEventListener('mouseleave', boundMouseLeave);

      /* ResizeObserver */
      if (typeof ResizeObserver !== 'undefined') {
        ro = new ResizeObserver(function() {
          var a = tabNav.querySelector('.tab-item.active');
          if (a && a.offsetWidth >= MIN_W) setPosition(a, hoverBorder, tabNav);
        });
        ro.observe(tabNav);
      }
    }

    function safeInit() {
      initTabNav();
      if (document.fonts && document.fonts.ready) {
        document.fonts.ready.then(initTabNav);
      }
    }

    /* ===== 入口点 ===== */

    /* 1) 首次加载 */
    safeInit();

    /* 2) swup 切页 */
    function onPageSwitch() {
      lastNav = null;
      requestAnimationFrame(function() {
        requestAnimationFrame(safeInit);
      });
    }
    window.__initTabNav = safeInit;
    window.__refreshTabNav = onPageSwitch;

    (function hookSwup() {
      if (window.swup && window.swup.hooks) {
        window.swup.hooks.on('page:view', onPageSwitch);
      } else {
        var timer = setInterval(function() {
          if (window.swup && window.swup.hooks) {
            clearInterval(timer);
            window.swup.hooks.on('page:view', onPageSwitch);
          }
        }, 80);
      }
    })();

    /* 3) Astro View Transitions */
    document.addEventListener('astro:page-load', function() {
      lastNav = null;
      requestAnimationFrame(function() {
        requestAnimationFrame(safeInit);
      });
    });
  })();
</script>
