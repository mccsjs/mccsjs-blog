---
interface TabItem {
  label: string;
  href: string;
}

interface Props {
  tabs: TabItem[];
}

const { tabs } = Astro.props;
const slug = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<nav id="tab-nav" class="tab-nav">
  <div id="tab-hover-border"></div>
  {tabs.map((tab) => {
    const tabPath = tab.href.replace(/\/$/, '') || '/';
    const isActive = slug === tabPath || (slug !== '/' && tabPath !== '/' && slug.startsWith(tabPath));
    return (
      <a
        href={tab.href}
        class={`tab-item${isActive ? ' active' : ''}`}
        role="tab"
        aria-selected={isActive ? 'true' : 'false'}
      >
        {tab.label}
      </a>
    );
  })}
</nav>

<style is:global>
  /* TabNav 全局样式已集中在 src/styles/components.css，避免 SWUP 切换后样式丢失 */
</style>

<script is:inline>
!(function() {
  /* ===== 第四版：极简实现 =====
   * 去掉所有防护/调度/重试/rAF/ResizeObserver/引用守卫
   * 目的：排除过度工程化导致的 bug
   * 如果这版能工作 → 说明之前是自作聪明搞坏了
   * 如果还不行 → 问题在 CSS 层面或 DOM 结构，不是 JS 时序问题
   */

  function init() {
    var nav = document.getElementById('tab-nav');
    var border = document.getElementById('tab-hover-border');
    if (!nav || !border) return;

    var items = nav.querySelectorAll('.tab-item');
    if (!items.length) return;

    /* 解绑旧事件 */
    if (init._bound) {
      items.forEach(function(it) { it.removeEventListener('mouseenter', init._bound); });
      nav.removeEventListener('mouseleave', init._leave);
    }

    var active = nav.querySelector('.tab-item.active');

    if (active) {
      /* 直接同步写值，零防护 */
      border.style.width = active.offsetWidth + 'px';
      border.style.left = active.offsetLeft + 'px';
      nav.classList.add('has-active');
    } else {
      nav.classList.remove('has-active');
      border.style.width = '';
      border.style.left = '';
    }

    /* hover 跟随 */
    init._bound = function(e) {
      var t = e.currentTarget;
      border.style.width = t.offsetWidth + 'px';
      border.style.left = t.offsetLeft + 'px';
    };
    items.forEach(function(it) { it.addEventListener('mouseenter', init._bound); });

    /* leave 回弹 */
    init._leave = function() {
      var a = nav.querySelector('.tab-item.active');
      if (a) {
        border.style.width = a.offsetWidth + 'px';
        border.style.left = a.offsetLeft + 'px';
      }
    };
    nav.addEventListener('mouseleave', init._leave);

    /* 字体就绪后修正一次（自定义字体会改变文字宽度） */
    if (document.fonts && document.fonts.ready) {
      document.fonts.ready.then(function() {
        var n = document.getElementById('tab-nav');
        var b = document.getElementById('tab-hover-border');
        if (!n || !b) return;
        var a = n.querySelector('.tab-item.active');
        if (a) {
          b.style.width = a.offsetWidth + 'px';
          b.style.left = a.offsetLeft + 'px';
        }
      });
    }
  }

  /* 首次加载 */
  init();

  window.__initTabNav = init;
  window.__refreshTabNav = init;

  /* swup 切页后重新执行 */
  (function hookSwup() {
    function onSwitch() { init(); }
    if (window.swup && window.swup.hooks) {
      window.swup.hooks.on('page:view', onSwitch);
    } else {
      var t = setInterval(function() {
        if (window.swup && window.swup.hooks) {
          clearInterval(t);
          window.swup.hooks.on('page:view', onSwitch);
        }
      }, 100);
    }
  })();

  document.addEventListener('astro:page-load', init);
})();
</script>
