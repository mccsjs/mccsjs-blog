---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import FloatingBar from '../components/FloatingBar.astro';
import type { SiteSettings, MenuItem } from '../types';

const API_URL = 'http://localhost:4000';

interface Props {
  title?: string;
  description?: string;
  wide?: boolean;
  postSlug?: string;
  postCategory?: string;
}

const { title: rawTitle, description: rawDescription, wide = false, postSlug, postCategory } = Astro.props;
const isHome = Astro.url.pathname === '/';

const defaultSettings: SiteSettings = {
  siteTitle: 'My Blog',
  siteDescription: '一个使用 Astro + React + Tailwind CSS 构建的现代博客',
  siteLogo: '',
  favicon: '',
  icp: '',
  footerText: '',
  postsPerPage: '10',
  twikooEnvId: '',
  fontCssUrl: '',
  fontFamily: '',
  backgroundImage: '',
};

let settings: SiteSettings = defaultSettings;
try {
  const res = await fetch(`${API_URL}/api/settings`);
  if (res.ok) {
    settings = { ...defaultSettings, ...(await res.json()) };
  }
} catch {
  // 网络异常时使用默认设置
}

const pageTitle = rawTitle ? rawTitle.replace(/\s*\|\s*My Blog\s*$/, '').trim() : '';
const title = pageTitle ? `${pageTitle} | ${settings.siteTitle}` : settings.siteTitle;
const description = rawDescription || settings.siteDescription;

async function fetchMenus(type: string): Promise<MenuItem[]> {
  try {
    const res = await fetch(`${API_URL}/api/menus?type=${type}`);
    if (res.ok) return await res.json();
  } catch {
    // ignore
  }
  return [];
}

const navMenus = await fetchMenus('NAV');
const footerMenus = await fetchMenus('FOOTER');
const aggregateMenus = await fetchMenus('GROUP');

const fontUrl = settings.fontCssUrl?.trim() ?? '';
const fontFamily = settings.fontFamily?.trim() ?? '';
const fontExtMatch = fontUrl.match(/\.(woff2|woff|ttf|otf|eot)(\?.*)?$/i);
const isFontFile = !!fontExtMatch;
const fontFormat = fontExtMatch ? fontExtMatch[1].toLowerCase() : '';
const fontMimeType: Record<string, string> = {
  woff2: 'font/woff2',
  woff: 'font/woff',
  ttf: 'font/ttf',
  otf: 'font/otf',
  eot: 'application/vnd.ms-fontobject',
};
const effectiveFontFamily = fontFamily
  ? `'${fontFamily.replace(/'/g, "\\'")}'`
  : fontUrl
    ? "'CustomFont'"
    : '';
---
<html lang="zh-CN" style="color-scheme: light dark;">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="sitemap" href="/sitemap.xml" />
    <link rel="alternate" type="application/rss+xml" title="RSS" href="/rss.xml" />
    <link rel="alternate" type="application/atom+xml" title="Atom" href="/atom.xml" />
    <title>{title}</title>
    <script is:inline>
      (function () {
        const STORAGE_KEY = 'theme';
        const systemDark = window.matchMedia('(prefers-color-scheme: dark)');
        const saved = localStorage.getItem(STORAGE_KEY);
        const isDark = saved === 'dark' || (!saved && systemDark.matches);
        document.documentElement.classList.toggle('dark', isDark);
      })();
    </script>
    {settings.favicon && <link rel="icon" href={settings.favicon} />}
    {fontUrl && isFontFile && (
      <>
        <link rel="preload" href={fontUrl} as="font" type={fontMimeType[fontFormat]} crossorigin />
        <style set:html={`
          @font-face {
            font-family: ${effectiveFontFamily};
            src: url('${fontUrl}') format('${fontFormat}');
            font-weight: 100 900;
            font-style: normal;
            font-display: swap;
          }
        `} />
      </>
    )}
    {fontUrl && !isFontFile && <link rel="stylesheet" href={fontUrl} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body
    class="flex min-h-screen flex-col antialiased"
    style={
      isHome && settings.backgroundImage
        ? `background-image: url('${settings.backgroundImage}'); background-size: cover; background-position: center; background-attachment: fixed; font-family: ${effectiveFontFamily || 'inherit'};`
        : effectiveFontFamily
          ? `font-family: ${effectiveFontFamily};`
          : undefined
    }
  >
    {isHome && settings.backgroundImage && (
      <div class="fixed inset-0 bg-black/30 -z-10 md:hidden"></div>
    )}
    <div class="relative z-10 flex min-h-screen flex-col">
      <Header siteTitle={settings.siteTitle} siteLogo={settings.siteLogo} favicon={settings.favicon} menus={navMenus} aggregateMenus={aggregateMenus} />
      <main id="swup-container" class="transition-swup-main mx-auto w-full flex-1 px-4 pt-24 pb-12 md:pt-28 md:px-6 md:pb-16 overflow-x-clip" class:list={["max-w-5xl", wide && "max-w-6xl"]}>
        <Breadcrumb title={pageTitle} postSlug={postSlug} postCategory={postCategory} />
        <slot />
      </main>
      <Footer
        siteTitle={settings.siteTitle}
        icp={settings.icp}
        footerText={settings.footerText}
        menus={footerMenus}
      />
    </div>
    <FloatingBar />
    <div id="progress-bar"></div>

    <script is:inline>
      (function() {
        let progressTimeout1 = null;
        let progressTimeout2 = null;
        let transitionTimeout = null;

        function clearAllTransitionTimeouts() {
          if (progressTimeout1) { clearTimeout(progressTimeout1); progressTimeout1 = null; }
          if (progressTimeout2) { clearTimeout(progressTimeout2); progressTimeout2 = null; }
          if (transitionTimeout) { clearTimeout(transitionTimeout); transitionTimeout = null; }
        }

        // 文章表格横向滚动包裹
        function wrapTables() {
          document.querySelectorAll('.post-content table').forEach((table) => {
            if (table.parentElement?.classList.contains('post-table-wrap')) return;
            const wrap = document.createElement('div');
            wrap.className = 'post-table-wrap';
            table.parentElement?.insertBefore(wrap, table);
            wrap.appendChild(table);
          });
        }

        function setup() {
          if (!window.swup || !window.swup.hooks) return;

          window.swup.hooks.on('link:click', function() {
            document.documentElement.classList.add('is-page-transitioning');
          });

          window.swup.hooks.on('visit:start', function() {
            clearAllTransitionTimeouts();
            document.documentElement.classList.add('is-page-transitioning');
            var progressBar = document.getElementById('progress-bar');
            if (progressBar) {
              progressBar.classList.remove('finishing', 'done');
              void progressBar.offsetWidth;
              progressBar.classList.add('loading');
            }
            window.scrollTo({ top: 0, behavior: 'auto' });
            var topRow = document.getElementById('nav-top-row');
            if (topRow) topRow.classList.remove('scrolled');
          });

          window.swup.hooks.on('visit:end', function() {
            var progressBar = document.getElementById('progress-bar');
            if (progressBar) {
              progressBar.classList.remove('loading');
              progressBar.classList.add('finishing');
              progressTimeout1 = setTimeout(function() {
                progressBar.classList.remove('finishing');
                progressBar.classList.add('done');
                progressTimeout2 = setTimeout(function() { progressBar.classList.remove('done'); }, 300);
              }, 200);
            }
            transitionTimeout = setTimeout(function() {
              document.documentElement.classList.remove('is-page-transitioning');
            }, 400);
          });

          window.swup.hooks.on('page:view', function() {
            wrapTables();
            document.dispatchEvent(new CustomEvent('swup:page-view'));
          });
        }

        function resetScrollAndNav() {
          window.scrollTo(0, 0);
          var nav = document.getElementById('nav-top-row');
          if (nav) nav.classList.remove('scrolled');
        }

        // 首次执行
        wrapTables();

        if (window.swup && window.swup.hooks) {
          setup();
        } else {
          document.addEventListener('swup:enable', setup);
        }

        document.addEventListener('astro:page-load', function() {
          resetScrollAndNav();
          wrapTables();
        });
      })();
    </script>
  </body>
</html>
