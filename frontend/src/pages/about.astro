---
import BaseLayout from '../layouts/BaseLayout.astro';

const API_URL = 'http://localhost:4000';
const ESTABLISHED_DATE = new Date('2024-01-01');
const RUNNING_DAYS = Math.floor((Date.now() - ESTABLISHED_DATE.getTime()) / 86400000);

let postCount = 0;
try {
  const res = await fetch(`${API_URL}/api/posts`);
  if (res.ok) {
    const posts = await res.json();
    postCount = Array.isArray(posts) ? posts.length : posts.total || 0;
  }
} catch {}
---

<BaseLayout title="关于 | mccsjs" wide>
  <section class="mb-10 text-center">
    <h1 class="text-3xl font-extrabold tracking-tight sm:text-4xl">关于</h1>
    <p class="mt-3 text-gray-600 dark:text-gray-400">了解更多关于我的信息</p>
  </section>

  <div class="about-grid">
    <!-- 联系方式 -->
    <div class="about-card about-card--socialize">
      <div class="about-card__tips">账号</div>
      <div class="about-card__title">联系方式</div>
      <div class="about-card__tags">
        <a href="https://github.com/mccsjs" target="_blank" rel="noopener noreferrer" class="about-btn">GitHub</a>
        <a href="mailto:me@seln.cn" class="about-btn">Email</a>
        <a href="/link" class="about-btn">友链</a>
      </div>
    </div>

    <!-- 创作平台 -->
    <div class="about-card about-card--creation">
      <div class="about-card__tips">订阅</div>
      <div class="about-card__title">创作平台</div>
      <div class="about-card__tags">
        <a href="/rss.xml" target="_blank" class="about-btn">RSS</a>
        <a href="/atom.xml" target="_blank" class="about-btn">Atom</a>
      </div>
    </div>

    <!-- 本站信息 -->
    <div class="about-card about-card--site-info">
      <div class="about-card__inner-top">
        <span class="about-card__bg-text">Blog</span>
        <div class="about-card__big-title">本站信息</div>
      </div>
      <div class="about-card__running">已稳定运行 {RUNNING_DAYS} 天 🚀</div>
    </div>

    <!-- 版本与统计 -->
    <div class="about-card-group">
      <div class="about-card about-card--versions">
        <div class="about-version-item">
          <div class="about-version-name">Astro</div>
          <div class="about-version-ver">v7.x</div>
        </div>
        <div class="about-version-item">
          <div class="about-version-name">React</div>
          <div class="about-version-ver">v19</div>
        </div>
        <div class="about-version-name">Tailwind</div>
        <div class="about-version-ver">v4</div>
      </div>
      <div class="about-card about-card--stats-inline">
        <span>{postCount} 篇文章</span>
        <span>个人博客</span>
        <span>轻量简洁</span>
      </div>
    </div>

    <!-- 访问统计（深色卡片） -->
    <div class="about-card about-card--stats">
      <div class="about-stats__glow"></div>
      <div class="about-card__tips about-stats__tips">浏览</div>
      <div class="about-card__title about-stats__title">访问统计</div>
      <div class="about-stats__grid">
        <div class="about-stat-item">
          <span class="about-stat-label">今日访客</span>
          <span class="about-stat-num" id="stat-today-visitors">—</span>
        </div>
        <div class="about-stat-item">
          <span class="about-stat-label">今日访问</span>
          <span class="about-stat-num" id="stat-today-pv">—</span>
        </div>
        <div class="about-stat-item">
          <span class="about-stat-label">昨日访客</span>
          <span class="about-stat-num" id="stat-yesterday-visitors">—</span>
        </div>
        <div class="about-stat-item">
          <span class="about-stat-label">昨日访问</span>
          <span class="about-stat-num" id="stat-yesterday-pv">—</span>
        </div>
        <div class="about-stat-item">
          <span class="about-stat-label">本月访问</span>
          <span class="about-stat-num" id="stat-month-pv">—</span>
        </div>
      </div>
    </div>

    <!-- 游戏卡片 -->
    <div class="game-cards">
      <div class="game-card game-card--genshin">
        <div class="game-card__content">
          <div class="game-card__tips">爱好游戏</div>
          <div class="game-card__title">原神</div>
          <div class="game-card__bottom">
            <span class="game-card__uid">UID: 109468770</span>
          </div>
        </div>
      </div>
      <div class="game-card game-card--starrail">
        <div class="game-card__content">
          <div class="game-card__tips">常玩</div>
          <div class="game-card__title">星穹铁道</div>
          <div class="game-card__bottom">
            <span class="game-card__uid">UID: 101786049</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style is:global>
  /* ======================== About Page ======================== */
  .about-grid {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* 通用卡片 */
  .about-card {
    border-radius: 12px;
    padding: 1rem 2rem;
    position: relative;
    overflow: hidden;
    border: 1px solid oklch(0 0 0 / 0.06);
    background: oklch(1 0 0);
    box-shadow: 0 1px 3px oklch(0 0 0 / 0.04);
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .about-card:hover {
    transform: translateY(-2px);
    border-color: oklch(0.12 0.15 60);
    box-shadow: 0 8px 24px -4px oklch(0 0 0 / 0.08);
  }
  .dark .about-card:not(.about-card--stats):not(.game-card) {
    background: oklch(0.17 0.01 240);
    border-color: oklch(1 0 0 / 0.06);
  }
  .dark .about-card:not(.about-card--stats):not(.game-card):hover {
    border-color: oklch(0.25 0.1 55);
    box-shadow: 0 8px 24px -4px oklch(0 0 0 / 0.25);
  }

  /* 卡片内部文字 */
  .about-card__tips {
    opacity: 0.7;
    font-size: 0.75rem;
    line-height: 1.2;
    margin-bottom: 0.75rem;
    color: oklch(0.45 0 0);
  }
  .dark .about-card__tips { color: oklch(0.65 0 0); }

  .about-card__title {
    font-size: 2.25rem;
    font-weight: 700;
    line-height: 1.2;
    color: oklch(0.22 0 0);
  }
  .dark .about-card__title { color: oklch(0.9 0 0); }

  /* 按钮标签 */
  .about-btn {
    display: inline-block;
    padding: 6px 18px;
    margin: 0 18px 18px 0;
    color: oklch(0.35 0 0);
    text-decoration: none;
    border-radius: 9999px;
    border: 1px solid oklch(0 0 0 / 0.08);
    transition: all 0.2s ease;
    font-size: 14px;
  }
  .about-btn:hover {
    background: oklch(0.75 0.08 60);
    color: #fff;
    border-color: transparent;
  }
  .dark .about-btn {
    color: oklch(0.7 0 0);
    border-color: oklch(1 0 0 / 0.1);
  }
  .dark .about-btn:hover {
    background: oklch(0.45 0.12 55);
    color: #fff;
  }

  .about-card__tags {
    display: flex;
    flex-wrap: wrap;
    margin-top: 1.5rem;
  }

  /* ====== 联系方式 & 创作平台 横排 ====== */
  .about-card--socialize,
  .about-card--creation {
    padding: 2.25rem 2rem;
  }

  @media (min-width: 769px) {
    .about-row-2col {
      display: flex;
      gap: 16px;
    }
    .about-card--socialize { width: 40%; flex-shrink: 0; }
    .about-card--creation { width: 60%; flex: 1; min-width: 0; }
  }

  /* ====== 本站信息 ====== */
  .about-card--site-info {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 220px;
  }
  .about-card__inner-top {
    position: relative;
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .about-card__bg-text {
    position: absolute;
    top: 0;
    left: -48px;
    font-size: 80px;
    font-weight: 900;
    opacity: 0.3;
    letter-spacing: 0.05em;
    color: oklch(0.85 0.03 80);
    user-select: none;
  }
  .dark .about-card__bg-text { color: oklch(0.3 0 250); opacity: 0.15; }
  .about-card__big-title {
    font-size: 42px;
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: 0.2rem;
    color: oklch(0.22 0 0);
  }
  .dark .about-card__big-title { color: oklch(0.9 0 0); }
  .about-card__running {
    padding: 1.25rem 2rem;
    display: inline-flex;
    justify-content: center;
    font-size: 18px;
    font-weight: 600;
    color: oklch(0.35 0 0);
  }
  .dark .about-card__running { color: oklch(0.7 0 0); }

  /* 本站信息 + 版本统计 横排 */
  @media (min-width: 769px) {
    .about-site-row {
      display: flex;
      gap: 16px;
    }
    .about-card--site-info {
      width: 50%;
      aspect-ratio: 1 / 1;
      max-height: 360px;
      margin-right: 16px;
      flex-shrink: 0;
    }
  }

  .about-card-group {
    display: contents;
  }
  @media (min-width: 769px) {
    .about-site-inner {
      display: flex !important;
      flex-direction: column;
      width: 50%;
      gap: 16px;
    }
  }

  /* 版本号 */
  .about-card--versions {
    display: flex;
    align-items: center;
    justify-content: space-around;
    padding: 1.5rem 2rem;
    flex: 1;
    margin-bottom: 16px;
  }
  .about-version-item {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .about-version-name {
    font-size: 1.125rem;
    font-weight: 700;
    color: oklch(0.28 0 0);
  }
  .dark .about-version-name { color: oklch(0.85 0 0); }
  .about-version-ver {
    font-size: 0.875rem;
    color: oklch(0.5 0 0);
    margin-top: 0.5rem;
  }
  .dark .about-version-ver { color: oklch(0.55 0 0); }

  /* 统计行内 */
  .about-card--stats-inline {
    padding: 1.25rem 2rem;
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 8px;
    font-size: 18px;
    color: oklch(0.35 0 0);
  }
  .dark .about-card--stats-inline { color: oklch(0.65 0 0); }

  /* ====== 访问统计（深色卡片）===== */
  .about-card--stats {
    padding: 2.25rem 2rem;
    background: linear-gradient(135deg, #0c1c2c 0%, #1a3a52 100%);
    color: #fff;
    border: none;
  }
  .about-card--stats:hover {
    border-color: transparent;
  }
  .dark .about-card--stats {
    background: linear-gradient(135deg, #0a1520 0%, #162d42 100%);
  }

  .about-stats__glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(circle at 30% 50%, rgba(73, 177, 245, 0.12) 0%, transparent 50%),
      radial-gradient(circle at 70% 80%, rgba(120, 194, 244, 0.08) 0%, transparent 50%);
  }
  .about-stats__tips,
  .about-stats__title {
    position: relative;
    z-index: 1;
  }
  .about-stats__tips {
    color: rgba(255,255,255,0.7);
  }
  .about-stats__title {
    color: #fff;
  }

  .about-stats__grid {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    margin: auto 0;
    position: relative;
    z-index: 1;
    gap: 8px;
  }

  .about-stat-item {
    margin-right: 16px;
  }
  .about-stat-label {
    font-size: 0.75rem;
    opacity: 0.7;
    color: #fff;
    display: block;
    margin-bottom: 0.5rem;
  }
  .about-stat-num {
    font-size: 36px;
    font-weight: 700;
    color: #fff;
    display: block;
  }

  /* ====== 游戏卡片 ====== */
  .game-cards {
    display: flex;
    gap: 16px;
    margin-top: 4px;
  }

  .game-card {
    flex: 1;
    border-radius: 12px;
    overflow: hidden;
    min-height: 300px;
    max-height: 380px;
    position: relative;
    background-size: cover;
    background-position: top center;
    background-repeat: no-repeat;
  }

  .game-card::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .game-card--genshin {
    background-image: url('https://img02.anheyu.com/adminuploads/1/2022/12/19/63a079ca63c8a.webp');
  }
  .game-card--genshin::after {
    box-shadow: inset 0 -69px 203px 11px rgba(26,58,82,0.82);
  }

  .game-card--starrail {
    background-image: url('https://pic.seln.cn/file/awa/yiAdvKn8.avif');
  }
  .game-card--starrail::after {
    box-shadow: inset 0 -69px 203px 11px rgba(42,26,94,0.82);
  }

  .game-card__content {
    padding: 1.5rem;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    position: relative;
    z-index: 1;
  }

  .game-card__tips {
    font-size: 0.8rem;
    opacity: 0.85;
    color: #fff;
  }

  .game-card__title {
    font-size: 2rem;
    font-weight: 700;
    color: #fff;
    margin: 8px 0;
  }

  .game-card__bottom {
    position: absolute;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 3;
  }

  .game-card__uid {
    font-size: 0.75rem;
    font-weight: 500;
    color: #fff;
    background: transparent;
    border: 1px solid rgba(255,255,255,0.3);
    padding: 0.2rem 0.6rem;
    border-radius: 12px;
    text-shadow: 0 1px 2px rgba(0,0,0,0.5);
    transition: all 0.2s ease;
    display: inline-block;
  }
  .game-card__uid:hover {
    border-color: rgba(255,255,255,0.7);
    background: rgba(255,255,255,0.15);
    transform: translateY(-1px);
  }

  /* ====== 响应式 ====== */
  @media screen and (max-width: 1024px) {
    .about-card {
      padding: 1rem 1.5rem;
    }
    .about-card__title {
      font-size: 2rem;
    }
    .about-card__bg-text {
      font-size: 64px;
      left: -38px;
    }
    .about-card__big-title {
      font-size: 36px;
    }
  }

  @media screen and (max-width: 768px) {
    .about-card--socialize,
    .about-card--creation {
      width: 100%;
    }
    .about-card--site-info {
      width: 100%;
      height: auto;
      min-height: auto;
      max-height: none;
      margin-right: 0;
      margin-bottom: 16px;
      aspect-ratio: auto;
    }
    .about-card--versions {
      flex-wrap: wrap;
      gap: 16px;
    }
    .about-card--stats-inline span {
      width: 50%;
      text-align: center;
    }
    .about-stats__grid {
      flex-wrap: wrap;
      margin: 1.25rem 0;
    }
    .about-stat-item {
      width: 50%;
      margin: 0 0 16px;
    }
    .about-stat-num {
      font-size: 28px;
    }
    .game-cards {
      flex-direction: column;
    }
    .game-card {
      min-height: 220px;
      max-height: 280px;
    }
  }
</style>

<script is:inline>
  (function() {
    // 尝试获取访问统计
    function loadStats() {
      var els = ['stat-today-visitors','stat-today-pv','stat-yesterday-visitors','stat-yesterday-pv','stat-month-pv'];
      var allExist = els.every(function(id) { return !!document.getElementById(id); });
      if (!allExist) return;

      var API = 'http://localhost:4000/api/stats/visit';
      fetch(API).then(function(r) { return r.json(); }).then(function(data) {
        if (data && typeof data === 'object') {
          setVal('stat-today-visitors', data.todayVisitors || data.today_visitors || 0);
          setVal('stat-today-pv', data.todayPageviews || data.today_pageviews || 0);
          setVal('stat-yesterday-visitors', data.yesterdayVisitors || data.yesterday_visitors || 0);
          setVal('stat-yesterday-pv', data.yesterdayPageviews || data.yesterday_pageviews || 0);
          setVal('stat-month-pv', data.monthPageviews || data.month_pageviews || 0);
        }
      }).catch(function() {});
    }

    function setVal(id, val) {
      var el = document.getElementById(id);
      if (el) el.textContent = formatNum(val);
    }

    function formatNum(n) {
      n = Number(n) || 0;
      if (n >= 10000) return (n / 10000).toFixed(1) + 'w';
      if (n >= 1000) return (n / 1000).toFixed(1) + 'k';
      return String(n);
    }

    // 首次加载 + swup 兼容
    setTimeout(loadStats, 200);

    function hook() {
      if (!window.swup || !window.swup.hooks) return;
      window.swup.hooks.on('page:view', function() { setTimeout(loadStats, 300); });
      window.swup.hooks.on('visit:end', function() { setTimeout(loadStats, 300); });
    }
    hook();
    if (!window.swup || !window.swup.hooks) {
      var t = setInterval(function() {
        if (window.swup && window.swup.hooks) { clearInterval(t); hook(); }
      }, 50);
    }
    document.addEventListener('astro:page-load', function() { setTimeout(loadStats, 300); });
  })();
</script>
