---
import BaseLayout from '../layouts/BaseLayout.astro';
import StatsCard from '../components/StatsCard.astro';
---

<BaseLayout title="关于" description="关于本站">
  <section class="mb-10 text-center">
    <h1 class="text-3xl font-extrabold tracking-tight sm:text-4xl">关于</h1>
  </section>

  <div class="prose prose-neutral dark:prose-invert max-w-none post-content mb-10">
    <p>本站访问统计（数据来源：本站后端，无需 Umami）：</p>
  </div>

  <div class="max-w-4xl mx-auto mb-16 px-4">
    <StatsCard />
  </div>

  <div class="prose prose-neutral dark:prose-invert max-w-none post-content">
    <p>占位</p>
  </div>
</BaseLayout>
