---
import BaseLayout from '../layouts/BaseLayout.astro';
import TabNav from '../components/TabNav.astro';
import type { Post } from '../types';

const API_URL = 'http://localhost:4000';
const PER_PAGE = 10;

let posts: Post[] = [];
let error: string | null = null;

try {
  const response = await fetch(`${API_URL}/api/posts`);
  if (!response.ok) {
    throw new Error(`无法加载文章：${response.status}`);
  }
  posts = await response.json();
} catch (err) {
  error = err instanceof Error ? err.message : '未知错误';
}

const sorted = posts
  .slice()
  .sort((a, b) => +new Date(b.createdAt) - +new Date(a.createdAt));

const totalPages = Math.max(1, Math.ceil(sorted.length / PER_PAGE));
const grouped = sorted.reduce<Record<string, Post[]>>((acc, post) => {
  const year = new Date(post.createdAt).getFullYear().toString();
  if (!acc[year]) acc[year] = [];
  acc[year].push(post);
  return acc;
}, {});

const years = Object.keys(grouped).sort((a, b) => +b - +a);

const formatMonthDay = (date: string) =>
  new Date(date).toLocaleDateString('zh-CN', {
    month: '2-digit',
    day: '2-digit',
  });

const serializedPosts = JSON.stringify(sorted);
const serializedTotalPages = JSON.stringify(totalPages);
---

<BaseLayout title="归档 | mccsjs">
  <section class="mb-10 text-center">
    <h1 class="text-3xl font-extrabold tracking-tight sm:text-4xl">归档</h1>
    <p class="mt-3 text-gray-600 dark:text-gray-400">
      共 {posts.length} 篇文章，{Object.keys(grouped).length} 个年份
    </p>
  </section>
  <!-- Nav tabs -->
  <TabNav tabs={[
    { label: '文章', href: '/posts' },
    { label: '归档', href: '/archive' },
    { label: '分类', href: '/categories' },
    { label: '标签', href: '/tags' },
  ]} />
  

    

  {
    error ? (
      <div class="rounded-xl border border-red-100 bg-red-50 p-6 text-center text-red-700">
        <p class="font-medium">加载文章失败</p>
        <p class="mt-1 text-sm">{error}</p>
      </div>
    ) : posts.length === 0 ? (
      <div class="rounded-xl border border-gray-200 bg-white p-12 text-center text-gray-500 dark:border-gray-800 dark:bg-[#111] dark:text-gray-400">
        暂无文章，稍后再来吧
      </div>
    ) : (
      <div id="archive-root">
        <div id="archive-content" class="relative">
          <div class="absolute left-4 top-0 bottom-0 w-px bg-gray-200 sm:left-6 dark:bg-gray-700"></div>

          <div class="space-y-12">
            {years.map((year) => (
              <section class="relative">
                <div class="flex items-center gap-4 mb-6">
                  <div class="relative z-10 flex h-8 w-8 items-center justify-center rounded-full bg-yellow-400 text-sm font-bold text-white shadow-sm sm:h-10 sm:w-10 dark:bg-yellow-500">
                    {year.slice(2)}
                  </div>
                  <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100">{year}</h2>
                  <span class="text-sm text-gray-500 dark:text-gray-400">
                    {grouped[year].length} 篇
                  </span>
                </div>

                <div class="ml-12 space-y-3 sm:ml-16">
                  {grouped[year].map((post) => (
                    <a
                      href={`/posts/${post.slug}`}
                      class="group flex items-start gap-4 rounded-xl border border-gray-200 bg-white p-4 shadow-sm transition-all hover:-translate-y-0.5 hover:shadow-md dark:border-gray-800 dark:bg-[#111]"
                    >
                      <time class="shrink-0 pt-0.5 text-sm font-medium text-gray-400 dark:text-gray-500">
                        {formatMonthDay(post.createdAt)}
                      </time>
                      <div class="min-w-0 flex-1">
                        <h3 class="truncate text-base font-semibold text-gray-900 group-hover:text-yellow-600 dark:text-gray-100 dark:group-hover:text-yellow-400">
                          {post.title}
                        </h3>
                        <div class="mt-1 flex items-center gap-2 text-xs text-gray-500 dark:text-gray-400">
                          <span class="rounded-full bg-yellow-50 px-2 py-0.5 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-400">
                            {post.category.name}
                          </span>
                          {post.tags.length > 0 && (
                            <span class="truncate">
                              {post.tags.map((t) => `#${t.name}`).join(' ')}
                            </span>
                          )}
                        </div>
                      </div>
                    </a>
                  ))}
                </div>
              </section>
            ))}
          </div>
        </div>

        <nav class="mt-10 flex items-center justify-center gap-3" aria-label="分页导航">
          <button
            id="archive-prev"
            type="button"
            class="rounded-lg border px-4 py-2 text-sm transition-colors hover:border-gray-300 disabled:opacity-40 disabled:cursor-not-allowed"
          >
            上一页
          </button>
          <span id="archive-page-info" class="text-sm text-gray-600 dark:text-gray-400">
            第 1 / {totalPages} 页
          </span>
          <button
            id="archive-next"
            type="button"
            class="rounded-lg border px-4 py-2 text-sm transition-colors hover:border-gray-300 disabled:opacity-40 disabled:cursor-not-allowed"
          >
            下一页
          </button>
        </nav>
      </div>
    )
  }
</BaseLayout>

<script define:vars={{ serializedPosts, serializedTotalPages }}>
  const posts = JSON.parse(serializedPosts || '[]');
  const totalPages = Number(serializedTotalPages) || 1;
  const perPage = 10;
  let currentPage = 1;

  const contentEl = document.getElementById('archive-content');
  const prevBtn = document.getElementById('archive-prev');
  const nextBtn = document.getElementById('archive-next');
  const pageInfoEl = document.getElementById('archive-page-info');

  if (!contentEl || !prevBtn || !nextBtn || !pageInfoEl) {
    throw new Error('缺少归档页分页元素');
  }

  function formatMonthDay(date) {
    const d = new Date(date);
    const month = String(d.getMonth() + 1).padStart(2, '0');
    const day = String(d.getDate()).padStart(2, '0');
    return `${month}-${day}`;
  }

  function renderPage(page) {
    currentPage = page;
    const start = (page - 1) * perPage;
    const paged = posts.slice(start, start + perPage);

    const grouped = paged.reduce((acc, post) => {
      const year = new Date(post.createdAt).getFullYear().toString();
      if (!acc[year]) acc[year] = [];
      acc[year].push(post);
      return acc;
    }, {});

    const years = Object.keys(grouped).sort((a, b) => +b - +a);

    let html = '<div class="absolute left-4 top-0 bottom-0 w-px bg-gray-200 dark:bg-gray-700 sm:left-6" />';
    html += '<div class="space-y-12">';

    for (const year of years) {
      html += `
        <section class="relative">
          <div class="flex items-center gap-4 mb-6">
            <div class="relative z-10 flex h-8 w-8 items-center justify-center rounded-full bg-yellow-400 text-sm font-bold text-white shadow-sm sm:h-10 sm:w-10">
              ${year.slice(2)}
            </div>
            <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100">${year}</h2>
            <span class="text-sm text-gray-500 dark:text-gray-400">
              ${grouped[year].length} 篇
            </span>
          </div>
          <div class="ml-12 space-y-3 sm:ml-16">
      `;

      for (const post of grouped[year]) {
        html += `
          <a
            href="/posts/${post.slug}"
            class="group flex items-start gap-4 rounded-xl border border-gray-200 bg-white p-4 shadow-sm transition-all hover:-translate-y-0.5 hover:shadow-md dark:border-gray-800 dark:bg-[#111]"
          >
            <time class="shrink-0 pt-0.5 text-sm font-medium text-gray-400 dark:text-gray-500">
              ${formatMonthDay(post.createdAt)}
            </time>
            <div class="min-w-0 flex-1">
              <h3 class="truncate text-base font-semibold text-gray-900 group-hover:text-yellow-600 dark:text-gray-100 dark:group-hover:text-yellow-400">
                ${post.title}
              </h3>
              <div class="mt-1 flex items-center gap-2 text-xs text-gray-500 dark:text-gray-400">
                <span class="rounded-full bg-yellow-50 px-2 py-0.5 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-400">
                  ${post.category.name}
                </span>
                ${post.tags.length > 0 ? `<span class="truncate">${post.tags.map((t) => `#${t.name}`).join(' ')}</span>` : ''}
              </div>
            </div>
          </a>
        `;
      }

      html += `
          </div>
        </section>
      `;
    }

    html += '</div>';
    contentEl.innerHTML = html;

    prevBtn.disabled = page <= 1;
    nextBtn.disabled = page >= totalPages;
    pageInfoEl.textContent = `第 ${page} / ${totalPages} 页`;
  }

  prevBtn.addEventListener('click', () => {
    if (currentPage > 1) renderPage(currentPage - 1);
  });

  nextBtn.addEventListener('click', () => {
    if (currentPage < totalPages) renderPage(currentPage + 1);
  });
</script>
