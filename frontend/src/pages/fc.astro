---
import BaseLayout from '../layouts/BaseLayout.astro';
import TabNav from '../components/TabNav.astro';

const API_URL = (typeof import.meta !== 'undefined' && import.meta.env && import.meta.env.PUBLIC_API_URL)
  || (typeof process !== 'undefined' && process.env && process.env.PUBLIC_API_URL)
  || '';
const INITIAL_SIZE = 18;
const LOAD_MORE_SIZE = 12;

interface FeedItem {
  id: number;
  friend_id: number;
  friend_name: string;
  friend_url: string;
  friend_avatar: string;
  title: string;
  link: string;
  published_at?: string;
}

interface FeedData {
  list: FeedItem[];
  total: number;
  page: number;
  page_size: number;
}

let feedList: FeedItem[] = [];
let total = 0;
let noMore = false;

try {
  const res = await fetch(`${API_URL}/api/friends/feed?page=1&page_size=${INITIAL_SIZE}`);
  if (res.ok) {
    const data = await res.json();
    if (data.code === 0) {
      feedList = data.data.list || [];
      total = data.data.total || 0;
      noMore = feedList.length >= total;
    }
  }
} catch {}

function friendDomain(url: string): string {
  try {
    return new URL(url).hostname;
  } catch {
    return url;
  }
}

function timeAgo(dateStr?: string): string {
  if (!dateStr) return '';
  const date = new Date(dateStr);
  const diff = Date.now() - date.getTime();
  const minutes = Math.floor(diff / 60000);
  if (minutes < 1) return '刚刚';
  if (minutes < 60) return `${minutes} 分钟前`;
  const hours = Math.floor(diff / 3600000);
  if (hours < 24) return `${hours} 小时前`;
  const year = date.getFullYear();
  const month = String(date.getMonth() + 1).padStart(2, '0');
  const day = String(date.getDate()).padStart(2, '0');
  if (year === new Date().getFullYear()) {
    return `${month}-${day}`;
  }
  return `${year}-${month}-${day}`;
}
---

<BaseLayout title="朋友圈" wide description="汇集友链博客的最新文章动态">
  <section class="mb-10 text-center">
    <h1 class="text-3xl font-extrabold tracking-tight sm:text-4xl">朋友圈</h1>
    <p class="mt-3 text-[rgb(var(--fg-soft))] dark:text-[rgb(var(--fg-muted))]">汇集友链博客的最新文章动态</p>
  </section>

  <TabNav tabs={[
    { label: '友链', href: '/link' },
    { label: '朋友圈', href: '/fc' },
  ]} />

  <!-- 空状态 -->
  {
    feedList.length === 0 && (
      <div class="rounded-xl border border-[rgb(var(--card-border))] bg-[rgb(var(--card-bg))] p-12 text-center text-[rgb(var(--fg-muted))] dark:border-[rgb(var(--card-border))] dark:bg-[rgb(var(--card-bg))] dark:text-[rgb(var(--fg-muted))]">
        <svg class="mx-auto mb-4 h-12 w-12 text-[rgb(var(--fg-muted))]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
        </svg>
        <p>暂无文章，配置 RSS 后会自动抓取</p>
      </div>
    )
  }

  <!-- 文章网格 -->
  {
    feedList.length > 0 && (
      <div id="fc-grid" data-total={total} class="grid gap-3 grid-cols-2 md:grid-cols-2 lg:grid-cols-3">
        {feedList.map((item) => (
          <a
            href={item.link}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex flex-col gap-2 rounded-xl border border-[rgb(var(--card-border))] bg-[rgb(var(--card-bg))] p-3 sm:p-4 shadow-sm transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md dark:border-[rgb(var(--card-border))] dark:bg-[rgb(var(--card-bg))]"
          >
            <div class="flex items-center gap-2.5">
              <img
                src={item.friend_avatar}
                alt={item.friend_name}
                class="h-8 w-8 rounded-full object-cover bg-[rgb(var(--bg-soft))] sm:h-9 sm:w-9"
                loading="lazy"
                onerror="this.style.display='none'"
              />
              <span class="text-sm font-semibold text-[rgb(var(--fg))] group-hover:text-yellow-700 dark:group-hover:text-yellow-300">{item.friend_name}</span>
            </div>
            <div class="flex-1 text-sm font-medium text-[rgb(var(--fg))] line-clamp-2 leading-relaxed">
              {item.title}
            </div>
            <div class="flex items-center justify-between gap-2">
              <span class="text-xs text-[rgb(var(--fg-muted))] truncate">{friendDomain(item.link)}</span>
              <span class="text-xs text-[rgb(var(--fg-muted))] shrink-0">{timeAgo(item.published_at)}</span>
            </div>
          </a>
        ))}
      </div>
    )
  }

  <!-- 加载更多 -->
  {
    !noMore && feedList.length > 0 && (
      <div class="mt-8 text-center">
        <button id="fc-loadmore" class="fc-loadmore-btn rounded-full border border-[rgb(var(--card-border))] bg-[rgb(var(--card-bg))] px-8 py-3 text-sm font-medium text-[rgb(var(--fg))] transition-all duration-200 disabled:opacity-50">
          再来亿点
        </button>
      </div>
    )
  }
</BaseLayout>

<style>
  .fc-loadmore-btn:hover:not(:disabled) {
    background: #f5d800 !important;
    color: #333 !important;
    border-color: #f5d800 !important;
  }
</style>

<script>
  const LOAD_MORE_SIZE = 12;
  let page = 1;
  let loading = false;
  let noMore = false;
  let totalLoaded = 0;
  let total = 0;
  const grid = document.getElementById('fc-grid');
  const btn = document.getElementById('fc-loadmore');

  totalLoaded = grid?.children.length || 0;
  total = parseInt(grid?.dataset.total || '0');

  function timeAgo(dateStr) {
    if (!dateStr) return '';
    const date = new Date(dateStr);
    const diff = Date.now() - date.getTime();
    const minutes = Math.floor(diff / 60000);
    if (minutes < 1) return '刚刚';
    if (minutes < 60) return `${minutes} 分钟前`;
    const hours = Math.floor(diff / 3600000);
    if (hours < 24) return `${hours} 小时前`;
    const year = date.getFullYear();
    const month = String(date.getMonth() + 1).padStart(2, '0');
    const day = String(date.getDate()).padStart(2, '0');
    if (year === new Date().getFullYear()) {
      return `${month}-${day}`;
    }
    return `${year}-${month}-${day}`;
  }

  function friendDomain(url) {
    try {
      return new URL(url).hostname;
    } catch {
      return url;
    }
  }

  function createCard(item) {
    const a = document.createElement('a');
    a.href = item.link;
    a.target = '_blank';
    a.rel = 'noopener noreferrer';
    a.className = 'group flex flex-col gap-2 rounded-xl border border-[rgb(var(--card-border))] bg-[rgb(var(--card-bg))] p-3 sm:p-4 shadow-sm transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md dark:border-[rgb(var(--card-border))] dark:bg-[rgb(var(--card-bg))]';
    a.innerHTML = `
      <div class="flex items-center gap-2.5">
        <img src="${item.friend_avatar}" alt="${item.friend_name}" class="h-8 w-8 rounded-full object-cover bg-[rgb(var(--bg-soft))] sm:h-9 sm:w-9" loading="lazy" onerror="this.style.display='none'" />
        <span class="text-sm font-semibold text-[rgb(var(--fg))] group-hover:text-yellow-700 dark:group-hover:text-yellow-300">${item.friend_name}</span>
      </div>
      <div class="flex-1 text-sm font-medium text-[rgb(var(--fg))] line-clamp-2 leading-relaxed">${item.title}</div>
      <div class="flex items-center justify-between gap-2">
        <span class="text-xs text-[rgb(var(--fg-muted))] truncate">${friendDomain(item.link)}</span>
        <span class="text-xs text-[rgb(var(--fg-muted))] shrink-0">${timeAgo(item.published_at)}</span>
      </div>
    `;
    return a;
  }

  async function loadMore() {
    if (loading || noMore) return;
    loading = true;
    btn.textContent = '加载中...';
    btn.disabled = true;

    try {
      const res = await fetch(`${API_URL}/api/friends/feed?page=${page + 1}&page_size=${LOAD_MORE_SIZE}`);
      const data = await res.json();
      if (data.code === 0 && data.data.list.length > 0) {
        page++;
        totalLoaded += data.data.list.length;
        const fragment = document.createDocumentFragment();
        data.data.list.forEach(item => fragment.appendChild(createCard(item)));
        grid.appendChild(fragment);
        noMore = totalLoaded >= total;
        if (noMore) {
          btn.style.display = 'none';
        }
      } else {
        noMore = true;
        btn.style.display = 'none';
      }
    } catch {
      console.warn('加载更多失败');
    } finally {
      loading = false;
      if (!noMore) {
        btn.textContent = '再来亿点';
        btn.disabled = false;
      }
    }
  }

  btn?.addEventListener('click', loadMore);
</script>
