---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import type { Post } from '../types';

// serverless 化：首页按需渲染，最新文章实时可见
export const prerender = false;

const API_URL = (typeof import.meta !== 'undefined' && import.meta.env && import.meta.env.PUBLIC_API_URL)
  || (typeof process !== 'undefined' && process.env && process.env.PUBLIC_API_URL)
  || '';

let posts: Post[] = [];
let error: string | null = null;
let siteTitle = 'mccsjs';

// 获取文章列表
try {
  const response = await fetch(`${API_URL}/api/posts`);
  if (!response.ok) {
    throw new Error(`无法加载文章：${response.status}`);
  }
  posts = await response.json();
} catch (err) {
  error = err instanceof Error ? err.message : '未知错误';
}

// 获取网站标题（独立请求，失败不影响页面）
try {
  const settingsRes = await fetch(`${API_URL}/api/settings`);
  if (settingsRes.ok) {
    const settings = await settingsRes.json();
    siteTitle = settings.siteTitle || 'mccsjs';
  }
} catch {
  // 获取失败使用默认值
}

const latestPosts = posts.slice(0, 6);
---

<BaseLayout description={siteTitle + ' — 个人博客，分享技术文章与生活感悟'}>
  <section class="relative overflow-hidden rounded-3xl text-center sm:py-24">
    <img
      src="/hero.webp"
      alt="Hero"
      class="absolute inset-0 h-full w-full object-cover"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/30 via-black/40 to-black/60"></div>
    <div class="relative px-6 py-16">
      <h1 class="neon-text text-5xl font-extrabold tracking-tight text-white drop-shadow-lg">
        {siteTitle}
      </h1>
      <p class="mt-4 text-lg text-white/85 min-h-[4.5rem]">
        <span id="typewriter-text" class="neon-text"></span><span id="typewriter-cursor" class="ml-1 animate-blink">|</span>
      </p>
    </div>
  </section>

  <section class="mt-16">
    <div class="mb-8 flex items-end justify-between">
      <div>
        <h2 class="text-2xl font-bold">最新文章</h2>
        <p class="mt-1 text-[rgb(var(--fg-soft))]">看看最近发布了什么</p>
      </div>
      <a href="/posts" class="text-sm font-medium text-[rgb(var(--primary))] hover:brightness-110">
        查看全部 →
      </a>
    </div>

    {
      error ? (
        <div class="rounded-xl border border-red-100 bg-red-50 p-6 text-center text-red-700">
          <p class="font-medium">加载文章失败</p>
          <p class="mt-1 text-sm">{error}</p>
        </div>
      ) : latestPosts.length === 0 ? (
        <div class="rounded-xl border p-12 text-center text-[rgb(var(--fg-soft))]" style="border-color: rgb(var(--border) / 0.4); background: rgb(var(--surface));">
          暂无文章，稍后再来吧
        </div>
      ) : (
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {latestPosts.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
      )
    }
  </section>

<script is:inline data-swup-reload-script>
  (function () {
    // 代次机制：每次脚本运行时递增，旧实例的回调发现代次不匹配就自动退出
    window.__twGen = (window.__twGen || 0) + 1;
    var myGen = window.__twGen;

    var textEl = document.getElementById('typewriter-text');
    if (!textEl) return;

    var TYPING_SPEED = 80;
    var DELETING_SPEED = 40;
    var PAUSE_AFTER_TYPE = 2500;
    var PAUSE_BEFORE_START = 600;

    var mainText = '';
    var sourceText = '';
    var displayMain = '';
    var displaySource = '';
    var phase = 'typing-main';

    function isStale() {
      return window.__twGen !== myGen;
    }

    async function fetchHitokoto() {
      try {
        var res = await fetch('https://v1.hitokoto.cn');
        var data = await res.json();
        return {
          main: data.hitokoto || '活在珍贵的人间',
          source: data.from ? '——出自 ' + data.from : '',
        };
      } catch (e) {
        return [
          { main: '活在珍贵的人间', source: '' },
          { main: '探索技术的边界', source: '' },
          { main: '记录生活的点滴', source: '' },
        ][Math.floor(Math.random() * 3)];
      }
    }

    function render() {
      if (sourceText && displaySource.length > 0) {
        textEl.innerHTML = displayMain + '<br><span class="type-source">' + displaySource + '</span>';
      } else {
        textEl.textContent = displayMain;
      }
    }

    function tick() {
      if (isStale()) return;
      if (phase === 'typing-main') {
        if (displayMain.length < mainText.length) {
          displayMain = mainText.slice(0, displayMain.length + 1);
          render();
          window.__twTimer = setTimeout(tick, TYPING_SPEED);
        } else {
          phase = sourceText ? 'typing-source' : 'paused';
          window.__twTimer = setTimeout(tick, 400);
        }
      } else if (phase === 'typing-source') {
        if (displaySource.length < sourceText.length) {
          displaySource = sourceText.slice(0, displaySource.length + 1);
          render();
          window.__twTimer = setTimeout(tick, TYPING_SPEED);
        } else {
          phase = 'paused';
          window.__twTimer = setTimeout(tick, PAUSE_AFTER_TYPE);
        }
      } else if (phase === 'paused') {
        phase = 'deleting';
        window.__twTimer = setTimeout(tick, 0);
      } else if (phase === 'deleting') {
        if (displaySource.length > 0) {
          displaySource = displaySource.slice(0, -1);
          render();
          window.__twTimer = setTimeout(tick, DELETING_SPEED);
        } else if (displayMain.length > 0) {
          displayMain = displayMain.slice(0, -1);
          render();
          window.__twTimer = setTimeout(tick, DELETING_SPEED);
        } else {
          displayMain = '';
          displaySource = '';
          phase = 'typing-main';
          window.__twTimer = setTimeout(tick, PAUSE_BEFORE_START);
        }
      }
    }

    async function init() {
      var result = await fetchHitokoto();
      if (isStale()) return;
      mainText = result.main;
      sourceText = result.source;
      displayMain = '';
      displaySource = '';
      phase = 'typing-main';
      tick();
    }

    // 清除旧实例的定时器
    if (window.__twTimer) clearTimeout(window.__twTimer);

    init();
  })();
</script>

<style is:global>
  /* 霓虹灯文字效果 */
  @keyframes light_10px {
    0%, 100% {
      text-shadow:
        0 0 2px rgba(255,255,255,0.65),
        0 0 4px rgba(0,255,170,0.75),
        0 0 8px rgba(0,255,170,0.62);
    }
    50% {
      text-shadow:
        0 0 2px rgba(255,255,255,0.65),
        0 0 4px rgba(255,0,128,0.75),
        0 0 8px rgba(255,0,128,0.62);
    }
  }

  .neon-text {
    animation: light_10px 10s linear infinite;
  }

  @keyframes blink {
    0%, 49% { opacity:1; }
    50%, 100% { opacity:0; }
  }
  .animate-blink {
    animation: blink 1s step-end infinite;
  }
  .type-source {
    font-size: 0.85em;
    color: rgba(255,255,255,0.6);
  }
</style>

</BaseLayout>
