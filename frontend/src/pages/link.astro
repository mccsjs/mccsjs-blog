---
import BaseLayout from '../layouts/BaseLayout.astro';
import TwikooComments from '../components/TwikooComments.astro';
import MarkdownIt from 'markdown-it';

const API_URL = 'http://localhost:4000';

interface FriendItem {
  id: string;
  name: string;
  url: string;
  description: string;
  avatar: string;
  screenshot?: string;
  accessible: number;
  latency: number;
}

interface FriendGroup {
  type_name: string;
  friends: FriendItem[];
}

let groups: FriendGroup[] = [];
let linkMarkdownHtml = '';

const isLostGroup = (name: string) => /失联/.test(name);

try {
  const [friendsRes, settingsRes] = await Promise.all([
    fetch(`${API_URL}/api/friends`),
    fetch(`${API_URL}/api/settings`),
  ]);

  if (friendsRes.ok) {
    const data = await friendsRes.json();
    groups = (data.groups || []).filter((g: FriendGroup) => g.friends.length > 0);
  }

  if (settingsRes.ok) {
    const settings = await settingsRes.json();
    const raw = settings.linkMarkdown || '';
    if (raw) {
      const md = new MarkdownIt({ html: true, linkify: true, typographer: true, breaks: true });
      linkMarkdownHtml = md.render(raw);
    }
  }
} catch {}
---

<BaseLayout title="友链 | mccsjs" wide showComment={true}>
  <section class="mb-10 text-center">
    <h1 class="text-3xl font-extrabold tracking-tight sm:text-4xl">友情链接</h1>
    <p class="mt-3 text-gray-600 dark:text-gray-400">有趣的人与站点，欢迎交换友链</p>
  </section>

  {
    groups.length === 0 ? (
      <div class="rounded-xl border border-gray-200 bg-white p-12 text-center text-gray-500 dark:border-gray-800 dark:bg-[#111] dark:text-gray-400">
        暂无友链，稍后再来吧
      </div>
    ) : (
      groups.map((group) => {
        const lost = isLostGroup(group.type_name);
        return (
          <section class="mb-12">
            <h2 class="mb-5 text-lg font-bold text-gray-900 dark:text-gray-100">
              {group.type_name}
            </h2>
            {lost ? (
              <div class="flex flex-wrap items-center gap-x-6 gap-y-2">
                {group.friends.map((friend) => (
                  <span class="text-sm text-gray-500 dark:text-gray-400">{friend.name}</span>
                ))}
              </div>
            ) : (
              <div class="grid gap-4 grid-cols-2 lg:grid-cols-6">
                {group.friends.map((friend) => (
                  <a
                    href={friend.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group block overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm transition-all hover:-translate-y-0.5 hover:shadow-md dark:border-gray-800 dark:bg-[#111]"
                  >
                    <div class="relative h-32 w-full overflow-hidden bg-gray-100 dark:bg-gray-800">
                      {friend.screenshot ? (
                        <img src={friend.screenshot} alt={friend.name} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
                      ) : (
                        <div class="flex h-full w-full items-center justify-center text-xs text-gray-400 dark:text-gray-500">暂无截图</div>
                      )}
                      <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent" />
                      {friend.latency > 0 || friend.accessible === 1 ? (
                    <div class="absolute top-1 left-1 flex items-center gap-0.5 rounded-full px-1 py-px text-[9px] font-medium shadow-sm"
                      class:list={[
                        friend.accessible === 1
                          ? 'bg-red-500/90 text-white'
                          : friend.latency <= 4000
                            ? 'bg-green-500/90 text-white'
                            : 'bg-yellow-400/90 text-yellow-900'
                      ]}
                    >
                      {friend.accessible === 0 ? (
                        <span>{(friend.latency / 1000).toFixed(2)}s</span>
                      ) : (
                        <span>不可用</span>
                      )}
                        </div>
                      ) : null}
                    </div>
                    <div class="flex items-start gap-2.5 py-1 px-2 h-[54px]">
                      <div class="h-9 w-9 shrink-0 -ml-1 rounded-full border-2 border-gray-200 bg-gray-50 dark:border-gray-700 dark:bg-gray-800">
                        {friend.avatar ? (
                          <img src={friend.avatar} alt={friend.name} class="h-full w-full rounded-full object-cover" />
                        ) : (
                          <span class="text-[10px] font-bold text-gray-500 dark:text-gray-300 flex h-full items-center justify-center">{friend.name.charAt(0)}</span>
                        )}
                      </div>
                      <div class="min-w-0">
                        <h3 class="truncate text-xs font-semibold text-gray-900 group-hover:text-yellow-700 dark:text-gray-100 dark:group-hover:text-yellow-300">
                          {friend.name}
                        </h3>
                        <p class="mt-0 line-clamp-2 text-xs leading-snug text-gray-500 dark:text-gray-400">
                          {friend.description || friend.url}
                        </p>
                      </div>
                    </div>
                  </a>
                ))}
              </div>
            )}
          </section>
        );
      })
    )
  }

  {
    linkMarkdownHtml && (
      <section id="link-markdown-section" class="mb-10">
        <div class="prose dark:prose-invert max-w-none rounded-xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-[#111]"
          set:html={linkMarkdownHtml}
        ></div>
      </section>
    )
  }

  <section id="comments" class="mt-14">
    <h2 class="text-2xl font-bold">评论</h2>
    <div class="mt-6">
      <TwikooComments />
    </div>
  </section>
</BaseLayout>
