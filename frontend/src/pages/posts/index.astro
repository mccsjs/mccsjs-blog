---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import TabNav from '../../components/TabNav.astro';
import type { Post } from '../../types';

const API_URL = (typeof import.meta !== 'undefined' && import.meta.env && import.meta.env.PUBLIC_API_URL)
  || (typeof process !== 'undefined' && process.env && process.env.PUBLIC_API_URL)
  || '';

// 每页篇数与管理端「每页文章数」(postsPerPage) 绑定；构建时读一次用于首屏无闪烁
let postsPerPage = 10; // 与 defaultSettings.postsPerPage 一致
try {
  const sResp = await fetch(`${API_URL}/api/settings`);
  if (sResp.ok) {
    const settings = await sResp.json();
    const n = parseInt(settings.postsPerPage, 10);
    if (!isNaN(n) && n >= 1 && n <= 100) postsPerPage = n;
  }
} catch {
  // 网络异常时沿用默认 10
}

const PER_PAGE = postsPerPage;

let posts: Post[] = [];
let error: string | null = null;

try {
  const response = await fetch(`${API_URL}/api/posts`);
  if (!response.ok) {
    throw new Error(`无法加载文章：${response.status}`);
  }
  posts = await response.json();
} catch (err) {
  error = err instanceof Error ? err.message : '未知错误';
}

const totalPages = Math.max(1, Math.ceil(posts.length / PER_PAGE));
const serializedTotalPages = JSON.stringify(totalPages);
const serializedPerPage = JSON.stringify(PER_PAGE);
---

<BaseLayout title="文章" description="浏览全部文章，按时间倒序排列">
  <section class="mb-10 text-center">
    <h1 class="text-3xl font-extrabold tracking-tight sm:text-4xl">全部文章</h1>
    <p class="mt-3 text-[rgb(var(--fg-soft))] dark:text-[rgb(var(--fg-muted))]">共 {posts.length} 篇文章</p>
  </section>
  <!-- Nav tabs -->
  <TabNav tabs={[
    { label: '文章', href: '/posts' },
    { label: '归档', href: '/archive' },
    { label: '分类', href: '/categories' },
    { label: '标签', href: '/tags' },
  ]} />

  {
    error ? (
      <div class="rounded-xl border border-red-100 bg-red-50 p-6 text-center text-red-700">
        <p class="font-medium">加载文章失败</p>
        <p class="mt-1 text-sm">{error}</p>
      </div>
    ) : posts.length === 0 ? (
      <div class="rounded-xl border border-[rgb(var(--card-border))] bg-[rgb(var(--card-bg))] p-12 text-center text-[rgb(var(--fg-muted))] dark:border-[rgb(var(--card-border))] dark:bg-[rgb(var(--card-bg))] dark:text-[rgb(var(--fg-muted))]">
        暂无文章，稍后再来吧
      </div>
    ) : (
      <>
        <div id="posts-grid" class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {posts.map((post, i) => (
            <div class={`post-item${i < PER_PAGE ? '' : ' hidden'}`} data-index={i}>
              <PostCard post={post} />
            </div>
          ))}
        </div>

        <nav id="posts-pagination" class="mt-12 flex flex-wrap items-center justify-center gap-2" aria-label="分页导航"></nav>
      </>
    )
  }
</BaseLayout>

<script define:vars={{ serializedTotalPages, serializedPerPage }} data-swup-reload-script>
  const grid = document.getElementById('posts-grid');
  const pager = document.getElementById('posts-pagination');
  if (grid && pager) {
    const items = Array.from(grid.querySelectorAll('.post-item'));
    // 运行时优先读管理端「每页文章数」，确保改设置后立即生效（无需重新构建）
    let perPage = Number(serializedPerPage) || 10;
    let totalPages = Math.max(1, Math.ceil(items.length / perPage));
    let current = 1;
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let animating = false;

    const BTN = 'inline-flex h-10 min-w-10 items-center justify-center rounded-xl border px-3 text-sm font-medium transition-all duration-200';
    const NORMAL = 'border-[rgb(var(--card-border))] text-[rgb(var(--fg))] hover:-translate-y-0.5 hover:border-[rgb(var(--primary))] hover:text-[rgb(var(--primary))]';
    const ACTIVE = 'border-[rgb(var(--primary))] bg-[rgb(var(--primary))] text-white';
    const DISABLED = 'opacity-40 cursor-not-allowed';

    function pageList(cur, total) {
      if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);
      const set = new Set([1, total, cur - 1, cur, cur + 1]);
      const arr = [...set].filter((p) => p >= 1 && p <= total).sort((a, b) => a - b);
      const out = [];
      let prev = 0;
      for (const p of arr) {
        if (p - prev > 1) out.push('...');
        out.push(p);
        prev = p;
      }
      return out;
    }

    function renderPager() {
      if (totalPages <= 1) {
        pager.innerHTML = '';
        return;
      }
      let html = '';
      html += `<button type="button" data-page="${current - 1}" ${current === 1 ? 'disabled' : ''} class="${BTN} ${NORMAL} ${current === 1 ? DISABLED : ''}">上一页</button>`;
      for (const p of pageList(current, totalPages)) {
        if (p === '...') {
          html += `<span class="${BTN} border-transparent cursor-default">…</span>`;
        } else {
          const cls = p === current ? ACTIVE : NORMAL;
          html += `<button type="button" data-page="${p}" class="${BTN} ${cls}">${p}</button>`;
        }
      }
      html += `<button type="button" data-page="${current + 1}" ${current === totalPages ? 'disabled' : ''} class="${BTN} ${NORMAL} ${current === totalPages ? DISABLED : ''}">下一页</button>`;
      pager.innerHTML = html;
    }

    function setHidden(p) {
      const start = (p - 1) * perPage;
      const end = start + perPage;
      items.forEach((el) => {
        const idx = Number(el.dataset.index);
        el.classList.toggle('hidden', idx < start || idx >= end);
      });
    }

    function applyPage(p) {
      current = Math.min(Math.max(1, p), totalPages);
      if (reduceMotion) {
        setHidden(current);
        renderPager();
        window.scrollTo({ top: 0, behavior: 'auto' });
        return;
      }
      if (animating) return;
      animating = true;
      // 1) 整页淡出，再做切换
      grid.style.opacity = '0';
      window.setTimeout(() => {
        // 2) 切换到目标页，并让新卡片处于入场前状态
        setHidden(current);
        const visible = items.filter((el) => !el.classList.contains('hidden'));
        visible.forEach((el) => el.classList.add('is-enter'));
        // 强制重排，使 is-enter 初始态生效，后续移除才能触发过渡
        void grid.offsetWidth;
        grid.style.opacity = '1';
        // 3) 错峰淡入上滑
        visible.forEach((el, i) => {
          window.setTimeout(() => el.classList.remove('is-enter'), i * 45);
        });
        window.setTimeout(() => { animating = false; }, visible.length * 45 + 80);
        renderPager();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }, 230);
    }

    pager.addEventListener('click', (e) => {
      const t = e.target.closest('button[data-page]');
      if (!t || t.disabled) return;
      const p = Number(t.dataset.page);
      applyPage(p);
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    // 拉取管理端实时设置，覆盖构建时的值
    async function syncPerPageFromSettings() {
      try {
        const apiUrl = (window.__API_URL__ || '');
        const r = await fetch(`${apiUrl}/api/settings`);
        if (!r.ok) return;
        const s = await r.json();
        const n = parseInt(s.postsPerPage, 10);
        if (!isNaN(n) && n >= 1 && n <= 100) {
          perPage = n;
          totalPages = Math.max(1, Math.ceil(items.length / perPage));
        }
      } catch {
        // 失败时沿用构建时的值
      }
    }

    (async () => {
      await syncPerPageFromSettings();
      applyPage(1);
    })();
  }
</script>
