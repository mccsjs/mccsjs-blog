---
import BaseLayout from '../../layouts/BaseLayout.astro';
import type { Post } from '../../types';

const API_URL = 'http://localhost:4000';

export async function getStaticPaths() {
  const response = await fetch('http://localhost:4000/api/tags');
  const tags = await response.json();
  return tags.map((tag: { slug: string }) => ({
    params: { slug: tag.slug },
  }));
}

const { slug } = Astro.params;

let posts: Post[] = [];
let error: string | null = null;
let tagName = '';

try {
  const response = await fetch(`${API_URL}/api/posts?tagSlug=${encodeURIComponent(slug || '')}`);
  if (!response.ok) {
    throw new Error(`无法加载文章：${response.status}`);
  }
  posts = await response.json();
} catch (err) {
  error = err instanceof Error ? err.message : '未知错误';
}

if (posts.length > 0) {
  const matchedTag = posts[0].tags.find((t) => t.slug === slug);
  if (matchedTag) {
    tagName = matchedTag.name;
  }
}
---

<BaseLayout title={tagName ? `#${tagName}` : '标签'} description={tagName ? `标签「#${tagName}」下的全部文章` : '按标签浏览文章'}>
  <section class="mb-10 text-center">
    <h1 class="text-3xl font-extrabold tracking-tight sm:text-4xl">#{tagName || '标签'}</h1>
    <p class="mt-3 text-[rgb(var(--fg-soft))] dark:text-[rgb(var(--fg-muted))]">共 {posts.length} 篇文章</p>
  </section>

  {
    error ? (
      <div class="rounded-xl border border-red-100 bg-red-50 dark:bg-red-900/20 dark:border-red-800 dark:text-red-300 p-6 text-center text-red-700">
        <p class="font-medium">加载文章失败</p>
        <p class="mt-1 text-sm">{error}</p>
      </div>
    ) : posts.length === 0 ? (
      <div class="rounded-xl border border-[rgb(var(--card-border))] bg-[rgb(var(--card-bg))] p-12 text-center text-[rgb(var(--fg-muted))] dark:border-[rgb(var(--card-border))] dark:bg-[rgb(var(--card-bg))] dark:text-[rgb(var(--fg-muted))]">
        该标签下暂无文章
      </div>
    ) : (
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => (
          <a
            href={`/posts/${post.slug}`}
            class="group rounded-xl border border-[rgb(var(--card-border))] bg-[rgb(var(--card-bg))] p-6 shadow-sm transition-all hover:-translate-y-0.5 hover:shadow-md dark:border-[rgb(var(--card-border))] dark:bg-[rgb(var(--card-bg))]"
          >
            <h2 class="text-lg font-semibold text-[rgb(var(--fg))] group-hover:text-yellow-600 dark:text-[rgb(var(--fg))] dark:group-hover:text-yellow-400">
              {post.title}
            </h2>
            <p class="mt-2 line-clamp-2 text-sm text-[rgb(var(--fg-soft))] dark:text-[rgb(var(--fg-muted))]">
              {post.description || ''}
            </p>
          </a>
        ))}
      </div>
    )
  }
</BaseLayout>
