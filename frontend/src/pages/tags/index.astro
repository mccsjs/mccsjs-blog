---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TabNav from '../../components/TabNav.astro';

const API_URL = 'http://localhost:4000';

interface Tag {
  id: string;
  name: string;
  slug: string;
}

let tags: Tag[] = [];
let error: string | null = null;

try {
  const response = await fetch(`${API_URL}/api/tags`);
  if (!response.ok) throw new Error(`无法加载标签：${response.status}`);
  tags = await response.json();
} catch (err) {
  error = err instanceof Error ? err.message : '未知错误';
}
---

<BaseLayout title="标签" description="按标签浏览文章">
  <section class="mb-10 text-center">
    <h1 class="text-3xl font-extrabold tracking-tight sm:text-4xl">标签</h1>
    <p class="mt-3 text-[rgb(var(--fg-soft))] dark:text-[rgb(var(--fg-muted))]">共 {tags.length} 个标签</p>
  </section>
  <TabNav tabs={[
    { label: '文章', href: '/posts' },
    { label: '归档', href: '/archive' },
    { label: '分类', href: '/categories' },
    { label: '标签', href: '/tags' },
  ]} />

  {
    error ? (
      <div class="rounded-xl border border-red-100 bg-red-50 p-6 text-center text-red-700">
        <p class="font-medium">加载标签失败</p>
        <p class="mt-1 text-sm">{error}</p>
      </div>
    ) : tags.length === 0 ? (
      <div class="rounded-xl border border-[rgb(var(--card-border))] bg-[rgb(var(--card-bg))] p-12 text-center text-[rgb(var(--fg-muted))] dark:border-[rgb(var(--card-border))] dark:bg-[rgb(var(--card-bg))] dark:text-[rgb(var(--fg-muted))]">
        暂无标签
      </div>
    ) : (
      <div class="flex flex-wrap justify-center gap-3">
        {tags.map((tag) => (
          <a
            href={`/tags/${tag.slug}`}
            class="inline-flex items-center rounded-full border border-[rgb(var(--card-border))] bg-[rgb(var(--card-bg))] px-4 py-2 text-sm font-medium text-[rgb(var(--fg-soft))] transition-colors hover:border-gray-300 hover:text-[rgb(var(--fg))] dark:border-[rgb(var(--card-border))] dark:bg-[rgb(var(--card-bg))] dark:text-[rgb(var(--fg-muted))] dark:hover:border-gray-600 dark:hover:text-[rgb(var(--fg))]"
          >
            #{tag.name}
          </a>
        ))}
      </div>
    )
  }
</BaseLayout>
